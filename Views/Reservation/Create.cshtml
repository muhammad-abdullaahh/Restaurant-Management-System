@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        AOS.init({
            duration: 800,
            once: true,
            offset: 50
        });

        constCOST_PER_PERSON = 15;

        function updateCost() {
            const type = document.getElementById('ReservationType').value;
            const partySize = parseInt(document.getElementById('PartySize').value) || 1;
            const costAmount = document.getElementById('cost-amount');
            
            if (type === 'Premium') { 
                const total = partySize * COST_PER_PERSON;
                costAmount.innerText = '$' + total;
            }
        }

        function selectPremiumTable() {
            setReservationType('Premium');
            const form = document.getElementById('reservationForm');
            if(form) form.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }

        function setReservationType(type) {
            document.getElementById('ReservationType').value = type;
            const toggleBg = document.getElementById('toggle-bg');
            const btnStandard = document.getElementById('btn-standard');
            const btnPrivate = document.getElementById('btn-private');
            const btnPremium = document.getElementById('btn-premium');
            
            const infoPrivate = document.getElementById('private-party-info');
            const infoPremium = document.getElementById('premium-info');
            
            // Reset all buttons text color
            [btnStandard, btnPrivate, btnPremium].forEach(btn => {
                btn.classList.remove('text-black', 'dark:text-white', 'text-white-force-dark');
                btn.classList.add('text-gray-500', 'hover:text-black', 'dark:text-gray-400', 'dark:hover:text-white');
            });
            
            // Hide all info boxes
            infoPrivate.classList.add('hidden');
            infoPremium.classList.add('hidden');

            if (type === 'Standard') {
                toggleBg.style.transform = 'translateX(0)';
                btnStandard.classList.remove('text-gray-500', 'dark:text-gray-400');
                btnStandard.classList.add('text-black');
            } 
            else if (type === 'PrivateParty') {
                toggleBg.style.transform = 'translateX(100%)';
                btnPrivate.classList.remove('text-gray-500', 'dark:text-gray-400');
                btnPrivate.classList.add('text-black', 'dark:text-white', 'text-white-force-dark');
                infoPrivate.classList.remove('hidden');
            }
            else if (type === 'Premium') {
                toggleBg.style.transform = 'translateX(200%)';
                btnPremium.classList.remove('text-gray-500', 'dark:text-gray-400');
                btnPremium.classList.add('text-black', 'dark:text-white', 'text-white-force-dark');
                infoPremium.classList.remove('hidden');
            }
            
            updateCost();
        }

        document.getElementById('PartySize').addEventListener('change', updateCost);

        // Mouse Parallax for Hero Background
        document.addEventListener('mousemove', function(e) {
            const heroBg = document.getElementById('hero-bg');
            const heroSection = document.getElementById('hero-section');
            if (heroSection && heroBg && heroSection.matches(':hover')) {
                const x = (e.clientX / window.innerWidth - 0.5) * 20; 
                const y = (e.clientY / window.innerHeight - 0.5) * 20;
                heroBg.style.transform = `translate(calc(-50% + ${-x}px), calc(-50% + ${-y}px)) scale(1.05)`;
            }
        });
        
        // Simple parallax for fixed bg effect
        window.addEventListener('scroll', function() {
            const scroll = window.pageYOffset;
            const fixedBgs = document.querySelectorAll('.fixed-bg-effect');
            fixedBgs.forEach(bg => {
                bg.style.transform = `translateY(${scroll * 0.15}px)`;
            });
        });
    </script>
}

<style>
    .animate-float {
        animation: float 6s ease-in-out infinite;
    }
    .animate-spin-slow {
        animation: spin 12s linear infinite;
    }
    .animate-bounce-slow {
        animation: bounce 3s infinite;
    }
    .animation-delay-500 { animation-delay: 500ms; }
    .animation-delay-1000 { animation-delay: 1000ms; }
    
    .custom-scrollbar::-webkit-scrollbar {
        width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background-color: rgba(0,0,0,0.2);
        border-radius: 4px;
    }
    
    .perspective-1000 {
        perspective: 1000px;
    }
    
    .preserve-3d {
        transform-style: preserve-3d;
    }

    @@keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-20px); }
    }
</style>
