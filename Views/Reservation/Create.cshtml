@model FoodHeaven.Models.Reservation
@{
    ViewData["Title"] = "Reserve Your Table - FoodHeaven";
}

<!-- AOS & Styles -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<!-- Lottie Player -->
<script src="https://unpkg.com/@@dotlottie/player-component@latest/dist/dotlottie-player.mjs" type="module"></script>

<!-- Hero Section with Mouse Parallax -->
<div class="relative h-[65vh] min-h-[600px] w-full overflow-hidden flex items-center justify-center bg-zinc-900 group" id="hero-section">
    <div class="absolute inset-0 z-0 overflow-hidden">
        <img id="hero-bg" src="~/images/restaurant_hero_bg.png" class="w-[110%] h-[110%] object-cover opacity-80 absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 transition-transform duration-100 ease-out" style="transform: translate(-50%, -50%) scale(1.05);" />
        <div class="absolute inset-0 bg-gradient-to-t from-background-light dark:from-background-dark via-transparent to-black/70"></div>
    </div>
    
    <!-- Floating Particles -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-primary rounded-full animate-float opacity-50"></div>
        <div class="absolute top-3/4 left-1/3 w-3 h-3 bg-white rounded-full animate-float animation-delay-500 opacity-30"></div>
        <div class="absolute top-1/2 right-1/4 w-2 h-2 bg-primary rounded-full animate-float animation-delay-1000 opacity-50"></div>
    </div>

    <div class="relative z-10 text-center px-4 mt-16 max-w-4xl">
        <span class="text-primary font-bold tracking-[0.4em] uppercase mb-4 block animate-fade-in-down drop-shadow-lg" data-aos="fade-down" data-aos-delay="100">Make It Memorable</span>
        <h1 class="text-6xl md:text-8xl font-display font-black text-white mb-6 animate-fade-in-up drop-shadow-xl tracking-tight leading-tight" data-aos="fade-up" data-aos-delay="200">
            Book <span class="italic text-transparent bg-clip-text bg-gradient-to-r from-primary to-yellow-200">Your Spot</span>
        </h1>
        <p class="text-white/90 text-xl font-light leading-relaxed animate-fade-in-up animation-delay-300 drop-shadow-md max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="300">
             Whether it's a romantic dinner for two or a private celebration for twenty, we create the perfect atmosphere for you.
        </p>
    </div>
</div>

<!-- Main Content Split Layout -->
<main class="container mx-auto px-4 py-8 relative z-20 -mt-32 mb-24">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12">
        
        <!-- Left Column: Reservation Form -->
        <div class="lg:w-7/12 order-2 lg:order-1" data-aos="fade-right" data-aos-delay="400">
            <div class="bg-white/90 dark:bg-card-dark/90 backdrop-blur-xl rounded-[2.5rem] p-8 md:p-12 shadow-2xl border border-white/20 dark:border-white/5 relative overflow-hidden group">
                
                <!-- Animated Gradient Border -->
                <div class="absolute inset-0 border-2 border-transparent rounded-[2.5rem] bg-gradient-to-br from-primary/30 to-transparent opacity-50 pointer-events-none"></div>

                 <!-- Floating Food Icons (Decorative) -->
                <span class="material-symbols-outlined absolute top-10 right-10 text-6xl text-primary/10 animate-spin-slow pointer-events-none select-none">settings_brightness</span>
                <span class="material-symbols-outlined absolute bottom-20 left-6 text-5xl text-primary/5 animate-bounce-slow pointer-events-none select-none">lunch_dining</span>
                <span class="material-symbols-outlined absolute top-1/2 right-[-20px] text-8xl text-primary/5 rotate-12 pointer-events-none select-none">restaurant_menu</span>

                <div class="relative z-10">
                    <div class="mb-8 text-center lg:text-left flex flex-col md:flex-row justify-between items-end gap-4">
                        <div>
                            <span class="text-primary font-bold uppercase tracking-widest text-sm mb-2 block">Start Here</span>
                            <h2 class="text-3xl md:text-4xl font-black text-text-main dark:text-white mb-2">Reservation</h2>
                        </div>
                        
                        <!-- Reservation Type Toggle -->
                        <!-- Reservation Type Toggle -->
                        <div class="bg-gray-100 dark:bg-black/30 p-1.5 rounded-2xl inline-flex relative shadow-inner w-full md:w-auto">
                            <div id="toggle-bg" class="absolute top-1.5 left-1.5 w-[calc(33.33%-4px)] bottom-1.5 bg-white dark:bg-primary rounded-xl shadow-md transition-all duration-300"></div>
                            
                            <button type="button" onclick="setReservationType('Standard')" class="flex-1 relative z-10 px-4 py-2.5 rounded-xl text-xs md:text-sm font-bold transition-colors duration-300 text-black text-center" id="btn-standard">
                                <span class="flex items-center justify-center gap-2"><span class="material-symbols-outlined text-lg">restaurant</span> Standard</span>
                            </button>
                            <button type="button" onclick="setReservationType('PrivateParty')" class="flex-1 relative z-10 px-4 py-2.5 rounded-xl text-xs md:text-sm font-bold transition-colors duration-300 text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white text-center" id="btn-private">
                                <span class="flex items-center justify-center gap-2"><span class="material-symbols-outlined text-lg">celebration</span> Private</span>
                            </button>
                            <button type="button" onclick="setReservationType('Premium')" class="flex-1 relative z-10 px-4 py-2.5 rounded-xl text-xs md:text-sm font-bold transition-colors duration-300 text-gray-500 hover:text-black dark:text-gray-400 dark:hover:text-white text-center" id="btn-premium">
                                <span class="flex items-center justify-center gap-2"><span class="material-symbols-outlined text-lg">diamond</span> Premium</span>
                            </button>
                        </div>
                    </div>

                    <!-- Private Party Info -->
                    <div id="private-party-info" class="hidden mb-6 bg-gradient-to-r from-blue-500/10 to-purple-500/10 border border-blue-500/20 rounded-2xl p-4 animate-fade-in-down">
                        <div class="flex items-start gap-4">
                            <div class="p-2 bg-blue-500/20 rounded-full text-blue-600 dark:text-blue-300">
                                <span class="material-symbols-outlined">celebration</span>
                            </div>
                            <div>
                                <h4 class="font-bold text-blue-900 dark:text-blue-100">Private Party Booking</h4>
                                <p class="text-sm text-blue-800/70 dark:text-blue-200/70">Perfect for large groups and events. We'll contact you to discuss details.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Premium Table Info (With Cost) -->
                    <div id="premium-info" class="hidden mb-6 bg-gradient-to-r from-amber-500/10 to-orange-500/10 border border-amber-500/20 rounded-2xl p-4 animate-fade-in-down">
                        <div class="flex items-start gap-4">
                            <div class="p-2 bg-amber-500/20 rounded-full text-amber-600 dark:text-amber-300">
                                <span class="material-symbols-outlined">diamond</span>
                            </div>
                            <div class="flex-1">
                                <h4 class="font-bold text-amber-900 dark:text-amber-100">Premium Table Experience</h4>
                                <p class="text-sm text-amber-800/70 dark:text-amber-200/70">Guaranteed best view in the house. Includes Priority Service.</p>
                            </div>
                            
                            <!-- Cost Display -->
                            <div id="premium-cost-display" class="flex bg-white dark:bg-black/50 px-4 py-2 rounded-xl shadow-sm border border-amber-500/20 items-center justify-center flex-col">
                                <span class="text-xs uppercase font-bold text-amber-500 tracking-wider">Estimated Cost</span>
                                <span id="cost-amount" class="text-xl font-black text-text-main dark:text-white">$15</span>
                            </div>
                        </div>
                    </div>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="bg-green-500/10 border border-green-500/20 text-green-700 dark:text-green-400 px-6 py-4 rounded-2xl flex items-center gap-4 mb-8 animate-fade-in-up">
                            <dotlottie-player src="https://lottie.host/9e414848-6a3f-4e08-966e-c6c7b944208e/2X0m4k3b3M.json" background="transparent" speed="1" style="width: 50px; height: 50px;" loop autoplay></dotlottie-player>
                            <div>
                                <p class="font-bold">Reservation Successful!</p>
                                <p class="text-sm opacity-80">@TempData["SuccessMessage"]</p>
                            </div>
                        </div>
                    }

                    <form asp-action="Create" method="post" class="space-y-8" id="reservationForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ReservationType" id="ReservationType" value="Standard" />
                        <input type="hidden" name="TableNumber" value="Unassigned" /> <!-- Auto-assigned by staff/system -->
                        
                        <!-- Personal Info Group -->
                        <div class="space-y-6">
                            <h3 class="text-lg font-bold text-text-main dark:text-white flex items-center gap-2 border-b border-gray-100 dark:border-white/5 pb-2">
                                <span class="material-symbols-outlined text-primary animate-pulse">person</span> Contact Information
                            </h3>
                            
                            <div class="space-y-5">
                                <div class="group relative">
                                    <label asp-for="CustomerName" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">Full Name</label>
                                    <div class="relative transform transition-all duration-300 group-hover:-translate-y-1">
                                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">badge</span>
                                        <input asp-for="CustomerName" 
                                               class="w-full pl-12 pr-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-text-main/30 dark:placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium shadow-sm group-hover:shadow-md" 
                                               placeholder="e.g. John Doe" />
                                    </div>
                                    <span asp-validation-for="CustomerName" class="text-red-500 text-xs mt-1 ml-1 font-bold"></span>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                    <div class="group relative">
                                        <label asp-for="Email" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">Email Address</label>
                                        <div class="relative transform transition-all duration-300 group-hover:-translate-y-1">
                                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">mail</span>
                                            <input asp-for="Email" type="email"
                                                   class="w-full pl-12 pr-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-text-main/30 dark:placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium shadow-sm group-hover:shadow-md" 
                                                   placeholder="john@example.com" />
                                        </div>
                                        <span asp-validation-for="Email" class="text-red-500 text-xs mt-1 ml-1 font-bold"></span>
                                    </div>
                                    <div class="group relative">
                                        <label asp-for="PhoneNumber" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">Phone Number <span class="text-xs text-primary font-normal">(For Confirmation SMS)</span></label>
                                        <div class="relative transform transition-all duration-300 group-hover:-translate-y-1">
                                            <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors">smartphone</span>
                                            <input asp-for="PhoneNumber" type="tel"
                                                   class="w-full pl-12 pr-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-text-main/30 dark:placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium shadow-sm group-hover:shadow-md" 
                                                   placeholder="+1 (555) 000-0000" />
                                        </div>
                                        <span asp-validation-for="PhoneNumber" class="text-red-500 text-xs mt-1 ml-1 font-bold"></span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Booking Details Group -->
                        <div class="space-y-6 pt-4">
                            <h3 class="text-lg font-bold text-text-main dark:text-white flex items-center gap-2 border-b border-gray-100 dark:border-white/5 pb-2">
                                <span class="material-symbols-outlined text-primary animate-pulse">event_seat</span> Booking Details
                            </h3>
                            
                            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                                <div class="group relative">
                                    <label asp-for="ReservationDate" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">Date</label>
                                    <div class="relative transform transition-all duration-300 group-hover:-translate-y-1">
                                        <input asp-for="ReservationDate" type="date"
                                               class="w-full px-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium cursor-pointer shadow-sm group-hover:shadow-md" />
                                    </div>
                                    <span asp-validation-for="ReservationDate" class="text-red-500 text-xs mt-1 ml-1 font-bold"></span>
                                </div>
                                
                                <div class="group relative">
                                    <label asp-for="ReservationTime" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">Time</label>
                                    <div class="relative transform transition-all duration-300 group-hover:-translate-y-1">
                                        <input asp-for="ReservationTime" type="time"
                                               class="w-full px-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium cursor-pointer shadow-sm group-hover:shadow-md" />
                                    </div>
                                    <span asp-validation-for="ReservationTime" class="text-red-500 text-xs mt-1 ml-1 font-bold"></span>
                                </div>
                                
                                <div class="group relative">
                                    <label asp-for="PartySize" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">Guests</label>
                                    <div class="relative transform transition-all duration-300 group-hover:-translate-y-1">
                                        <span class="material-symbols-outlined absolute right-4 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none">expand_more</span>
                                        <select asp-for="PartySize" id="PartySize"
                                                class="w-full px-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium appearance-none cursor-pointer shadow-sm group-hover:shadow-md">
                                            @for (int i = 1; i <= 20; i++)
                                            {
                                                <option value="@i">@i @(i == 1 ? "Person" : "People")</option>
                                            }
                                            <option value="21+">20+ (Call Us)</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="PartySize" class="text-red-500 text-xs mt-1 ml-1 font-bold"></span>
                                </div>
                            </div>
                        </div>

                        <!-- Special Requests -->
                        <div class="group relative pt-4">
                             <label asp-for="SpecialRequests" class="block text-text-main dark:text-white text-sm font-bold mb-2 ml-1">
                                 Special Requests <span class="text-text-muted font-normal text-xs ml-1">(Optional)</span>
                             </label>
                             <div class="transform transition-all duration-300 group-hover:-translate-y-1">
                                 <textarea asp-for="SpecialRequests" rows="3"
                                           class="w-full px-4 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-text-main/30 dark:placeholder-white/30 focus:outline-none focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all font-medium resize-none leading-relaxed shadow-sm group-hover:shadow-md" 
                                           placeholder="Any allergies, dietary requirements, or special occasion details (e.g. Birthday, Anniversary)?"></textarea>
                             </div>
                        </div>

                        <!-- Submit Button -->
                         <button type="submit" class="w-full group bg-black dark:bg-white text-white dark:text-black font-black text-lg py-5 rounded-xl transition-all hover:scale-[1.02] active:scale-[0.98] shadow-xl hover:shadow-2xl hover:shadow-primary/20 flex items-center justify-center gap-3 relative overflow-hidden">
                            <span class="absolute inset-0 w-full h-full bg-primary/20 translate-x-[-100%] group-hover:translate-x-0 transition-transform duration-500"></span>
                            <span class="relative flex items-center gap-2">
                                Confirm Reservation <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </span>
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- Right Column: Visual Journey & Info -->
        <div class="lg:w-5/12 order-1 lg:order-2 flex flex-col gap-6" data-aos="fade-left" data-aos-delay="500">
            
            <!-- Interactive Lottie Animation Card -->
            <div class="bg-primary/5 dark:bg-primary/5 rounded-[2rem] p-8 border border-primary/20 relative overflow-hidden group hover:shadow-lg transition-all duration-300 cursor-pointer">
                <div class="flex items-center gap-6">
                    <!-- Animation -->
                    <div class="w-24 h-24 bg-white dark:bg-black/20 rounded-full flex items-center justify-center shadow-inner group-hover:scale-110 transition-transform">
                        <dotlottie-player src="https://lottie.host/dd595dc0-d5be-4835-9610-8b6fa292f974/l8j8gJ2y0k.json" background="transparent" speed="1" style="width: 150px; height: 150px;" loop autoplay></dotlottie-player>
                    </div>
                     <div>
                        <h3 class="text-xl font-black text-text-main dark:text-white mb-1">Celebration Ready</h3>
                        <p class="text-text-main/70 dark:text-white/70 text-sm">We make every meal a special occasion.</p>
                     </div>
                </div>
            </div>

            <!-- Image Showcase -->
            <div class="flex-1 min-h-[400px] rounded-[2.5rem] relative overflow-hidden shadow-2xl group cursor-pointer perspective-1000" id="table-card">
                 <!-- Interactive 3D Card -->
                 <div class="relative w-full h-full transform transition-transform duration-500 group-hover:rotate-y-6">
                      <img src="~/images/restaurant_table_setting.png" class="w-full h-full object-cover rounded-[2.5rem] shadow-2xl" id="interactive-table-img" />
                      <div class="absolute inset-0 rounded-[2.5rem] bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex flex-col items-center justify-center text-center p-8">
                           <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                               <span class="material-symbols-outlined text-5xl text-primary mb-2 drop-shadow-md">table_restaurant</span>
                               <h3 class="text-3xl font-bold text-white mb-1 drop-shadow-md">Premium Table</h3>
                               <p class="text-white/80 text-lg drop-shadow-md">Luxury Setting with View</p>
                           </div>
                      </div>
                      
                       <!-- Floating Reserve Badge -->
                       <button type="button" onclick="selectPremiumTable()" class="absolute bottom-8 right-8 bg-primary text-black font-black py-3 px-6 rounded-full shadow-xl transform scale-0 group-hover:scale-100 transition-transform duration-500 z-20 hover:scale-110 active:scale-95 cursor-pointer">
                           Reserve Now
                       </button>
                 </div>
            </div>
            
            <!-- Additional Scrollable Animated Content -->
             <div class="bg-gray-50 dark:bg-card-dark rounded-[2rem] p-6 border border-gray-100 dark:border-white/5 relative overflow-hidden group hover:shadow-lg transition-all duration-300">
                <div class="flex items-center justify-between mb-4">
                     <h3 class="text-lg font-black text-text-main dark:text-white">Upcoming Events</h3>
                     <span class="material-symbols-outlined text-primary">event_upcoming</span>
                </div>
                <div class="space-y-4 max-h-[150px] overflow-y-auto custom-scrollbar pr-2">
                    <div class="flex gap-3 items-center group/item hover:bg-white dark:hover:bg-white/5 p-2 rounded-xl transition-colors">
                        <div class="bg-primary/20 text-primary font-bold rounded-lg w-10 h-10 flex items-center justify-center text-xs text-center leading-tight">JAN<br>20</div>
                        <div>
                            <p class="font-bold text-sm text-text-main dark:text-white">Jazz Night</p>
                            <p class="text-xs text-text-muted">Live Music & Drinks</p>
                        </div>
                    </div>
                     <div class="flex gap-3 items-center group/item hover:bg-white dark:hover:bg-white/5 p-2 rounded-xl transition-colors">
                        <div class="bg-primary/20 text-primary font-bold rounded-lg w-10 h-10 flex items-center justify-center text-xs text-center leading-tight">FEB<br>14</div>
                        <div>
                            <p class="font-bold text-sm text-text-main dark:text-white">Valentine's</p>
                            <p class="text-xs text-text-muted">Romantic Dinner Special</p>
                        </div>
                    </div>
                     <div class="flex gap-3 items-center group/item hover:bg-white dark:hover:bg-white/5 p-2 rounded-xl transition-colors">
                        <div class="bg-primary/20 text-primary font-bold rounded-lg w-10 h-10 flex items-center justify-center text-xs text-center leading-tight">MAR<br>05</div>
                        <div>
                            <p class="font-bold text-sm text-text-main dark:text-white">Chef's Table</p>
                            <p class="text-xs text-text-muted">Exclusive Tasting Menu</p>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</main>

<!-- Scrollable Features / Visual Experience -->
<section class="py-24 bg-zinc-900 text-white relative overflow-hidden">
     <div class="absolute inset-0 z-0">
          <img src="~/images/restaurant_hero_bg.png" class="w-full h-full object-cover opacity-20 fixed-bg-effect" />
     </div>
     <div class="container mx-auto px-6 relative z-10">
         <div class="text-center mb-16">
             <span class="text-primary font-bold tracking-widest uppercase mb-2 block">Experience</span>
             <h2 class="text-4xl md:text-6xl font-black">More Than Just Dining</h2>
         </div>
         
         <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
             <div data-aos="fade-right">
                  <!-- Interactive 3D Card for Experience Section -->
                  <div class="relative w-full aspect-[4/3] group cursor-pointer perspective-1000" id="experience-card">
                      <div class="relative w-full h-full transform transition-transform duration-700 preserve-3d group-hover:rotate-y-6 group-hover:rotate-x-6 shadow-2xl rounded-[3rem]">
                          <img src="~/images/restaurant_table_setting.png" class="w-full h-full object-cover rounded-[3rem] shadow-2xl" />
                          <div class="absolute inset-0 rounded-[3rem] bg-gradient-to-t from-black/60 to-transparent opacity-60"></div>
                          
                          <!-- Hover Reveal Content -->
                           <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-[3rem]">
                               <div class="bg-white/10 backdrop-blur-md border border-white/20 p-8 rounded-3xl text-center transform translate-y-8 group-hover:translate-y-0 transition-transform duration-500 shadow-xl">
                                   <span class="material-symbols-outlined text-4xl text-primary mb-2">table_restaurant</span>
                                   <h3 class="text-2xl font-bold font-display">Premium Seating</h3>
                                   <p class="text-sm opacity-90">Experience the View</p>
                               </div>
                          </div>
                      </div>
                  </div>
             </div>
             <div class="space-y-8" data-aos="fade-left">
                 <div class="group hover:bg-white/5 p-6 rounded-2xl transition-all border border-transparent hover:border-white/10">
                     <span class="text-6xl text-primary font-display font-black opacity-30 group-hover:opacity-100 transition-opacity">01</span>
                     <h3 class="text-3xl font-bold mt-2 mb-4">Master Chefs</h3>
                     <p class="text-gray-400 text-lg">Our culinary team brings decades of experience from top Michelin-starred kitchens around the world.</p>
                 </div>
                  <div class="group hover:bg-white/5 p-6 rounded-2xl transition-all border border-transparent hover:border-white/10">
