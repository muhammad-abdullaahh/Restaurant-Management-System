@model FoodHeaven.Models.Reservation
@{
    ViewData["Title"] = "Reserve Your Table - FoodHeaven";
}

<!-- Hero Section with Parallax -->
<div class="relative h-[55vh] min-h-[500px] w-full overflow-hidden flex items-center justify-center bg-zinc-950" id="reservation-hero">
    <div class="absolute inset-0 z-0">
        <img id="hero-bg" src="~/images/restaurant_hero_bg.png" class="w-full h-full object-cover opacity-50 transition-transform duration-[10s] animate-slow-zoom" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-background-light dark:to-background-dark"></div>
    </div>
    
    <!-- Floating Elements -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden opacity-20">
        <div class="absolute top-[20%] left-[10%] animate-float">
            <svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                <path d="M4 18v3h3v-3h10v3h3v-3h1v-5c0-1.1-.9-2-2-2h-1V7c0-2.76-2.24-5-5-5S8 4.24 8 7v4H7c-1.1 0-2 .9-2 2v5h1zm10-11c0-1.1-.9-2-2-2s-2 .9-2 2v4h4V7z"/>
            </svg>
        </div>
        <div class="absolute top-[60%] right-[10%] animate-float-delayed">
            <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                <path d="M6 3v6c0 2.97 2.16 5.43 5 5.91V19H8v2h8v-2h-3v-4.09c2.84-.48 5-2.94 5-5.91V3H6zm10 2v4h-8V5h8z"/>
            </svg>
        </div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-5xl space-y-6">
        <div class="opacity-0 animate-fade-in-down">
            <span class="px-6 py-2 rounded-full border border-primary/40 text-primary bg-primary/5 backdrop-blur-xl text-xs font-black uppercase tracking-[0.4em]">Secure Your Table</span>
        </div>
        <h1 class="text-6xl md:text-[100px] font-display font-black text-white leading-none opacity-0 animate-fade-in-up animation-delay-300">
            Dine in <span class="italic text-primary">Paradise</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/70 font-light max-w-3xl mx-auto opacity-0 animate-fade-in-up animation-delay-500 leading-relaxed">
            Experience the perfect blend of ambiance and excellence. Your table awaits.
        </p>
    </div>
</div>

<!-- Main Content -->
<main class="container mx-auto px-4 py-20 -mt-24 relative z-20 mb-16">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
        
        <!-- Left: Experience & Info -->
        <div class="lg:w-5/12 space-y-10 reveal">
            <div class="bg-white/80 dark:bg-card-dark/80 backdrop-blur-3xl rounded-[3rem] p-10 shadow-2xl border border-white/20 dark:border-white/5 overflow-hidden group">
                <div class="relative z-10 space-y-8">
                    <div>
                        <span class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-2 block">The Setting</span>
                        <h2 class="text-4xl font-black text-text-main dark:text-white tracking-tighter">Luxury <span class="text-primary">Atmosphere</span></h2>
                    </div>
                    
                    <div class="aspect-[4/3] rounded-[2.5rem] overflow-hidden shadow-2xl">
                        <img src="~/images/restaurant_table_setting.png" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" />
                    </div>

                    <div class="space-y-6">
                        <div class="flex gap-5">
                            <div class="size-12 rounded-2xl bg-primary/20 flex items-center justify-center text-primary shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                                    <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-black text-text-main dark:text-white">Premium Service</h4>
                                <p class="text-sm text-text-muted">Dedicated staff for your entire dining experience.</p>
                            </div>
                        </div>
                        <div class="flex gap-5">
                            <div class="size-12 rounded-2xl bg-primary/20 flex items-center justify-center text-primary shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6">
                                    <path d="M12 3v10.55c-.59-.34-1.27-.55-2-.55-2.21 0-4 1.79-4 4s1.79 4 4 4 4-1.79 4-4V7h4V3h-6z"/>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-black text-text-main dark:text-white">Curated Playlists</h4>
                                <p class="text-sm text-text-muted">Ambient soundscapes to enhance your meal.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Operating Stats -->
            <div class="grid grid-cols-2 gap-6">
                <div class="bg-zinc-950 p-8 rounded-[2.5rem] border border-white/5 text-center">
                    <span class="block text-4xl font-black text-primary mb-1">98%</span>
                    <span class="text-[10px] font-black text-white/50 uppercase tracking-widest">Satisfaction</span>
                </div>
                <div class="bg-zinc-950 p-8 rounded-[2.5rem] border border-white/5 text-center">
                    <span class="block text-4xl font-black text-primary mb-1">5★</span>
                    <span class="text-[10px] font-black text-white/50 uppercase tracking-widest">Google Rating</span>
                </div>
            </div>
        </div>

        <!-- Right: Modern Reservation Form -->
        <div class="lg:w-7/12 reveal">
            <div class="bg-white dark:bg-card-dark rounded-[3rem] p-10 md:p-16 shadow-2xl border border-gray-100 dark:border-white/5 relative">
                
                <div class="mb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                    <div>
                        <h2 class="text-4xl md:text-5xl font-black text-text-main dark:text-white tracking-tighter mb-4">Book Your <span class="text-primary">Spot.</span></h2>
                        <p class="text-text-muted text-lg font-light">Join us for a celestial dining experience.</p>
                    </div>
                    
                    <!-- Res Type Toggle -->
                    <div class="bg-gray-100 dark:bg-white/5 p-1.5 rounded-2xl flex gap-1 relative shadow-inner">
                        <div id="type-indicator" class="absolute top-1.5 left-1.5 bottom-1.5 w-[calc(33.33%-4px)] bg-primary rounded-xl shadow-md transition-all duration-500 ease-out"></div>
                        <button type="button" onclick="setType('Standard', 0)" class="relative z-10 px-4 py-2 text-[10px] font-black uppercase tracking-widest text-black transition-colors duration-500" id="btn-0">Standard</button>
                        <button type="button" onclick="setType('PrivateParty', 1)" class="relative z-10 px-4 py-2 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 transition-colors duration-500" id="btn-1">Private</button>
                        <button type="button" onclick="setType('Premium', 2)" class="relative z-10 px-4 py-2 text-[10px] font-black uppercase tracking-widest text-gray-500 dark:text-gray-400 transition-colors duration-500" id="btn-2">Premium</button>
                    </div>
                </div>

                <form asp-action="Create" method="post" class="space-y-8" id="resForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ReservationType" id="ReservationType" value="Standard" />
                    <input type="hidden" asp-for="TableNumber" value="Auto" />

                    <div class="space-y-8">
                        <!-- Personal Info -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="space-y-2">
                                <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Full Name</label>
                                <input asp-for="CustomerName" required 
                                       class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400" 
                                       placeholder="John Doe" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Email Address</label>
                                <input asp-for="Email" type="email" required 
                                       class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400" 
                                       placeholder="john@example.com" />
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Phone Number</label>
                            <input asp-for="PhoneNumber" type="tel" required 
                                   class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400" 
                                   placeholder="+1 (555) 000-0000" />
                        </div>

                        <!-- Booking Details -->
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 pt-4 border-t border-gray-100 dark:border-white/5">
                            <div class="space-y-2">
                                <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Date</label>
                                <input asp-for="ReservationDate" type="date" required 
                                       class="w-full px-4 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Time</label>
                                <input asp-for="ReservationTime" type="time" required 
                                       class="w-full px-4 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white" />
                            </div>
                            <div class="space-y-2">
                                <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Guests</label>
                                <select asp-for="PartySize" 
                                        class="w-full px-4 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white appearance-none cursor-pointer">
                                    @for (int i = 1; i <= 20; i++) { <option value="@i">@i People</option> }
                                </select>
                            </div>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Special Requests</label>
                            <textarea asp-for="SpecialRequests" rows="3" 
                                      class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400 resize-none" 
                                      placeholder="Allergies, anniversaries, or specific table preferences..."></textarea>
                        </div>
                    </div>

                    <button type="submit" class="w-full py-6 bg-black dark:bg-white text-white dark:text-black font-black text-xl rounded-2xl hover:bg-primary dark:hover:bg-primary dark:hover:text-black transition-all shadow-xl hover:shadow-primary/40 flex items-center justify-center gap-4 group/btn overflow-hidden relative">
                        <div class="absolute inset-0 bg-primary/20 translate-y-full group-hover/btn:translate-y-0 transition-transform duration-500"></div>
                        <span class="relative z-10">Confirm Reservation</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="relative z-10 group-hover/btn:translate-x-2 transition-transform">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>

<style>
    .animate-slow-zoom { animation: slowZoom 25s infinite alternate ease-in-out; }
    @@keyframes slowZoom { from { transform: scale(1); } to { transform: scale(1.15); } }
    
    .animate-fade-in-up { animation: fadeInUp 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    .animate-fade-in-down { animation: fadeInDown 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-40px); } to { opacity: 1; transform: translateY(0); } }
    
    .animation-delay-300 { animation-delay: 300ms; }
    .animation-delay-500 { animation-delay: 500ms; }

    .animate-float { animation: float 6s infinite ease-in-out; }
    .animate-float-delayed { animation: float 6s infinite ease-in-out 3s; }
    @@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }
</style>

@section Scripts {
    <script>
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        function setType(type, index) {
            document.getElementById('ReservationType').value = type;
            const indicator = document.getElementById('type-indicator');
            indicator.style.left = `calc(${index * 33.33}% + 6px)`;
            
            for(let i=0; i<3; i++) {
                const btn = document.getElementById(`btn-${i}`);
                if(i === index) {
                    btn.classList.remove('text-gray-500', 'dark:text-gray-400');
                    btn.classList.add('text-black');
                } else {
                    btn.classList.add('text-gray-500', 'dark:text-gray-400');
                    btn.classList.remove('text-black');
                }
            }
        }

        // Mouse Parallax
        document.addEventListener('mousemove', (e) => {
            const hero = document.getElementById('reservation-hero');
            const bg = document.getElementById('hero-bg');
            if (hero && hero.matches(':hover')) {
                const x = (e.clientX / window.innerWidth - 0.5) * 40;
                const y = (e.clientY / window.innerHeight - 0.5) * 40;
                bg.style.transform = `translate(${-x}px, ${-y}px) scale(1.1)`;
            }
        });

        // Double Submission Prevention
        document.getElementById('resForm').addEventListener('submit', function(e) {
            const btn = this.querySelector('button[type="submit"]');
            if (btn.hasAttribute('data-submitting')) {
                e.preventDefault();
                return false;
            }
            
            btn.setAttribute('data-submitting', 'true');
            btn.classList.add('opacity-70', 'cursor-not-allowed');
            const btnText = btn.querySelector('span:not(.material-symbols-outlined)');
            const btnIcon = btn.querySelector('.material-symbols-outlined');
            
            if (btnText) btnText.innerText = 'Processing Reservation...';
            if (btnIcon) {
                btnIcon.innerText = 'sync';
                btnIcon.classList.add('animate-spin');
            }
        });
    </script>
}
