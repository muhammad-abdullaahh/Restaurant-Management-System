@model FoodHeaven.Models.LoyaltyAccount
@{
    ViewData["Title"] = "Loyalty Rewards - FoodHeaven";
}

<!-- Hero Section with Parallax -->
<div class="relative h-[45vh] min-h-[400px] w-full overflow-hidden flex items-center justify-center bg-zinc-950">
    <div class="absolute inset-0 z-0">
        <img src="~/images/restaurant_hero_bg.png" class="w-full h-full object-cover opacity-30 animate-slow-zoom" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-background-light dark:to-background-dark"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl space-y-4">
        <div class="opacity-0 animate-fade-in-down">
            <span class="px-6 py-2 rounded-full border border-amber-500/40 text-amber-600 dark:text-primary bg-amber-50 dark:bg-primary/5 backdrop-blur-xl text-xs font-black uppercase tracking-[0.4em]">Elite Rewards</span>
        </div>
        <h1 class="text-6xl md:text-[80px] font-display font-black text-white leading-none opacity-0 animate-fade-in-up animation-delay-300">
            Heaven <span class="italic text-primary">Privileges</span>
        </h1>
        <p class="text-xl text-white/70 font-light max-w-2xl mx-auto opacity-0 animate-fade-in-up animation-delay-500 leading-relaxed">
            Your journey through taste, rewarded with exclusive benefits and celestial surprises.
        </p>
    </div>
</div>

<!-- Main Content -->
<main class="container mx-auto px-4 py-20 -mt-24 relative z-20 mb-16">
    <div class="max-w-6xl mx-auto space-y-12">
        
        <!-- Premium Member Card -->
        <div class="relative group reveal">
            <!-- Glow Effect -->
            <div class="absolute -inset-1 bg-gradient-to-r from-primary via-yellow-500 to-primary rounded-[3rem] blur-2xl opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
            
            <div class="relative bg-white/90 dark:bg-card-dark/90 backdrop-blur-3xl rounded-[3rem] p-10 md:p-16 border border-white/20 dark:border-white/5 shadow-2xl overflow-hidden">
                <!-- Decorative Elements -->
                <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
                
                <div class="relative z-10 flex flex-col md:flex-row items-center justify-between gap-12">
                    <div class="flex-1 text-center md:text-left space-y-6">
                        <div class="inline-flex items-center gap-3 px-4 py-2 rounded-full bg-primary/10 border border-primary/20 text-primary">
                            <span class="material-symbols-outlined text-xl animate-pulse">verified</span>
                            <span class="text-xs font-black uppercase tracking-widest">@Model.MembershipTier Status</span>
                        </div>
                        
                        <h2 class="text-5xl md:text-6xl font-black text-text-main dark:text-white tracking-tighter leading-none">
                            Welcome back, <br /><span class="text-amber-600 dark:text-primary italic">@Model.CustomerName.</span>
                        </h2>
                        
                        <p class="text-xl text-text-muted font-light max-w-md">
                            You're currently enjoying <span class="font-black text-text-main dark:text-white">@Model.MembershipTier</span> benefits. 
                            Collect more points to ascend to the next level of luxury.
                        </p>

                        <div class="flex flex-wrap gap-4 pt-4">
                            <div class="bg-black dark:bg-white text-white dark:text-black px-8 py-4 rounded-2xl font-black shadow-xl flex items-center gap-3 group/btn cursor-pointer">
                                <span class="material-symbols-outlined text-primary group-hover/btn:rotate-12 transition-transform">qr_code_2</span>
                                <span class="text-sm">MEMBER ID: @Model.CustomerId</span>
                            </div>
                            <a href="/Order/MyOrders" class="bg-gray-100 dark:bg-white/5 text-text-main dark:text-white px-8 py-4 rounded-2xl font-black border border-transparent hover:border-primary/20 transition-all flex items-center gap-3">
                                <span class="material-symbols-outlined">history</span>
                                <span class="text-sm">History</span>
                            </a>
                        </div>
                    </div>

                    <!-- Circular Progress -->
                    <div class="relative size-64 md:size-72 shrink-0">
                         @{
                            int nextTierPoints = Model.MembershipTier switch {
                                "Bronze" => 500, "Silver" => 1000, "Gold" => 2000, _ => 5000
                            };
                            double progress = Math.Min(100.0, (double)Model.Points / nextTierPoints * 100.0);
                            double offset = 440 - (440 * progress / 100.0);
                        }
                        <svg class="size-full -rotate-90">
                            <circle class="text-gray-100 dark:text-white/5" cx="50%" cy="50%" r="70" fill="transparent" stroke="currentColor" stroke-width="12"></circle>
                            <circle class="text-primary transition-all duration-1000 ease-out" cx="50%" cy="50%" r="70" fill="transparent" stroke="currentColor" stroke-width="12" stroke-dasharray="440" stroke-dashoffset="@offset" stroke-linecap="round"></circle>
                        </svg>
                        <div class="absolute inset-0 flex flex-col items-center justify-center text-center">
                            <span class="text-6xl font-black text-text-main dark:text-white tracking-tighter leading-none">@Model.Points</span>
                            <span class="text-[10px] font-black text-amber-600 dark:text-primary uppercase tracking-[0.3em] mt-2">Celestial Points</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- How It Works Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 reveal">
            <div class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all text-center">
                <div class="size-20 mx-auto bg-primary/10 rounded-3xl flex items-center justify-center mb-8 group-hover:bg-primary transition-all duration-500 group-hover:rotate-12 shadow-inner">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:text-black transition-colors">restaurant</span>
                </div>
                <h4 class="text-xl font-black text-text-main dark:text-white mb-3">Order & Ascend</h4>
                <p class="text-text-muted text-sm leading-relaxed font-medium">Earn 10 celestial points for every $1 spent in our restaurant.</p>
            </div>

            <div class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all text-center">
                <div class="size-20 mx-auto bg-primary/10 rounded-3xl flex items-center justify-center mb-8 group-hover:bg-primary transition-all duration-500 group-hover:-rotate-12 shadow-inner">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:text-black transition-colors">auto_awesome</span>
                </div>
                <h4 class="text-xl font-black text-text-main dark:text-white mb-3">Tier Upgrades</h4>
                <p class="text-text-muted text-sm leading-relaxed font-medium">Unlock silver, gold, and diamond tiers with exclusive privileges.</p>
            </div>

            <div class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all text-center">
                <div class="size-20 mx-auto bg-primary/10 rounded-3xl flex items-center justify-center mb-8 group-hover:bg-primary transition-all duration-500 group-hover:rotate-12 shadow-inner">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:text-black transition-colors">redeem</span>
                </div>
                <h4 class="text-xl font-black text-text-main dark:text-white mb-3">Divine Rewards</h4>
                <p class="text-text-muted text-sm leading-relaxed font-medium">Redeem your points for exquisite dishes, fine wines, and events.</p>
            </div>
        </div>

        <!-- Available Rewards -->
        <div class="reveal">
            <div class="flex items-end justify-between mb-10">
                <div class="space-y-2">
                    <span class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-1 block">Celestial Store</span>
                    <h2 class="text-4xl font-black text-text-main dark:text-white tracking-tighter">Available <span class="text-amber-500 dark:text-primary italic">Rewards</span></h2>
                </div>
                <div class="hidden md:block">
                     <p class="text-sm font-bold text-text-muted">Total Balance: <span class="text-primary">@Model.Points Points</span></p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                @foreach (var reward in new[] { 
                    new { Name = "Free Signature Drink", Points = 50, Icon = "local_cafe", Desc = "Choice of any premium coffee or shake." },
                    new { Name = "Heavenly Dessert", Points = 100, Icon = "cake", Desc = "Select any dessert from our seasonal menu." },
                    new { Name = "Elite 10% Discount", Points = 200, Icon = "percent", Desc = "Apply 10% discount to your entire order." },
                    new { Name = "Chef's Main Course", Points = 500, Icon = "restaurant", Desc = "One complimentary main dish of your choice." }
                })
                {
                    <div class="group relative bg-white dark:bg-card-dark rounded-[2.5rem] p-8 shadow-xl border border-gray-100 dark:border-white/5 hover:border-primary/40 transition-all duration-500 flex items-center gap-8 overflow-hidden">
                        <!-- BG Icon -->
                        <span class="absolute -right-8 -bottom-8 material-symbols-outlined text-[150px] text-gray-400/5 group-hover:text-primary/5 transition-colors duration-700">@reward.Icon</span>
                        
                        <div class="size-20 shrink-0 rounded-[1.5rem] bg-gray-50 dark:bg-white/5 flex items-center justify-center text-amber-600 dark:text-primary group-hover:bg-amber-500 group-hover:text-black transition-all duration-500 shadow-inner">
                            <span class="material-symbols-outlined text-4xl">@reward.Icon</span>
                        </div>
                        
                        <div class="flex-1 space-y-1">
                            <h4 class="text-2xl font-black text-text-main dark:text-white group-hover:text-primary transition-colors">@reward.Name</h4>
                            <p class="text-text-muted text-sm font-medium">@reward.Desc</p>
                            <div class="flex items-center gap-2 pt-2">
                                <span class="px-2 py-0.5 rounded-md bg-amber-50 dark:bg-primary/10 text-xs font-black text-amber-700 dark:text-primary uppercase tracking-widest border border-amber-200 dark:border-primary/20">@reward.Points Points</span>
                                @if (Model.Points < reward.Points)
                                {
                                    <span class="text-[10px] text-gray-400 font-bold">(@(reward.Points - Model.Points) more needed)</span>
                                }
                            </div>
                        </div>

                        <div class="relative z-10">
                            @if (Model.Points >= reward.Points)
                            {
                                <button onclick="redeemReward('@reward.Name', @reward.Points)" class="size-14 bg-black dark:bg-white text-white dark:text-black rounded-2xl flex items-center justify-center hover:bg-primary dark:hover:bg-primary dark:hover:text-black transition-all shadow-xl active:scale-90">
                                    <span class="material-symbols-outlined font-black">check</span>
                                </button>
                            }
                            else
                            {
                                <div class="size-14 bg-gray-100 dark:bg-white/5 rounded-2xl flex items-center justify-center text-gray-300 dark:text-gray-700">
                                    <span class="material-symbols-outlined font-black">lock</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</main>

<style>
    .animate-slow-zoom { animation: slowZoom 25s infinite alternate ease-in-out; }
    @@keyframes slowZoom { from { transform: scale(1); } to { transform: scale(1.1); } }
    
    .animate-fade-in-up { animation: fadeInUp 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    .animate-fade-in-down { animation: fadeInDown 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-40px); } to { opacity: 1; transform: translateY(0); } }
    
    .animation-delay-300 { animation-delay: 300ms; }
    .animation-delay-500 { animation-delay: 500ms; }
</style>

@section Scripts {
    <script>
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        async function redeemReward(name, points) {
            if (!confirm(`Redeem ${name} for ${points} Celestial Points?`)) return;

            try {
                const response = await fetch('/Loyalty/RedeemReward', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `customerId=@Model.CustomerId&points=${points}&rewardName=${name}`
                });
                const result = await response.json();
                if (result.success) {
                    alert('SUCCESS: ' + result.message);
                    location.reload();
                } else {
                    alert('ERROR: ' + result.message);
                }
            } catch (error) {
                alert('Connection error.');
            }
        }
    </script>
}
