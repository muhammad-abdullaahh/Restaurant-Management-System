@model FoodHeaven.Models.UserActivityViewModel
@{
    ViewData["Title"] = "My Activity - FoodHeaven";
}

<!-- Hero Section -->
<div class="relative h-[40vh] min-h-[350px] w-full overflow-hidden flex items-center justify-center bg-zinc-950">
    <div class="absolute inset-0 z-0">
        <img src="~/images/restaurant_hero_bg.png" class="w-full h-full object-cover opacity-30 animate-slow-zoom" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-background-light dark:to-background-dark"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl space-y-4">
        <div class="opacity-0 animate-fade-in-down">
            <span class="px-6 py-2 rounded-full border border-primary/40 text-primary bg-primary/5 backdrop-blur-xl text-xs font-black uppercase tracking-[0.4em]">Personal Journal</span>
        </div>
        <h1 class="text-6xl md:text-[80px] font-display font-black text-white leading-none opacity-0 animate-fade-in-up animation-delay-300">
            My <span class="italic text-primary">Activity</span>
        </h1>
        <p class="text-xl text-white/70 font-light max-w-2xl mx-auto opacity-0 animate-fade-in-up animation-delay-500 leading-relaxed">
            Track your culinary adventures and upcoming reservations in one elegant place.
        </p>
    </div>
</div>

<!-- Main Content -->
<main class="container mx-auto px-4 py-20 -mt-24 relative z-20 mb-16">
    <div class="max-w-5xl mx-auto space-y-20">
        
        <!-- Orders Section -->
        <section class="reveal">
            <div class="flex items-center justify-between mb-10">
                <div class="flex items-center gap-4">
                    <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shadow-inner">
                        <span class="material-symbols-outlined text-3xl">receipt_long</span>
                    </div>
                    <h2 class="text-3xl font-black text-text-main dark:text-white tracking-tighter">Recent <span class="text-primary">Orders</span></h2>
                </div>
                <span class="text-sm font-bold text-text-muted">Total @Model.Orders.Count() Entries</span>
            </div>

            @if (!Model.Orders.Any())
            {
                <div class="text-center py-20 bg-white dark:bg-card-dark rounded-[3rem] border-2 border-dashed border-gray-100 dark:border-white/5 shadow-xl">
                    <span class="material-symbols-outlined text-6xl text-gray-200 dark:text-gray-700 mb-6">shopping_cart_off</span>
                    <p class="text-xl text-text-muted font-light">No orders found. Time to taste something divine?</p>
                    <a href="/Menu" class="mt-8 inline-block px-10 py-4 bg-primary text-black font-black rounded-2xl hover:scale-110 transition-transform shadow-lg">Explore Menu</a>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 gap-8">
                    @foreach (var order in Model.Orders)
                    {
                        <div id="order-@order.Id" class="group bg-white dark:bg-card-dark rounded-[2.5rem] p-8 md:p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-white/5 relative overflow-hidden">
                            <!-- Status Side Gradient -->
                            @{
                                var statusColorClass = order.Status switch {
                                    "Pending" => "from-orange-500",
                                    "Confirmed" => "from-blue-500",
                                    "Delivered" => "from-green-500",
                                    "Cancelled" => "from-red-500",
                                    _ => "from-gray-500"
                                };
                            }
                            <div class="absolute left-0 top-0 bottom-0 w-2 bg-gradient-to-b @statusColorClass to-transparent opacity-50"></div>

                            <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 relative z-10">
                                <div class="space-y-3">
                                    <div class="flex items-center gap-4">
                                        <span class="text-2xl font-black text-text-main dark:text-white tracking-tighter">#@order.OrderNumber</span>
                                        <span class="px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 @(order.Status == "Pending" ? "text-orange-500" : order.Status == "Delivered" ? "text-green-500" : "text-primary")">
                                            @order.Status
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-2 text-text-muted text-sm font-medium">
                                        <span class="material-symbols-outlined text-sm">schedule</span>
                                        @order.OrderDate.ToString("MMMM dd, yyyy • hh:mm tt")
                                    </div>
                                </div>

                                <div class="flex flex-col md:items-end gap-2">
                                    <span class="text-4xl font-black text-text-main dark:text-white tracking-tighter">@order.Total.ToString("C")</span>
                                    <div class="flex gap-3">
                                        <a href="/Order/Confirmation/@order.Id" class="px-6 py-3 bg-gray-100 dark:bg-white/5 text-text-main dark:text-white font-black rounded-xl hover:bg-primary hover:text-black transition-all text-xs uppercase tracking-widest">
                                            Order Details
                                        </a>
                                        @if (order.Status == "Pending")
                                        {
                                            <button onclick="cancelOrder(@order.Id)" class="px-6 py-3 bg-red-500/10 text-red-500 font-black rounded-xl hover:bg-red-500 hover:text-white transition-all text-xs uppercase tracking-widest">
                                                Cancel
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </section>

        <!-- Reservations Section -->
        <section class="reveal">
            <div class="flex items-center justify-between mb-10">
                <div class="flex items-center gap-4">
                    <div class="size-14 rounded-2xl bg-primary/10 flex items-center justify-center text-primary shadow-inner">
                        <span class="material-symbols-outlined text-3xl">event_seat</span>
                    </div>
                    <h2 class="text-3xl font-black text-text-main dark:text-white tracking-tighter">My <span class="text-primary">Reservations</span></h2>
                </div>
                <span class="text-sm font-bold text-text-muted">Total @Model.Reservations.Count() Entries</span>
            </div>

            @if (!Model.Reservations.Any())
            {
                <div class="text-center py-20 bg-white dark:bg-card-dark rounded-[3rem] border-2 border-dashed border-gray-100 dark:border-white/5 shadow-xl">
                    <span class="material-symbols-outlined text-6xl text-gray-200 dark:text-gray-700 mb-6">calendar_today</span>
                    <p class="text-xl text-text-muted font-light">No reservations yet. Planning a special evening?</p>
                    <a href="/Reservation/Create" class="mt-8 inline-block px-10 py-4 bg-primary text-black font-black rounded-2xl hover:scale-110 transition-transform shadow-lg">Book a Table</a>
                </div>
            }
            else
            {
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    @foreach (var res in Model.Reservations)
                    {
                        <div id="res-@res.Id" class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl hover:shadow-2xl transition-all duration-500 border border-gray-100 dark:border-white/5 relative overflow-hidden">
                             <div class="flex flex-col gap-6">
                                <div class="flex justify-between items-start">
                                    <div class="size-16 rounded-2xl bg-gray-50 dark:bg-white/5 flex items-center justify-center text-primary group-hover:scale-110 transition-transform duration-500">
                                        <span class="material-symbols-outlined text-4xl">table_restaurant</span>
                                    </div>
                                    <span class="px-4 py-1.5 rounded-full text-[10px] font-black uppercase tracking-widest bg-gray-50 dark:bg-white/5 border border-gray-100 dark:border-white/10 @(res.Status == "Confirmed" ? "text-green-500" : "text-red-500")">
                                        @res.Status
                                    </span>
                                </div>

                                <div class="space-y-1">
                                    <h4 class="text-2xl font-black text-text-main dark:text-white tracking-tighter">Table for @res.PartySize</h4>
                                    <p class="text-text-muted text-sm font-medium">@res.ReservationType Package</p>
                                </div>

                                <div class="flex items-center gap-4 pt-4 border-t border-gray-100 dark:border-white/5">
                                    <div class="flex-1">
                                        <p class="text-[10px] font-black text-primary uppercase tracking-[0.2em] mb-1">Date & Time</p>
                                        <p class="text-lg font-black text-text-main dark:text-white">@res.ReservationDate.ToShortDateString() @@ @DateTime.Today.Add(res.ReservationTime).ToString("hh:mm tt")</p>
                                    </div>
                                    @if (res.Status == "Confirmed" && res.ReservationDate >= DateTime.Today)
                                    {
                                        <button onclick="cancelReservation(@res.Id)" class="size-12 bg-red-500/10 text-red-500 rounded-xl flex items-center justify-center hover:bg-red-500 hover:text-white transition-all shadow-lg active:scale-90" title="Cancel Reservation">
                                            <span class="material-symbols-outlined">close</span>
                                        </button>
                                    }
                                </div>
                             </div>
                        </div>
                    }
                </div>
            }
        </section>

    </div>
</main>

<style>
    .animate-slow-zoom { animation: slowZoom 25s infinite alternate ease-in-out; }
    @@keyframes slowZoom { from { transform: scale(1); } to { transform: scale(1.15); } }
    
    .animate-fade-in-up { animation: fadeInUp 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    .animate-fade-in-down { animation: fadeInDown 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-40px); } to { opacity: 1; transform: translateY(0); } }
    
    .animation-delay-300 { animation-delay: 300ms; }
    .animation-delay-500 { animation-delay: 500ms; }
</style>

@section Scripts {
    <script>

        async function cancelOrder(id) {
            if (!confirm('Cancel this order? This action cannot be undone.')) return;
            try {
                const response = await fetch('/Order/Cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${id}`
                });
                const result = await response.json();
                if (result.success) { alert(result.message); location.reload(); }
                else alert(result.message);
            } catch (error) { alert('Error.'); }
        }

        async function cancelReservation(id) {
            if (!confirm('Cancel this reservation?')) return;
            try {
                const response = await fetch('/Reservation/Cancel', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${id}`
                });
                const result = await response.json();
                if (result.success) { alert(result.message); location.reload(); }
                else alert(result.message);
            } catch (error) { alert('Error.'); }
        }
    </script>
}
