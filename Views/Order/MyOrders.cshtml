@model IEnumerable<FoodHeaven.Models.Order>

@{
    ViewData["Title"] = "My Orders";
}

<div class="min-h-screen bg-gray-50 dark:bg-[#0a0a0a] py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-4xl mx-auto">
        
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-display font-black text-text-main dark:text-white">My Orders</h1>
            <p class="text-text-muted dark:text-gray-400 mt-2">Track your past and current orders</p>
            
            @* Debug Information *@
            @if (ViewBag.DebugMessage != null)
            {
                <div class="mt-4 p-4 bg-red-100 dark:bg-red-900/20 border border-red-300 dark:border-red-700 rounded-xl">
                    <p class="text-sm text-red-800 dark:text-red-300 font-mono">@ViewBag.DebugMessage</p>
                </div>
            }
            @if (ViewBag.UserId != null)
            {
                <div class="mt-4 p-4 bg-blue-100 dark:bg-blue-900/20 border border-blue-300 dark:border-blue-700 rounded-xl">
                    <p class="text-sm text-blue-800 dark:text-blue-300"><strong>Debug Info:</strong></p>
                    <p class="text-sm text-blue-800 dark:text-blue-300 font-mono">User ID: @ViewBag.UserId</p>
                    <p class="text-sm text-blue-800 dark:text-blue-300 font-mono">Username: @ViewBag.Username</p>
                    <p class="text-sm text-blue-800 dark:text-blue-300 font-mono">Orders Found: @ViewBag.OrderCount</p>
                </div>
            }
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-16 bg-white dark:bg-card-dark rounded-[2.5rem] border border-gray-100 dark:border-white/5 shadow-xl">
                <div class="w-24 h-24 bg-gray-100 dark:bg-white/5 rounded-full flex items-center justify-center mx-auto mb-6">
                    <span class="material-symbols-outlined text-4xl text-gray-400">receipt_long</span>
                </div>
                <h2 class="text-xl font-bold text-text-main dark:text-white mb-2">No orders yet</h2>
                <p class="text-text-muted dark:text-gray-400 mb-8 max-w-xs mx-auto">Looks like you haven't placed any orders with us yet.</p>
                <a href="/Menu" class="inline-flex items-center gap-2 px-8 py-3 bg-primary text-white font-bold rounded-xl hover:bg-primary-dark transition-colors">
                    Browse Menu <span class="material-symbols-outlined">restaurant_menu</span>
                </a>
            </div>
        }
        else
        {
            <div class="space-y-6">
                @foreach (var order in Model)
                {
                    <div class="bg-white dark:bg-card-dark rounded-[2rem] p-6 sm:p-8 border border-gray-100 dark:border-white/5 shadow-lg hover:shadow-xl transition-all duration-300 group">
                        <div class="flex flex-col sm:flex-row justify-between sm:items-center gap-4 mb-6">
                            <div>
                                <div class="flex items-center gap-3 mb-1">
                                    <span class="text-lg font-bold text-text-main dark:text-white">@order.OrderNumber</span>
                                    @{
                                        var statusColor = "bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400";
                                        if (order.Status == "Pending") statusColor = "bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400";
                                        else if (order.Status == "Confirmed" || order.Status == "Preparing") statusColor = "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400";
                                        else if (order.Status == "Delivered" || order.Status == "Completed") statusColor = "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400";
                                        else if (order.Status == "Cancelled") statusColor = "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400";
                                    }
                                    <span class="px-3 py-1 rounded-full text-xs font-bold @statusColor">@order.Status</span>
                                </div>
                                <div class="text-sm text-text-muted">
                                    <span class="flex items-center gap-1">
                                        <span class="material-symbols-outlined text-[16px]">calendar_today</span>
                                        @order.OrderDate.ToString("MMM dd, yyyy • hh:mm tt")
                                    </span>
                                </div>
                            </div>
                            <div class="text-right">
                                <div class="text-2xl font-black text-primary">@order.Total.ToString("C")</div>
                                <div class="text-xs text-text-muted">@order.OrderItems.Count items</div>
                            </div>
                        </div>

                        <!-- Items Preview -->
                        <div class="bg-gray-50 dark:bg-black/20 rounded-xl p-4 mb-6">
                            <ul class="space-y-2">
                                @foreach (var item in order.OrderItems.Take(3))
                                {
                                    <li class="flex justify-between text-sm text-text-main dark:text-gray-300">
                                        <span><span class="font-bold text-primary">@item.Quantity x</span> @item.MenuItem.Name</span>
                                        <span class="font-medium">@item.Price.ToString("C")</span>
                                    </li>
                                }
                                @if (order.OrderItems.Count > 3)
                                {
                                    <li class="pt-2 text-xs text-text-muted italic">
                                        + @(order.OrderItems.Count - 3) more items...
                                    </li>
                                }
                            </ul>
                        </div>

                        <div class="flex justify-end gap-3">
                            <a href="/Order/Confirmation/@order.Id" class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-100 dark:bg-white/10 text-text-main dark:text-white font-bold rounded-xl hover:bg-gray-200 dark:hover:bg-white/20 transition-colors text-sm">
                                View Details <span class="material-symbols-outlined text-sm">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>
