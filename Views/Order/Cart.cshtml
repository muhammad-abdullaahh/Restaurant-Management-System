@{
    ViewData["Title"] = "Your Order - FoodHeaven";
}

<!-- AOS & Styles -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<style>
    /* Custom Animations & Polishes */
    .glass-panel {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
    }
    .dark .glass-panel {
        background: rgba(30, 30, 30, 0.85);
    }
    
    .blob-bg {
        position: absolute;
        filter: blur(80px);
        opacity: 0.6;
        z-index: 0;
        animation: blob-float 10s infinite alternate;
    }
    @@keyframes blob-float {
        0% { transform: translate(0, 0) scale(1); }
        100% { transform: translate(20px, -20px) scale(1.1); }
    }

    .step-active {
        background: #f2b90d;
        color: black;
        border-color: #f2b90d;
    }
    .step-inactive {
        background: transparent;
        color: rgba(156, 163, 175, 1);
        border-color: rgba(156, 163, 175, 0.3);
    }
    
    .hover-lift {
        transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    }
    .hover-lift:hover {
        transform: translateY(-4px);
    }

    /* Custom Checkbox for Promo */
    .promo-input:focus {
        box-shadow: 0 0 0 4px rgba(242, 185, 13, 0.2);
    }
</style>

<!-- Background Blobs -->
<div class="fixed top-0 left-0 w-full h-full overflow-hidden pointer-events-none z-0">
    <div class="blob-bg w-96 h-96 bg-primary/20 rounded-full top-[-10%] left-[-10%]"></div>
    <div class="blob-bg w-80 h-80 bg-orange-500/10 rounded-full bottom-[-10%] right-[-5%] animation-delay-2000"></div>
</div>

<!-- Main Content -->
<main class="relative z-10 mx-auto max-w-[1440px] w-full flex-1 px-4 sm:px-6 lg:px-8 py-12">
    
    <!-- Hero / Header Section -->
    <div class="text-center mb-16" data-aos="fade-down">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/10 text-primary font-bold uppercase text-xs tracking-widest mb-4 border border-primary/20">
            <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
            Checkout Process
        </div>
        <h1 class="text-4xl md:text-6xl font-black text-text-main dark:text-white tracking-tight mb-4 leading-tight">
            Finalize Your <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-orange-500">Delicious Order</span>
        </h1>
        <p class="text-lg text-text-main/60 dark:text-white/60 max-w-2xl mx-auto">
            You're just a few clicks away from a culinary masterpiece. Review your items below.
        </p>
    </div>

    <!-- Progress Stepper -->
    <div class="max-w-4xl mx-auto mb-16" data-aos="fade-up" data-aos-delay="100">
        <div class="relative flex justify-between items-center text-center">
            <!-- Line -->
            <div class="absolute top-1/2 left-0 w-full h-1 bg-gray-200 dark:bg-white/10 -z-10 -translate-y-1/2 rounded-full"></div>
            <div class="absolute top-1/2 left-0 w-[50%] h-1 bg-gradient-to-r from-primary to-primary/50 -z-10 -translate-y-1/2 rounded-full transition-all duration-1000"></div>

            <!-- Step 1: Menu -->
            <div class="flex flex-col items-center gap-3">
                <div class="w-12 h-12 rounded-full flex items-center justify-center bg-primary text-black font-bold text-xl shadow-lg shadow-primary/30 z-10">
                    <span class="material-symbols-outlined">restaurant_menu</span>
                </div>
                <span class="font-bold text-text-main dark:text-white text-sm uppercase tracking-wider">Menu Selection</span>
            </div>

            <!-- Step 2: Review (Current) -->
            <div class="flex flex-col items-center gap-3">
                <div class="w-14 h-14 rounded-full flex items-center justify-center bg-white dark:bg-zinc-800 border-4 border-primary text-primary font-bold text-2xl shadow-xl shadow-primary/20 z-10 scale-110">
                    <span class="material-symbols-outlined fill-current">receipt_long</span>
                </div>
                <span class="font-bold text-primary text-sm uppercase tracking-wider">Review Order</span>
            </div>

            <!-- Step 3: Checkout -->
            <div class="flex flex-col items-center gap-3 opacity-50">
                <div class="w-12 h-12 rounded-full flex items-center justify-center bg-gray-200 dark:bg-zinc-800 text-gray-400 dark:text-gray-500 font-bold text-xl border-2 border-transparent z-10">
                    <span class="material-symbols-outlined">check_circle</span>
                </div>
                <span class="font-bold text-gray-400 dark:text-gray-500 text-sm uppercase tracking-wider">Confirmation</span>
            </div>
        </div>
    </div>

    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 max-w-6xl mx-auto">
        
        <!-- Cart Items Column -->
        <div class="flex-1 order-2 lg:order-1">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-2xl font-bold text-text-main dark:text-white flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">shopping_bag</span>
                    Selected Items
                </h3>
                <span id="itemCountBadge" class="px-3 py-1 bg-gray-100 dark:bg-white/10 rounded-full text-xs font-bold text-text-main/70 dark:text-white/70">0 Items</span>
            </div>

            <!-- JS Populated Container -->
            <div id="cartItemsContainer" class="space-y-6 min-h-[300px]" data-aos="fade-right" data-aos-delay="200">
                <!-- Loader placeholder could go here -->
            </div>
            
            <!-- Empty State -->
            <div id="emptyCart" class="hidden flex-col items-center justify-center py-20 bg-card-light dark:bg-card-dark rounded-[2.5rem] border border-dashed border-gray-300 dark:border-white/10 text-center shadow-sm" data-aos="zoom-in">
                <div class="w-32 h-32 bg-gray-100 dark:bg-white/5 rounded-full flex items-center justify-center mb-6 animate-bounce">
                    <span class="material-symbols-outlined text-6xl text-gray-300 dark:text-gray-600">no_meals</span>
                </div>
                <h3 class="text-2xl font-bold text-text-main dark:text-white mb-2">Your plate is empty!</h3>
                <p class="text-text-main/60 dark:text-white/50 mb-8 max-w-sm">Looks like you haven't made your choice yet. Explore our menu to find something delicious.</p>
                <a href="/Menu" class="px-8 py-4 bg-black dark:bg-white text-white dark:text-black font-bold rounded-2xl hover:scale-105 transition-transform shadow-lg flex items-center gap-2">
                    <span class="material-symbols-outlined">restaurant_menu</span>
                    Go to Menu
                </a>
            </div>

            <!-- Delivery & Payment Section (New) -->
            <div id="checkoutDetails" class="mt-8 space-y-8" data-aos="fade-up" data-aos-delay="250">
                <!-- Delivery Details -->
                <div class="bg-card-light dark:bg-card-dark rounded-[2rem] p-8 shadow-lg border border-gray-100 dark:border-white/5">
                    <h3 class="text-xl font-bold text-text-main dark:text-white flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">location_on</span>
                        Delivery Details
                    </h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold text-text-main/70 dark:text-white/70 mb-2">Delivery Address</label>
                            <textarea id="deliveryAddressInput" rows="3" class="w-full px-5 py-4 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="Enter your full delivery address (Street, City, Zip Code)"></textarea>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="bg-card-light dark:bg-card-dark rounded-[2rem] p-8 shadow-lg border border-gray-100 dark:border-white/5">
                    <h3 class="text-xl font-bold text-text-main dark:text-white flex items-center gap-2 mb-6">
                        <span class="material-symbols-outlined text-primary">payments</span>
                        Payment Method
                    </h3>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                        <!-- Visa -->
                        <label class="group cursor-pointer relative">
                            <input type="radio" name="paymentMethod" value="Visa" class="peer sr-only" id="paymentMethodVisa">
                            <div class="p-4 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all flex flex-col items-center gap-2 hover:bg-gray-100 dark:hover:bg-white/10 h-full justify-center">
                                <span class="material-symbols-outlined text-3xl">credit_card</span>
                                <span class="font-bold text-sm text-center">Visa Card</span>
                            </div>
                            <div class="absolute top-2 right-2 w-4 h-4 rounded-full border border-gray-300 dark:border-white/20 peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                        </label>

                        <!-- Mastercard (New) -->
                        <label class="group cursor-pointer relative">
                            <input type="radio" name="paymentMethod" value="Mastercard" class="peer sr-only" id="paymentMethodMastercard">
                            <div class="p-4 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all flex flex-col items-center gap-2 hover:bg-gray-100 dark:hover:bg-white/10 h-full justify-center">
                                <span class="material-symbols-outlined text-3xl">credit_score</span>
                                <span class="font-bold text-sm text-center">Mastercard</span>
                            </div>
                            <div class="absolute top-2 right-2 w-4 h-4 rounded-full border border-gray-300 dark:border-white/20 peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                        </label>

                        <!-- Debit -->
                        <label class="group cursor-pointer relative">
                            <input type="radio" name="paymentMethod" value="Debit Card" class="peer sr-only" id="paymentMethodDebit">
                            <div class="p-4 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all flex flex-col items-center gap-2 hover:bg-gray-100 dark:hover:bg-white/10 h-full justify-center">
                                <span class="material-symbols-outlined text-3xl">account_balance</span>
                                <span class="font-bold text-sm text-center">Debit Card</span>
                            </div>
                            <div class="absolute top-2 right-2 w-4 h-4 rounded-full border border-gray-300 dark:border-white/20 peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                        </label>

                        <!-- Cash -->
                        <label class="group cursor-pointer relative">
                            <input type="radio" name="paymentMethod" value="Cash on Delivery" class="peer sr-only" id="paymentMethodCash">
                            <div class="p-4 rounded-2xl border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 peer-checked:bg-primary/10 peer-checked:border-primary peer-checked:text-primary transition-all flex flex-col items-center gap-2 hover:bg-gray-100 dark:hover:bg-white/10 h-full justify-center">
                                <span class="material-symbols-outlined text-3xl">attach_money</span>
                                <span class="font-bold text-sm text-center">Cash</span>
                            </div>
                            <div class="absolute top-2 right-2 w-4 h-4 rounded-full border border-gray-300 dark:border-white/20 peer-checked:bg-primary peer-checked:border-primary transition-all"></div>
                        </label>
                    </div>

                    <!-- Payment Details Form -->
                    <div id="cardDetailsForm" class="hidden mt-6 pt-6 border-t border-gray-100 dark:border-white/5 space-y-4 animate-fade-in-down transition-all duration-300">
                        <div class="flex items-center justify-between">
                            <h4 class="font-bold text-text-main dark:text-white flex items-center gap-2">
                                <span class="material-symbols-outlined text-primary text-sm">lock</span>
                                Enter Card Details
                            </h4>
                            <div class="flex gap-2">
                                <span class="material-symbols-outlined text-2xl text-gray-400">credit_card</span>
                            </div>
                        </div>
                        
                        <div class="space-y-4">
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-wider text-text-main/50 dark:text-white/50 mb-1">Cardholder Name</label>
                                <input type="text" id="cardName" class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all" placeholder="John Doe">
                            </div>
                            <div>
                                <label class="block text-xs font-bold uppercase tracking-wider text-text-main/50 dark:text-white/50 mb-1">Card Number</label>
                                <div class="relative">
                                    <input type="text" id="cardNumber" class="w-full pl-10 pr-4 py-3 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all font-mono" placeholder="0000 0000 0000 0000" maxlength="19">
                                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-lg">credit_card</span>
                                </div>
                            </div>
                            <div class="grid grid-cols-2 gap-4">
                                 <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-text-main/50 dark:text-white/50 mb-1">Expiry Date</label>
                                    <input type="text" id="cardExpiry" class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all text-center" placeholder="MM/YY" maxlength="5">
                                </div>
                                <div>
                                    <label class="block text-xs font-bold uppercase tracking-wider text-text-main/50 dark:text-white/50 mb-1 flex items-center gap-1">
                                        CVV
                                        <span class="material-symbols-outlined text-[10px] cursor-help" title="3 digits on back of card">help</span>
                                    </label>
                                    <input type="password" id="cardCvv" class="w-full px-4 py-3 rounded-xl bg-gray-50 dark:bg-black/20 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all text-center" placeholder="•••" maxlength="3">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Order Summary Column -->
        <div class="w-full lg:w-[400px] xl:w-[450px] shrink-0 order-1 lg:order-2">
            <div class="sticky top-28 space-y-6" data-aos="fade-left" data-aos-delay="300">
                
                <!-- Promo Code Card -->
                <div class="glass-panel p-6 rounded-3xl shadow-lg border border-white/20 dark:border-white/5 relative overflow-hidden group">
                    <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-br from-primary/20 to-transparent rounded-bl-full -mr-4 -mt-4 transition-transform group-hover:scale-110"></div>
                    
                    <h3 class="text-lg font-bold text-text-main dark:text-white mb-4 flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">local_offer</span>
                        Have a coupon?
                    </h3>
                    <div class="flex gap-2 relative">
                        <input id="promoCodeInput" 
                               type="text" 
                               class="promo-input w-full pl-4 pr-12 py-3 rounded-xl bg-gray-50 dark:bg-black/30 border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-gray-400 focus:outline-none focus:border-primary transition-all font-medium" 
                               placeholder="Enter code" />
                        <button onclick="applyPromoCode()" class="absolute right-1 top-1 bottom-1 px-4 bg-black dark:bg-white text-white dark:text-black font-bold rounded-lg hover:bg-primary hover:text-black transition-colors text-sm shadow-md">
                            Apply
                        </button>
                    </div>
                </div>

                <!-- Totals Card -->
                <div class="bg-white dark:bg-card-dark rounded-[2rem] p-8 shadow-2xl border border-gray-100 dark:border-white/5 relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-primary via-orange-500 to-primary"></div>
                    
                    <h3 class="text-xl font-bold text-text-main dark:text-white mb-6">Order Summary</h3>
                    
                    <div class="space-y-4">
                        <div class="flex justify-between items-center text-text-main/70 dark:text-white/70">
                            <span class="font-medium">Subtotal</span>
                            <span id="subtotal" class="font-bold text-text-main dark:text-white">$0.00</span>
                        </div>
                        <div class="flex justify-between items-center text-text-main/70 dark:text-white/70">
                            <span class="font-medium flex items-center gap-1">
                                Delivery
                                <span class="material-symbols-outlined text-sm text-primary" title="Standard Delivery">info</span>
                            </span>
                            <span id="deliveryFee" class="font-bold text-text-main dark:text-white">$5.00</span>
                        </div>
                        <div class="flex justify-between items-center text-text-main/70 dark:text-white/70">
                            <span class="font-medium">Tax (10%)</span>
                            <span id="tax" class="font-bold text-text-main dark:text-white">$0.00</span>
                        </div>
                        
                        <div id="discountRow" class="hidden flex justify-between items-center bg-green-500/10 p-3 rounded-lg border border-green-500/20">
                            <span class="text-green-600 dark:text-green-400 font-bold text-sm flex items-center gap-1">
                                <span class="material-symbols-outlined text-sm">check_circle</span>
                                Discount Applied
                            </span>
                            <span id="discount" class="text-green-600 dark:text-green-400 font-bold">-$0.00</span>
                        </div>

                        <div class="border-t border-dashed border-gray-200 dark:border-white/10 my-4"></div>
                        
                        <div class="flex justify-between items-end mb-2">
                            <span class="text-lg font-bold text-text-main dark:text-white">Total</span>
                            <span id="total" class="text-4xl font-black text-primary tracking-tight">$0.00</span>
                        </div>
                        <p class="text-xs text-text-main/40 dark:text-white/40 text-right mb-6">Includes all taxes and fees</p>
                    </div>

                    <button onclick="placeOrder()" class="w-full relative group overflow-hidden bg-gradient-to-br from-primary to-[#ffc400] text-black font-black text-lg py-5 rounded-2xl shadow-xl shadow-primary/30 hover:shadow-primary/50 hover:scale-[1.02] active:scale-95 transition-all duration-300">
                        <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
                        <span class="relative flex items-center justify-center gap-3">
                            Confirm Order
                            <span class="material-symbols-outlined text-2xl group-hover:translate-x-1 transition-transform">arrow_forward</span>
                        </span>
                    </button>
                    
                    <div class="mt-6 flex items-center justify-center gap-4 text-gray-400 opacity-60 grayscale hover:grayscale-0 transition-all duration-500">
                        <span class="material-symbols-outlined text-2xl">credit_card</span>
                        <span class="material-symbols-outlined text-2xl">account_balance_wallet</span>
                        <span class="material-symbols-outlined text-2xl">payments</span>
                    </div>
                </div>

            </div>
        </div>
    </div>
</main>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            AOS.init({ once: true, duration: 800 });
            renderCartItems();
            
            // Update item count badge
            const itemCount = cart.items.length;
            const badge = document.getElementById('itemCountBadge');
            if (badge) {
                badge.textContent = `${itemCount} Item${itemCount !== 1 ? 's' : ''}`;
            }
            
            // Show/hide checkout details based on cart
            const checkoutDetails = document.getElementById('checkoutDetails');
            const emptyCart = document.getElementById('emptyCart');
            if (itemCount > 0) {
                if (checkoutDetails) checkoutDetails.classList.remove('hidden');
                if (emptyCart) emptyCart.classList.add('hidden');
            } else {
                if (checkoutDetails) checkoutDetails.classList.add('hidden');
                if (emptyCart) emptyCart.classList.remove('hidden');
                emptyCart.classList.add('flex');
            }
        });
    </script>
}
