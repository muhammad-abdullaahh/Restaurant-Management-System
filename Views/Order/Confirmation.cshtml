@model FoodHeaven.Models.Order
@{
    ViewData["Title"] = "Order Confirmation - FoodHeaven";
}



<!-- Main Content -->
<main class="mx-auto flex w-full flex-1 items-center justify-center px-4 py-12 bg-gray-100 dark:bg-black/50">
    <!-- Receipt Container -->
    <div class="w-full max-w-md bg-white text-black p-0 shadow-2xl relative animate-fade-in-up">
        
        <!-- Zigzag Top -->
        <div class="absolute top-0 left-0 right-0 h-4 bg-gray-100 dark:bg-black/50" style="background-image: linear-gradient(135deg, white 50%, transparent 50%), linear-gradient(225deg, white 50%, transparent 50%); background-position: top center; background-size: 20px 20px; background-repeat: repeat-x; transform: translateY(-10px);"></div>

        <div class="p-8 pb-4 text-center border-b-2 border-dashed border-gray-300">
            <div class="flex items-center justify-center mb-4">
                <span class="material-symbols-outlined text-4xl text-black">restaurant</span>
            </div>
            <h1 class="font-display font-black text-3xl uppercase tracking-widest mb-1">FoodHeaven</h1>
            <p class="font-mono text-sm uppercase text-gray-500">Fine Dining Experience</p>
            <p class="font-mono text-xs text-gray-400 mt-2">123 Gourmet Street, Food City</p>
            <p class="font-mono text-xs text-gray-400">+1 (555) 123-4567</p>
        </div>

        <div class="p-8 py-6">
            <div class="text-center mb-6">
                 <h2 class="font-mono font-bold text-2xl uppercase border-b-2 border-black inline-block pb-1 mb-2">Order Slip</h2>
                 <p class="font-mono text-sm text-gray-500">@Model.OrderNumber</p>
                 <p class="font-mono text-xs text-gray-400">@Model.OrderDate.ToString("MMM dd, yyyy - hh:mm tt")</p>
            </div>

            <!-- Customer -->
            <div class="mb-6 font-mono text-sm">
                <div class="flex justify-between border-b border-dashed border-gray-300 pb-2 mb-2">
                    <span class="text-gray-500">Customer:</span>
                    <span class="font-bold">@Model.CustomerName</span>
                </div>
                <!-- Status Badge -->
                 <div class="text-center mt-4">
                     <span class="border-2 border-black rounded px-3 py-1 font-bold uppercase text-xs tracking-wider">
                         Status: @Model.Status
                     </span>
                 </div>
            </div>

            <!-- Items -->
            <div class="space-y-3 mb-6 font-mono text-sm">
                 <div class="flex justify-between border-b border-black pb-2 font-bold">
                     <span>Item</span>
                     <span>Amt</span>
                 </div>
                 @if (Model.OrderItems != null)
                 {
                     @foreach (var item in Model.OrderItems)
                     {
                         <div class="flex justify-between items-start">
                             <div class="flex gap-2">
                                 <span class="font-bold">@item.Quantity x</span>
                                 <span class="max-w-[180px]">@item.MenuItem?.Name</span>
                             </div>
                             <span>$@((item.Price * item.Quantity).ToString("F2"))</span>
                         </div>
                     }
                 }
            </div>

            <!-- Totals -->
            <div class="border-t-2 border-dashed border-gray-300 pt-4 space-y-1 font-mono text-sm">
                 <div class="flex justify-between text-gray-500">
                     <span>Subtotal</span>
                     <span>$@Model.Subtotal.ToString("F2")</span>
                 </div>
                 <div class="flex justify-between text-gray-500">
                     <span>Delivery</span>
                     <span>$@Model.DeliveryFee.ToString("F2")</span>
                 </div>
                 <div class="flex justify-between text-gray-500">
                     <span>Tax (10%)</span>
                     <span>$@Model.Tax.ToString("F2")</span>
                 </div>
                 <div class="flex justify-between font-bold text-xl mt-3 pt-3 border-t-2 border-black">
                     <span>Total</span>
                     <span>$@Model.Total.ToString("F2")</span>
                 </div>
            </div>
            
            <div class="mt-8 text-center font-mono text-xs text-gray-400">
                <p>*** THANK YOU FOR VISITING ***</p>
                <p class="mt-1">Please come again!</p>
                <div class="mt-4 barcode h-12 bg-black w-2/3 mx-auto opacity-80" style="background: repeating-linear-gradient(90deg, black, black 2px, transparent 2px, transparent 3px);"></div>
            </div>

        </div>

        <!-- Buttons (Outside Receipt) -->
        <div class="p-6 bg-gray-50 border-t border-gray-200">
            <a href="/Menu" class="block w-full bg-black text-white font-bold py-3 text-center uppercase tracking-widest hover:bg-primary hover:text-black transition-colors mb-3">
                Order Again
            </a>
            <a href="/" class="block w-full text-gray-500 text-center text-sm hover:underline">
                Back to Home
            </a>
        </div>
        
        <!-- Zigzag Bottom -->
        <div class="absolute bottom-0 left-0 right-0 h-4 bg-gray-100 dark:bg-black/50" style="background-image: linear-gradient(135deg, transparent 50%, white 50%), linear-gradient(225deg, transparent 50%, white 50%); background-position: bottom center; background-size: 20px 20px; background-repeat: repeat-x; transform: translateY(10px);"></div>
    </div>
</main>

<!-- Footer -->

