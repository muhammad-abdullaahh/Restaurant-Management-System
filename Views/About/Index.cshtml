@{
    ViewData["Title"] = "About Us - FoodHeaven";
}

<!-- AOS & Styles -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<!-- Hero Section -->
<div class="relative h-[60vh] min-h-[500px] w-full overflow-hidden flex items-center justify-center bg-zinc-900 group">
    <div class="absolute inset-0 z-0">
        <img src="~/images/about_hero_v3.jpg" class="w-full h-full object-cover opacity-60 transform scale-100 group-hover:scale-105 transition-transform duration-[20s] ease-out" />
        <div class="absolute inset-0 bg-gradient-to-b from-transparent to-black/80"></div>
    </div>
    <div class="relative z-10 text-center px-4 max-w-4xl" data-aos="zoom-in" data-aos-duration="1000">
        <span class="text-primary font-bold tracking-[0.3em] uppercase mb-4 block animate-fade-in-down drop-shadow-md">Since 2010</span>
        <h1 class="text-6xl md:text-8xl font-display font-black text-white mb-6 animate-fade-in-up drop-shadow-2xl">Our Story</h1>
        <p class="text-white/90 text-xl font-light leading-relaxed animate-fade-in-up animation-delay-300 max-w-2xl mx-auto">
             A decade of passion, tradition, and culinary excellence served on every plate.
        </p>
    </div>
</div>

<!-- Philosophy Section -->
<section class="py-24 bg-background-light dark:bg-background-dark relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/2"></div>
    
    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row items-center gap-16">
            <div class="w-full md:w-1/2" data-aos="fade-right">
                <div class="relative group">
                    <div class="absolute inset-0 bg-black rounded-[2.5rem] transform translate-x-4 translate-y-4 group-hover:translate-x-2 group-hover:translate-y-2 transition-transform duration-500"></div>
                    <img src="~/images/about_gallery_1.jpg" class="relative w-full rounded-[2.5rem] shadow-2xl transition-transform duration-500 group-hover:-translate-y-1 grayscale group-hover:grayscale-0" alt="Philosophy" />
                    
                    <div class="absolute -bottom-8 -right-8 bg-white dark:bg-zinc-800 p-6 rounded-3xl shadow-xl max-w-xs hidden md:block" data-aos="fade-up" data-aos-delay="300">
                        <p class="font-display font-bold text-lg italic">"Food is symbolic of love when words are inadequate."</p>
                    </div>
                </div>
            </div>
            
            <div class="w-full md:w-1/2 space-y-8" data-aos="fade-left">
                <span class="text-primary font-bold tracking-widest uppercase">Our Philosophy</span>
                <h2 class="text-5xl font-black text-text-main dark:text-white leading-tight">Crafting Memories Through Flavor</h2>
                <p class="text-lg text-text-muted leading-relaxed">
                    At FoodHeaven, we believe that dining is not just about eating—it's about connection. Founded with a vision to bring authentic, world-class flavors to your table, we source only the freshest organic ingredients and prepare them with love and precision.
                </p>
                <p class="text-lg text-text-muted leading-relaxed">
                    Our journey began in a small kitchen with a big dream: to create a space where community, culture, and cuisine intersect. Today, we are proud to serve thousands of happy guests who call FoodHeaven their second home.
                </p>
                
                <div class="flex gap-8 pt-4">
                    <div>
                        <span class="block text-4xl font-black text-primary mb-1">15+</span>
                        <span class="text-sm font-bold text-text-muted uppercase tracking-wide">Years Served</span>
                    </div>
                    <div>
                        <span class="block text-4xl font-black text-primary mb-1">50k+</span>
                        <span class="text-sm font-bold text-text-muted uppercase tracking-wide">Happy Guests</span>
                    </div>
                    <div>
                        <span class="block text-4xl font-black text-primary mb-1">100+</span>
                        <span class="text-sm font-bold text-text-muted uppercase tracking-wide">Awards Won</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Team / Chef Section -->
<section class="py-24 bg-zinc-900 text-white relative">
    <div class="absolute inset-0 opacity-10 bg-[url('/images/about_hero.jpg')] bg-fixed bg-cover"></div>
    <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16" data-aos="fade-up">
            <span class="text-primary font-bold tracking-widest uppercase mb-2 block">The Mastermind</span>
            <h2 class="text-5xl font-black">Meet The Executive Chef</h2>
        </div>
        
        <div class="flex flex-col md:flex-row items-center gap-12 bg-white/5 backdrop-blur-md border border-white/10 rounded-[3rem] p-8 md:p-12 shadow-2xl" data-aos="zoom-in-up">
            <div class="w-full md:w-1/3 relative">
                <div class="aspect-[3/4] rounded-2xl overflow-hidden shadow-2xl ring-4 ring-white/10">
                    <img src="~/images/about_chef.jpg" class="w-full h-full object-cover" alt="Chef Marco" />
                </div>
                <div class="absolute -bottom-6 -right-6 bg-primary text-black p-4 rounded-xl shadow-lg rotate-3">
                    <span class="block text-2xl font-black">Marco R.</span>
                    <span class="text-sm font-bold uppercase">Head Chef</span>
                </div>
            </div>
            
            <div class="w-full md:w-2/3 space-y-6">
                <h3 class="text-4xl font-bold">"Passion is the secret ingredient."</h3>
                <p class="text-xl text-gray-300 font-light italic leading-relaxed">
                    "I started cooking with my grandmother when I was just five years old. She taught me that the best dishes aren't made with the most expensive ingredients, but with the utmost respect for what nature provides. Every dish at FoodHeaven tells a story of tradition, innovation, and heart."
                </p>
                <div class="h-px w-24 bg-primary my-6"></div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-sm font-bold text-gray-400">
                    <div class="flex items-center gap-2"><span class="material-symbols-outlined text-primary">restaurant</span> 20 Years Exp.</div>
                    <div class="flex items-center gap-2"><span class="material-symbols-outlined text-primary">workspace_premium</span> Michelin Star</div>
                    <div class="flex items-center gap-2"><span class="material-symbols-outlined text-primary">school</span> Culinary Institute</div>
                    <div class="flex items-center gap-2"><span class="material-symbols-outlined text-primary">public</span> Global Cuisine</div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Values Grid -->
<section class="py-24 bg-background-light dark:bg-background-dark">
    <div class="container mx-auto px-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <!-- 1 -->
            <div class="group bg-white dark:bg-card-dark rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 dark:border-white/5" data-aos="fade-up" data-aos-delay="0">
                <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:text-black transition-colors">eco</span>
                </div>
                <h3 class="text-2xl font-bold text-text-main dark:text-white mb-4">Sustainably Sourced</h3>
                <p class="text-text-muted">We work directly with local organic farms to ensure our ingredients are ethical, sustainable, and fresh.</p>
            </div>
            <!-- 2 -->
             <div class="group bg-white dark:bg-card-dark rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 dark:border-white/5" data-aos="fade-up" data-aos-delay="100">
                <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:text-black transition-colors">diamond</span>
                </div>
                <h3 class="text-2xl font-bold text-text-main dark:text-white mb-4">Premium Quality</h3>
                <p class="text-text-muted">Only the finest cuts of meat and freshest produce make it to your plate. No compromises.</p>
            </div>
            <!-- 3 -->
             <div class="group bg-white dark:bg-card-dark rounded-3xl p-8 shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 border border-gray-100 dark:border-white/5" data-aos="fade-up" data-aos-delay="200">
                <div class="w-20 h-20 bg-primary/10 rounded-2xl flex items-center justify-center mb-6 group-hover:bg-primary transition-colors duration-300">
                    <span class="material-symbols-outlined text-4xl text-primary group-hover:text-black transition-colors">diversity_3</span>
                </div>
                <h3 class="text-2xl font-bold text-text-main dark:text-white mb-4">Community Focused</h3>
                <p class="text-text-muted">We are more than a restaurant; we are a gathering place. We regularly support local charities and events.</p>
            </div>
        </div>
    </div>
</section>

<!-- Gallery Grid (Masonry effect roughly) -->
<section class="py-24 bg-zinc-900 text-center">
    <div class="container mx-auto px-6">
        <span class="text-primary font-bold tracking-widest uppercase mb-4 block">Visual Journey</span>
        <h2 class="text-4xl md:text-5xl font-black text-white mb-16">Moments of Joy</h2>
        
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 h-[800px] md:h-[600px]">
            <!-- Large Left -->
            <div class="col-span-2 row-span-2 relative group rounded-3xl overflow-hidden cursor-pointer" data-aos="zoom-in">
                 <img src="~/images/about_gallery_1.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                 <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                     <span class="text-white font-bold text-2xl tracking-widest uppercase">Precision</span>
                 </div>
            </div>
            <!-- Small 1 -->
            <div class="relative group rounded-3xl overflow-hidden cursor-pointer" data-aos="zoom-in" data-aos-delay="100">
                 <img src="~/images/about_gallery_2.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                 <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                     <span class="text-white font-bold tracking-widest uppercase">Craft</span>
                 </div>
            </div>
            <!-- Small 2 -->
             <div class="relative group rounded-3xl overflow-hidden cursor-pointer" data-aos="zoom-in" data-aos-delay="200">
                 <img src="~/images/about_gallery_3.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                 <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                     <span class="text-white font-bold tracking-widest uppercase">Flavor</span>
                 </div>
            </div>
            <!-- Wide Bottom Right -->
             <div class="col-span-2 relative group rounded-3xl overflow-hidden cursor-pointer" data-aos="zoom-in" data-aos-delay="300">
                 <img src="~/images/about_gallery_4.jpg" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                 <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                     <span class="text-white font-bold tracking-widest uppercase">Atmosphere</span>
                 </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA -->
<section class="py-24 bg-primary text-black text-center relative overflow-hidden">
     <div class="absolute top-0 left-0 w-full h-full opacity-10 bg-[url('/images/restaurant_hero_bg.png')] bg-cover"></div>
     <div class="relative z-10 px-6">
         <h2 class="text-5xl md:text-7xl font-black mb-8">Ready to Dine?</h2>
         <p class="text-xl md:text-2xl font-medium mb-12 max-w-2xl mx-auto opacity-80">Book your table now and let us take care of the rest.</p>
         <a href="/Reservation/Create" class="inline-block px-12 py-5 bg-black text-white text-xl font-bold rounded-full hover:scale-105 transition-transform shadow-2xl">Make a Reservation</a>
     </div>
</section>

<script>
    AOS.init({
        duration: 1000,
        once: true,
        offset: 100
    });
</script>

<style>
    .animate-fade-in-up { animation: fadeInUp 1s ease-out forwards; }
    .animate-fade-in-down { animation: fadeInDown 1s ease-out forwards; }
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-40px); } to { opacity: 1; transform: translateY(0); } }
    .animation-delay-300 { animation-delay: 300ms; }
</style>
