@{
    ViewData["Title"] = "Our Story - FoodHeaven";
}

<!-- Hero Section with Parallax -->
<div class="relative h-[55vh] min-h-[500px] w-full overflow-hidden flex items-center justify-center bg-zinc-950">
    <div class="absolute inset-0 z-0">
        <img src="~/images/about_hero_v3.jpg" class="w-full h-full object-cover opacity-50 transition-transform duration-[10s] animate-slow-zoom" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-background-light dark:to-background-dark"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl space-y-6">
        <div class="opacity-0 animate-fade-in-down">
            <span class="px-6 py-2 rounded-full border border-primary/40 text-primary bg-primary/5 backdrop-blur-xl text-xs font-black uppercase tracking-[0.4em]">Established 2010</span>
        </div>
        <h1 class="text-6xl md:text-[100px] font-display font-black text-white leading-none opacity-0 animate-fade-in-up animation-delay-300">
            A Legacy of <br /><span class="italic text-primary">Flavor</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/70 font-light max-w-3xl mx-auto opacity-0 animate-fade-in-up animation-delay-500 leading-relaxed">
            Crafting unforgettable dining experiences through tradition, innovation, and passion.
        </p>
    </div>
</div>

<!-- Main Content -->
<main class="container mx-auto px-4 py-20 -mt-24 relative z-20 mb-16">
    
    <!-- Philosophy Section -->
    <section class="mb-32 reveal">
        <div class="bg-white/80 dark:bg-card-dark/80 backdrop-blur-3xl rounded-[4rem] p-10 md:p-20 shadow-2xl border border-white/20 dark:border-white/5">
            <div class="flex flex-col lg:flex-row items-center gap-16">
                <div class="w-full lg:w-1/2 relative">
                    <div class="relative group">
                        <div class="absolute inset-0 bg-primary/20 rounded-[3rem] blur-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        <img src="~/images/about_gallery_1.jpg" class="relative w-full rounded-[3rem] shadow-2xl transition-transform duration-700 group-hover:-translate-y-4" alt="Philosophy" />
                        
                        <div class="absolute -bottom-8 -right-8 bg-black text-white p-8 rounded-[2.5rem] shadow-2xl max-w-xs hidden lg:block transform rotate-3">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-primary mb-4">
                                <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C20.1216 16 21.017 16.8954 21.017 18V21M5.017 21L5.017 18C5.017 16.8954 5.91243 16 7.017 16H10.017C11.1216 16 12.017 16.8954 12.017 18V21M10.017 11C11.1216 11 12.017 10.1046 12.017 9V6C12.017 4.89543 11.1216 4 10.017 4H7.017C5.91243 4 5.017 4.89543 5.017 6V9C5.017 10.1046 5.91243 11 7.017 11H10.017Z"/>
                            </svg>
                            <p class="font-display font-bold text-xl italic leading-relaxed">"Great food is the ultimate connector of souls."</p>
                            <p class="text-xs text-primary font-black uppercase tracking-widest mt-4">— Chef Marco</p>
                        </div>
                    </div>
                </div>
                
                <div class="w-full lg:w-1/2 space-y-8">
                    <div class="space-y-4">
                        <span class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-2 block">The Philosophy</span>
                        <h2 class="text-5xl md:text-6xl font-black text-text-main dark:text-white leading-none tracking-tighter">Crafting <span class="text-primary">Memories</span></h2>
                    </div>
                    <p class="text-xl text-text-muted font-light leading-relaxed">
                        At FoodHeaven, we believe that dining is not just about eating—it's about connection. Founded with a vision to bring authentic, world-class flavors to your table, we source only the freshest organic ingredients and prepare them with love and precision.
                    </p>
                    <p class="text-xl text-text-muted font-light leading-relaxed">
                        Our journey began in a small kitchen with a big dream: to create a space where community, culture, and cuisine intersect.
                    </p>
                    
                    <div class="grid grid-cols-3 gap-8 pt-6 border-t border-gray-100 dark:border-white/5">
                        <div class="text-center md:text-left">
                            <span class="block text-4xl font-black text-primary mb-1">15+</span>
                            <span class="text-[10px] font-black text-text-muted uppercase tracking-widest">Years</span>
                        </div>
                        <div class="text-center md:text-left">
                            <span class="block text-4xl font-black text-primary mb-1">50k</span>
                            <span class="text-[10px] font-black text-text-muted uppercase tracking-widest">Guests</span>
                        </div>
                        <div class="text-center md:text-left">
                            <span class="block text-4xl font-black text-primary mb-1">12</span>
                            <span class="text-[10px] font-black text-text-muted uppercase tracking-widest">Awards</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Chef Section -->
    <section class="mb-32 reveal">
        <div class="bg-zinc-950 rounded-[4rem] p-10 md:p-20 relative overflow-hidden shadow-2xl group">
            <div class="absolute inset-0 bg-[url('/images/about_hero.jpg')] opacity-10 bg-fixed bg-cover"></div>
            <div class="absolute inset-0 bg-gradient-to-br from-black via-black/90 to-primary/10"></div>
            
            <div class="relative z-10 flex flex-col lg:flex-row items-center gap-16">
                <div class="w-full lg:w-1/3">
                    <div class="relative aspect-[3/4] rounded-[2.5rem] overflow-hidden shadow-2xl border-4 border-white/5 group-hover:border-primary/20 transition-all duration-500">
                        <img src="~/images/about_chef.jpg" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" alt="Chef Marco" />
                        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent"></div>
                        <div class="absolute bottom-8 left-8">
                            <h4 class="text-2xl font-black text-white leading-none">Marco R.</h4>
                            <p class="text-primary font-bold text-xs uppercase tracking-widest mt-1">Executive Chef</p>
                        </div>
                    </div>
                </div>
                
                <div class="w-full lg:w-2/3 space-y-8">
                    <h3 class="text-4xl md:text-6xl font-black text-white leading-none tracking-tighter">"Passion is the <br /><span class="text-primary italic">secret</span> ingredient."</h3>
                    <p class="text-xl text-white/70 font-light italic leading-relaxed">
                        "I started cooking with my grandmother when I was just five years old. She taught me that the best dishes aren't made with the most expensive ingredients, but with the utmost respect for what nature provides. Every dish at FoodHeaven tells a story of tradition, innovation, and heart."
                    </p>
                    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                        <div class="flex items-center gap-3 text-white/60 hover:text-primary transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                                <path d="M11 9H9V2H7v7H5V2H3v7c0 2.12 1.66 3.84 3.75 3.97V22h2.5v-9.03C11.34 12.84 13 11.12 13 9V2h-2v7zm5-3v8h2.5v8H21V2c-2.76 0-5 2.24-5 4z"/>
                            </svg>
                            <span class="text-xs font-black uppercase tracking-widest">20 Years Exp</span>
                        </div>
                        <div class="flex items-center gap-3 text-white/60 hover:text-primary transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                                <path d="M17 3H7c-1.1 0-2 .9-2 2v16l7-3 7 3V5c0-1.1-.9-2-2-2z"/>
                            </svg>
                            <span class="text-xs font-black uppercase tracking-widest">Michelin Star</span>
                        </div>
                        <div class="flex items-center gap-3 text-white/60 hover:text-primary transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                                <path d="M5 13.18v4L12 21l7-3.82v-4L12 17l-7-3.82zM12 3L1 9l11 6 9-4.91V17h2V9L12 3z"/>
                            </svg>
                            <span class="text-xs font-black uppercase tracking-widest">Culinary Institute</span>
                        </div>
                        <div class="flex items-center gap-3 text-white/60 hover:text-primary transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                            </svg>
                            <span class="text-xs font-black uppercase tracking-widest">Global Cuisine</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Values Grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 reveal">
        <div class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-4 border border-gray-100 dark:border-white/5 text-center">
            <div class="size-20 mx-auto bg-primary/20 rounded-3xl flex items-center justify-center mb-8 shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                    <path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm-1-6.102l-2.012-2.013a1 1 0 00-1.414 1.414l2.719 2.72a1 1 0 001.414 0l6.72-6.72a1 1 0 00-1.414-1.414L11 15.898z"/>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-text-main dark:text-white mb-4">Sustainably Sourced</h3>
            <p class="text-text-muted leading-relaxed font-medium">Direct partnerships with local organic farms ensure ethical, fresh, and sustainable ingredients.</p>
        </div>
        
        <div class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-4 border border-gray-100 dark:border-white/5 text-center">
            <div class="size-20 mx-auto bg-primary/20 rounded-3xl flex items-center justify-center mb-8 shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                    <path d="M12.16 3.09L9 7H4.5c-.28 0-.5.22-.5.5v12c0 .28.22.5.5.5h15c.28 0 .5-.22.5-.5V7.5c0-.28-.22-.5-.5-.5H15l-2.84-3.91c-.1-.13-.24-.22-.4-.26-.16-.04-.33-.01-.48.08-.15.09-.27.22-.32.38zM12 12c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3z"/>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-text-main dark:text-white mb-4">Premium Quality</h3>
            <p class="text-text-muted leading-relaxed font-medium">Only the finest cuts of meat and hand-picked produce make it to your plate. No compromises, ever.</p>
        </div>

        <div class="group bg-white dark:bg-card-dark rounded-[3rem] p-10 shadow-xl hover:shadow-2xl transition-all duration-500 hover:-translate-y-4 border border-gray-100 dark:border-white/5 text-center">
            <div class="size-20 mx-auto bg-primary/20 rounded-3xl flex items-center justify-center mb-8 shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-primary">
                    <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5s-3 1.34-3 3 1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                </svg>
            </div>
            <h3 class="text-2xl font-black text-text-main dark:text-white mb-4">Community Focused</h3>
            <p class="text-text-muted leading-relaxed font-medium">We are more than a restaurant; we are a gathering place where culture and culinary art meet.</p>
        </div>
    </div>
</main>

<!-- Visual Journey Gallery -->
<section class="py-32 bg-zinc-950 reveal overflow-hidden">
    <div class="container mx-auto px-6 text-center mb-20">
        <span class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-2 block">Moments of Joy</span>
        <h2 class="text-4xl md:text-6xl font-black text-white tracking-tighter">Visual <span class="italic text-primary">Journey</span></h2>
    </div>
    
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 max-w-7xl mx-auto h-[600px] md:h-[800px] px-4">
        <div class="col-span-2 row-span-2 relative group rounded-[3rem] overflow-hidden cursor-pointer shadow-2xl">
             <img src="~/images/about_gallery_1.jpg" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" />
             <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                 <span class="text-white font-black text-3xl tracking-widest uppercase">Precision</span>
             </div>
        </div>
        <div class="relative group rounded-[3rem] overflow-hidden cursor-pointer shadow-2xl">
             <img src="~/images/about_gallery_2.jpg" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" />
             <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                 <span class="text-white font-black text-xl tracking-widest uppercase">Craft</span>
             </div>
        </div>
        <div class="relative group rounded-[3rem] overflow-hidden cursor-pointer shadow-2xl">
             <img src="~/images/about_gallery_3.jpg" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" />
             <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                 <span class="text-white font-black text-xl tracking-widest uppercase">Art</span>
             </div>
        </div>
        <div class="col-span-2 relative group rounded-[3rem] overflow-hidden cursor-pointer shadow-2xl">
             <img src="~/images/about_gallery_4.jpg" class="w-full h-full object-cover transition-transform duration-[2s] group-hover:scale-110" />
             <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center">
                 <span class="text-white font-black text-3xl tracking-widest uppercase">Soul</span>
             </div>
        </div>
    </div>
</section>

<!-- Call to Action -->
<section class="py-32 bg-primary text-black text-center relative overflow-hidden">
     <div class="absolute inset-0 opacity-10 bg-[url('/images/restaurant_hero_bg.png')] bg-cover animate-slow-zoom"></div>
     <div class="relative z-10 px-6 max-w-4xl mx-auto">
         <h2 class="text-6xl md:text-8xl font-black mb-8 tracking-tighter leading-none">Ready to <br />Taste <span class="italic">Heaven?</span></h2>
         <p class="text-xl md:text-2xl font-bold mb-12 opacity-80 leading-relaxed">Join us for an unforgettable dining experience where every bite is a revelation.</p>
         <a href="/Reservation/Create" class="inline-block px-16 py-6 bg-black text-white text-xl font-black rounded-3xl hover:scale-110 transition-all shadow-2xl active:scale-95">Make a Reservation</a>
     </div>
</section>

<style>
    .animate-slow-zoom { animation: slowZoom 25s infinite alternate ease-in-out; }
    @@keyframes slowZoom { from { transform: scale(1); } to { transform: scale(1.15); } }
    
    .animate-fade-in-up { animation: fadeInUp 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    .animate-fade-in-down { animation: fadeInDown 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(60px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-60px); } to { opacity: 1; transform: translateY(0); } }
    
    .animation-delay-300 { animation-delay: 300ms; }
    .animation-delay-500 { animation-delay: 500ms; }
</style>

@section Scripts {
    <script>
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
    </script>
}
