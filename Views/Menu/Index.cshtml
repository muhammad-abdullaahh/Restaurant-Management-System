@model List<FoodHeaven.Models.MenuItem>
@{
    ViewData["Title"] = "Menu - FoodHeaven";
    
    var categoryIcons = new Dictionary<string, string> {
        { "Starters", "tapas" },
        { "Mains", "restaurant" },
        { "BBQ", "outdoor_grill" },
        { "Platters", "brunch_dining" },
        { "Desserts", "cake" },
        { "Ice Cream", "icecream" },
        { "Shakes", "blender" },
        { "Drinks", "local_bar" },
        { "Healthy", "eco" },
        { "Desi", "rice_bowl" }
    };
}

<!-- AOS & Styles -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>

<!-- Hero Section -->
<div class="relative h-[45vh] min-h-[400px] w-full overflow-hidden flex items-center justify-center bg-zinc-900 group">
    <div class="absolute inset-0 z-0 overflow-hidden">
        <img src="~/images/restaurant_hero_bg.png" class="w-full h-full object-cover opacity-60 transform scale-105 group-hover:scale-100 transition-transform duration-[10s] ease-out" />
        <div class="absolute inset-0 bg-gradient-to-t from-background-light dark:from-background-dark via-transparent to-black/60"></div>
    </div>
    <div class="relative z-10 text-center px-4 mt-16 max-w-4xl">
        <span class="text-primary font-bold tracking-[0.4em] uppercase mb-4 block animate-fade-in-down drop-shadow-lg">Taste The Extraordinary</span>
        <h1 class="text-6xl md:text-8xl font-display font-black text-white mb-6 animate-fade-in-up drop-shadow-xl tracking-tight">Our Menu</h1>
        <p class="text-white/90 text-xl font-light leading-relaxed animate-fade-in-up animation-delay-300 drop-shadow-md">
             A culinary journey curated just for you. Fresh ingredients, masterful techniques, and unforgettable flavors in every bite.
        </p>
    </div>
</div>

<!-- Main Layout -->
<main class="container mx-auto px-4 py-16 flex flex-col lg:flex-row gap-12 relative z-20 -mt-20">
    
    <!-- Sidebar (Desktop) -->
    <aside class="hidden lg:block w-80 shrink-0 sticky top-28 h-fit z-30" data-aos="fade-right" data-aos-delay="100">
        <div class="rounded-3xl bg-white/90 dark:bg-card-dark/90 backdrop-blur-xl p-6 shadow-2xl border border-white/20 dark:border-white/5 ring-1 ring-black/5">
            <h3 class="mb-6 text-2xl font-black text-text-main dark:text-white border-b-2 border-primary/20 pb-4 pl-2 flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">category</span> Categories
            </h3>
            <div class="flex flex-col gap-2 max-h-[60vh] overflow-y-auto pr-2 custom-scrollbar">
                <a href="/Menu" class="group flex items-center justify-between rounded-2xl px-5 py-4 transition-all duration-300 @(ViewBag.SelectedCategory == "All" || string.IsNullOrEmpty(ViewBag.SelectedCategory) ? "bg-gradient-to-r from-primary to-primary/80 text-black font-bold shadow-lg shadow-primary/30 scale-100" : "hover:bg-gray-100 dark:hover:bg-white/10 text-text-main/70 dark:text-white/70 hover:translate-x-2")">
                    <span class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-[24px]">restaurant_menu</span>
                        <span class="text-lg">All Items</span>
                    </span>
                    <span class="@(ViewBag.SelectedCategory == "All" || string.IsNullOrEmpty(ViewBag.SelectedCategory) ? "bg-black/20 text-black" : "bg-gray-200 dark:bg-white/10") text-xs px-2.5 py-1 rounded-full font-bold">@Model.Count</span>
                </a>
                @if (ViewBag.Categories != null)
                {
                    @foreach (var category in ViewBag.Categories)
                    {
                        var categoryCount = Model.Count(m => m.Category == category);
                        var icon = categoryIcons.ContainsKey(category) ? categoryIcons[category] : "lunch_dining";
                        
                        <a href="/Menu?category=@category" class="group flex items-center justify-between rounded-2xl px-5 py-4 transition-all duration-300 @(ViewBag.SelectedCategory == category ? "bg-gradient-to-r from-primary to-primary/80 text-black font-bold shadow-lg shadow-primary/30 scale-100" : "hover:bg-gray-100 dark:hover:bg-white/10 text-text-main/70 dark:text-white/70 hover:translate-x-2")">
                            <span class="flex items-center gap-3">
                                <span class="material-symbols-outlined text-[24px] group-hover:text-primary transition-colors">@icon</span>
                                <span class="text-lg">@category</span>
                            </span>
                             <span class="@(ViewBag.SelectedCategory == category ? "bg-black/20 text-black" : "bg-gray-200 dark:bg-white/10") text-xs px-2.5 py-1 rounded-full font-bold">@categoryCount</span>
                        </a>
                    }
                }
            </div>
        </div>
        
        <!-- Interactive Promo Banner -->
        <div class="mt-8 rounded-3xl relative overflow-hidden group shadow-2xl cursor-pointer transform hover:scale-[1.02] transition-all duration-500">
             <div class="absolute inset-0 bg-cover bg-center transition-transform duration-1000 group-hover:scale-110" style="background-image: url('/images/about_gallery_4.jpg')"></div>
             <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>
             <div class="relative z-10 p-8 text-center text-white">
                 <div class="inline-block p-3 rounded-full bg-primary/20 backdrop-blur-md mb-4 animate-bounce">
                     <span class="material-symbols-outlined text-4xl text-primary">event_seat</span>
                 </div>
                 <h4 class="text-2xl font-black mb-2">Book Your Table</h4>
                 <p class="text-sm text-gray-200 mb-6 font-medium">Secure the best spot for an unforgettable dining experience.</p>
                 <a href="/Reservation/Create" class="block w-full py-3 bg-white text-black font-bold rounded-xl hover:bg-primary transition-colors shadow-lg block text-center">Reserve Now</a>
             </div>
        </div>
    </aside>

    <!-- Content Area -->
    <div class="flex-1 min-w-0">
        
        <!-- Mobile Pills -->
        <div class="lg:hidden w-full overflow-x-auto no-scrollbar mb-8 -mx-4 px-4 sticky top-[70px] z-30 pb-4">
             <div class="bg-white/80 dark:bg-card-dark/80 backdrop-blur-lg rounded-2xl p-2 shadow-lg ring-1 ring-black/5 flex gap-2 min-w-max">
                <a href="/Menu" class="flex items-center gap-2 rounded-xl px-4 py-2 transition-all @(ViewBag.SelectedCategory == "All" || string.IsNullOrEmpty(ViewBag.SelectedCategory) ? "bg-primary text-black font-bold shadow-md" : "hover:bg-gray-100 dark:hover:bg-white/10 text-text-main dark:text-white font-medium")">
                    All
                </a>
                @if (ViewBag.Categories != null)
                {
                    @foreach (var category in ViewBag.Categories)
                    {
                         <a href="/Menu?category=@category" class="flex items-center gap-2 rounded-xl px-4 py-2 transition-all @(ViewBag.SelectedCategory == category ? "bg-primary text-black font-bold shadow-md" : "hover:bg-gray-100 dark:hover:bg-white/10 text-text-main dark:text-white font-medium")">
                            @category
                        </a>
                    }
                }
            </div>
        </div>

        <!-- Mobile Promo Banner -->
        <div class="lg:hidden mb-8 rounded-3xl relative overflow-hidden group shadow-xl">
             <div class="absolute inset-0 bg-cover bg-center" style="background-image: url('/images/about_gallery_4.jpg')"></div>
             <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/50 to-transparent"></div>
             <div class="relative z-10 p-6 text-center text-white">
                 <div class="inline-block p-3 rounded-full bg-primary/20 backdrop-blur-md mb-3">
                     <span class="material-symbols-outlined text-3xl text-primary">event_seat</span>
                 </div>
                 <h4 class="text-xl font-black mb-1">Book Your Table</h4>
                 <p class="text-xs text-gray-200 mb-4 font-medium">Secure the best spot for an unforgettable dining experience.</p>
                 <a href="/Reservation/Create" class="block w-full py-3 bg-white text-black font-bold rounded-xl hover:bg-primary transition-colors shadow-lg text-center">Reserve Now</a>
             </div>
        </div>

        @if ((ViewBag.SelectedCategory == "All" || string.IsNullOrEmpty(ViewBag.SelectedCategory)) && Model.Any())
        {
            <!-- Trending Section (Only on All Items) -->
            <div class="mb-12" data-aos="fade-up">
                <div class="flex items-end justify-between mb-6">
                    <div>
                        <span class="text-primary font-bold tracking-widest uppercase text-sm">Most Loved</span>
                        <h2 class="text-3xl font-black text-text-main dark:text-white">Trending Now</h2>
                    </div>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    @{
                        // Pick 3 random high rated items
                        var random = new Random();
                        var trending = Model.OrderByDescending(m => m.Rating).Take(10).OrderBy(x => random.Next()).Take(3).ToList();
                    }
                    @foreach (var item in trending)
                    {
                        <div onclick="openProductModal(this, event)" class="group cursor-pointer relative h-64 md:h-80 rounded-3xl overflow-hidden shadow-xl"
                             data-id="@item.Id" data-name="@item.Name" data-price="@item.Price" data-image="@item.ImageUrl" data-rating="@item.Rating" data-description="@item.Description">
                            <img src="@item.ImageUrl" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                            <div class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent"></div>
                            <div class="absolute bottom-0 left-0 right-0 p-6">
                                <div class="flex items-center gap-2 mb-2">
                                     <span class="bg-primary text-black text-[10px] font-bold px-2 py-0.5 rounded uppercase">Trending</span>
                                     <div class="flex text-primary text-xs"><span class="material-symbols-outlined text-[14px] fill-current">star</span> @item.Rating</div>
                                </div>
                                <h3 class="text-xl font-bold text-white mb-1">@item.Name</h3>
                                <p class="text-white/70 text-sm line-clamp-1 mb-3">@item.Description</p>
                                <div class="flex justify-between items-center mt-2">
                                    <span class="text-xl font-bold text-primary">$@item.Price.ToString("F2")</span>
                                    <button onclick="quickAdd(this, event)" class="bg-white text-black px-4 py-2 rounded-full font-bold text-sm hover:bg-primary transition-colors shadow-lg flex items-center gap-1">
                                        <span class="material-symbols-outlined text-sm">add_shopping_cart</span> Add
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }

        <!-- Menu Grid -->
        <h2 class="text-xl font-bold text-text-main dark:text-white mb-6 uppercase tracking-wider opacity-60">Full Menu Selection</h2>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8">
                @foreach (var item in Model)
                {
                    <div data-aos="fade-up" data-aos-offset="50"
                         onclick="openProductModal(this, event)" 
                         class="group bg-white dark:bg-card-dark rounded-[2.5rem] p-4 shadow-soft dark:shadow-none hover:shadow-2xl hover:shadow-primary/10 hover:-translate-y-2 transition-all duration-500 cursor-pointer border border-transparent hover:border-primary/20 relative"
                         data-id="@item.Id"
                         data-name="@item.Name"
                         data-price="@item.Price"
                         data-image="@item.ImageUrl"
                         data-rating="@item.Rating"
                         data-description="@item.Description">
                         
                        <!-- Image -->
                        <div class="relative h-56 rounded-[2rem] overflow-hidden mb-4 shadow-md bg-gray-100 dark:bg-zinc-900">
                             <img src="@item.ImageUrl" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                             <!-- Quick Add Button Removed -->
                        </div>

                        <!-- Info -->
                        <div class="px-2 pb-2">
                            <div class="flex justify-between items-start mb-2">
                                <h3 class="text-xl font-bold text-text-main dark:text-white leading-tight pr-2 group-hover:text-primary transition-colors">@item.Name</h3>
                                <span class="text-xl font-black text-text-main dark:text-white">$@item.Price.ToString("F0")</span>
                            </div>
                            <p class="text-text-main/50 dark:text-white/50 text-sm line-clamp-2 mb-4 font-medium h-10">@item.Description</p>
                            
                            <!-- Rating & Action -->
                            <div class="flex justify-between items-center mt-4">
                                <div class="flex items-center gap-1">
                                    <span class="material-symbols-outlined text-[18px] text-yellow-500 fill-current">star</span>
                                    <span class="font-bold text-text-main dark:text-white">@item.Rating</span>
                                </div>
                                <button onclick="quickAdd(this, event)" class="px-4 py-2 bg-black dark:bg-white text-white dark:text-black text-sm font-bold rounded-xl hover:scale-105 active:scale-95 transition-all shadow-lg flex items-center gap-2 hover:bg-primary hover:text-black dark:hover:bg-primary dark:hover:text-black">
                                    Add <span class="material-symbols-outlined text-sm">add</span>
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
             <div class="text-center py-20 bg-gray-50 dark:bg-white/5 rounded-[3rem] border-2 border-dashed border-gray-200 dark:border-white/10">
                <div class="inline-flex items-center justify-center w-24 h-24 rounded-full bg-gray-100 dark:bg-white/10 mb-6 text-gray-400">
                    <span class="material-symbols-outlined text-5xl">manage_search</span>
                </div>
                <h3 class="text-3xl font-bold text-text-main dark:text-white mb-2">No Items Found</h3>
                <p class="text-text-muted text-lg max-w-md mx-auto">We couldn't find any items matching your selection.</p>
                <a href="/Menu" class="mt-8 inline-block px-8 py-4 bg-black text-white font-bold rounded-2xl hover:scale-105 transition-transform shadow-lg">View All Menu</a>
            </div>
        }
    </div>
</main>


<!-- Product Modal -->
<!-- Product Modal -->
<div id="productModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-black/80 backdrop-blur-sm transition-opacity duration-500" onclick="closeProductModal()"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[95vw] md:w-[1100px] md:max-w-[95vw] h-[85vh] md:h-auto md:max-h-[85vh] bg-white dark:bg-zinc-900 rounded-[3rem] shadow-2xl overflow-hidden flex flex-col md:flex-row transform transition-all duration-500 opacity-0 scale-95 ring-1 ring-white/10" id="modalContent">
        
        <!-- Image & Gallery (Left Side) - Interactive 3D -->
        <div id="modalVisuals" class="w-full md:w-[45%] h-72 md:h-auto relative bg-zinc-900 group overflow-hidden" style="perspective: 1000px;">
             <!-- Tilt Container -->
             <div id="modalTiltContent" class="w-full h-full relative transition-transform duration-200 ease-out" style="transform-style: preserve-3d;">
                 <img id="modalImage" src="" class="w-full h-full object-cover opacity-90 transition-transform duration-[3s] group-hover:scale-110" style="transform: translateZ(-50px) scale(1.1);" />
                 
                 <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-transparent opacity-90 transition-opacity duration-500 group-hover:opacity-80"></div>
                 
                 <!-- Mobile Close Button -->
                 <button onclick="closeProductModal()" class="absolute top-6 left-6 p-3 bg-white/10 hover:bg-white/20 backdrop-blur-md rounded-full text-white transition-all md:hidden border border-white/10 z-50">
                     <span class="material-symbols-outlined">arrow_downward</span>
                 </button>

                 <!-- Content Layer with Depth -->
                 <div class="absolute bottom-10 left-8 right-8" style="transform: translateZ(50px);">
                     <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/20 backdrop-blur-md border border-white/20 text-white text-xs font-bold uppercase tracking-wider mb-4 shadow-lg animate-pulse">
                        <span class="material-symbols-outlined text-sm text-primary">verified</span> Signature Dish
                     </div>
                     <h2 id="modalTitle" class="text-4xl md:text-5xl font-black text-white leading-none drop-shadow-2xl mb-3 shadow-black"></h2>
                     <div class="flex items-center gap-2 text-white/90 text-sm font-medium bg-black/40 w-fit px-3 py-1 rounded-lg backdrop-blur-sm">
                         <span class="material-symbols-outlined text-primary text-lg animate-bounce">local_fire_department</span>
                         <span>Hot & Fresh</span>
                         <span class="w-1 h-1 bg-white/50 rounded-full mx-1"></span>
                         <span>Chef's Special</span>
                     </div>
                 </div>
             </div>
        </div>

        <!-- Details (Right Side) -->
        <div class="flex-1 p-8 md:p-12 flex flex-col h-full bg-white dark:bg-[#121212] relative">
             <!-- Top Bar (Rating & Close) -->
             <div class="flex justify-between items-start mb-8">
                 <div>
                      <div class="flex items-center gap-3 mb-1">
                           <div class="flex text-[#FFD700]">
                               <span class="material-symbols-outlined fill-current text-xl">star</span>
                               <span class="material-symbols-outlined fill-current text-xl">star</span>
                               <span class="material-symbols-outlined fill-current text-xl">star</span>
                               <span class="material-symbols-outlined fill-current text-xl">star</span>
                               <span class="material-symbols-outlined fill-current text-xl">star_half</span>
                           </div>
                           <span class="text-text-main/60 dark:text-white/60 font-semibold text-sm tracking-wide">(240+ Reviews)</span>
                      </div>
                      <span id="modalRating" class="hidden"></span>
                 </div>
                 <button onclick="closeProductModal()" class="hidden md:flex p-2.5 rounded-full hover:bg-gray-100 dark:hover:bg-white/10 transition-colors text-text-main/50 dark:text-white/50 hover:text-black dark:hover:text-white">
                    <span class="material-symbols-outlined text-3xl">close</span>
                </button>
             </div>

             <!-- Description -->
             <div class="mb-8 overflow-y-auto custom-scrollbar flex-1 pr-2">
                 <h3 class="text-xs font-bold text-gray-400 uppercase tracking-widest mb-3">Description</h3>
                 <p id="modalDescription" class="text-xl md:text-2xl text-text-main dark:text-white font-serif leading-relaxed"></p>
             </div>

             <!-- Info Pills -->
             <div class="flex flex-wrap gap-4 mb-10">
                 <div class="flex items-center gap-3 px-5 py-3 bg-gray-50 dark:bg-white/5 rounded-2xl border border-gray-100 dark:border-white/5">
                     <div class="p-2 bg-white dark:bg-white/10 rounded-full shadow-sm text-primary">
                        <span class="material-symbols-outlined text-xl">timer</span>
                     </div>
                     <div>
                         <p class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Time</p>
                         <p class="font-bold text-text-main dark:text-white">20 Mins</p>
                     </div>
                 </div>
                 <div class="flex items-center gap-3 px-5 py-3 bg-gray-50 dark:bg-white/5 rounded-2xl border border-gray-100 dark:border-white/5">
                     <div class="p-2 bg-white dark:bg-white/10 rounded-full shadow-sm text-orange-500">
                        <span class="material-symbols-outlined text-xl">local_fire_department</span>
                     </div>
                     <div>
                         <p class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Energy</p>
                         <p class="font-bold text-text-main dark:text-white">140 Cal</p>
                     </div>
                 </div>
                 <div class="flex items-center gap-3 px-5 py-3 bg-gray-50 dark:bg-white/5 rounded-2xl border border-gray-100 dark:border-white/5">
                     <div class="p-2 bg-white dark:bg-white/10 rounded-full shadow-sm text-green-500">
                        <span class="material-symbols-outlined text-xl">eco</span>
                     </div>
                     <div>
                         <p class="text-[10px] uppercase font-bold text-gray-400 tracking-wider">Type</p>
                         <p class="font-bold text-text-main dark:text-white">Fresh</p>
                     </div>
                 </div>
             </div>

             <!-- Bottom Actions -->
             <div class="flex flex-col md:flex-row items-center gap-6 pt-6 border-t border-gray-100 dark:border-white/10">
                 <div class="text-4xl md:text-5xl font-black text-text-main dark:text-white tracking-tight" id="modalPrice"></div>
                 
                 <div class="flex-1 w-full flex gap-4">
                     <!-- Add to Cart Removed -->
                     
                     <!-- Order Now -->
                     <button id="modalOrderNow" class="flex-[1.4] h-16 bg-gradient-to-r from-primary to-[#FFD700] text-black font-black rounded-2xl text-lg shadow-xl shadow-primary/20 hover:shadow-primary/40 hover:scale-[1.02] hover:-translate-y-1 transition-all duration-300 flex items-center justify-center gap-3 relative overflow-hidden">
                         <div class="absolute inset-0 bg-white/20 translate-y-full hover:translate-y-0 transition-transform duration-300"></div>
                         <span class="relative z-10">Order Now</span>
                         <span class="material-symbols-outlined relative z-10 text-2xl">arrow_forward</span>
                     </button>
                 </div>
             </div>
        </div>
    </div>
</div>

<script>
    // 3D Tilt Effect for Modal Visuals
    const visualContainer = document.getElementById('modalVisuals');
    const tiltContent = document.getElementById('modalTiltContent');

    if (visualContainer && tiltContent) {
        visualContainer.addEventListener('mousemove', (e) => {
            if (window.innerWidth < 768) return; // Disable on mobile
            
            const rect = visualContainer.getBoundingClientRect();
            const x = e.clientX - rect.left;
            const y = e.clientY - rect.top;
            
            // Calculate percentage from center
            const xPct = (x / rect.width) - 0.5;
            const yPct = (y / rect.height) - 0.5;
            
            // Max rotation deg
            const rotateX = yPct * -15; // Invert Y for natural tilt
            const rotateY = xPct * 15;
            
            requestAnimationFrame(() => {
                tiltContent.style.transform = `rotateX(${rotateX}deg) rotateY(${rotateY}deg)`;
            });
        });

        visualContainer.addEventListener('mouseleave', () => {
             requestAnimationFrame(() => {
                tiltContent.style.transform = `rotateX(0) rotateY(0)`;
             });
        });
    }

    // Initialize AOS
    AOS.init({
        duration: 800,
        once: true,
        easing: 'ease-out-cubic'
    });

    function quickAdd(element, event) {
        event.stopPropagation();
        event.preventDefault();
        
        // Prevent multiple clicks while animation is running
        if (element.classList.contains('bg-green-500')) return;
        
        const card = element.closest('.group');
        const data = card.dataset;
        
        const itemData = {
            id: parseInt(data.id),
            name: data.name,
            price: parseFloat(data.price),
            imageUrl: data.image
        };
        
        if (typeof cart !== 'undefined') {
            cart.addItem(itemData);
            
            // Visual feedback
            const btn = element;
            const originalContent = btn.innerHTML;
            const originalClasses = btn.className; // Save exact original classes
            
            btn.innerHTML = '<span class="material-symbols-outlined text-sm">check</span>';
            btn.classList.add('bg-green-500', 'text-white', 'border-green-500');
            
            setTimeout(() => {
                btn.innerHTML = originalContent;
                btn.className = originalClasses; // Restore exact original classes
            }, 1000);
        }
    }

    function openProductModal(element, event) {
        if (event && event.target.closest('.add-to-cart')) {
             return;
        }
        
        const modal = document.getElementById('productModal');
        const content = document.getElementById('modalContent');
        const data = element.dataset;

        document.getElementById('modalImage').src = data.image;
        document.getElementById('modalTitle').textContent = data.name;
        document.getElementById('modalRating').textContent = data.rating;
        document.getElementById('modalDescription').textContent = data.description;
        document.getElementById('modalPrice').textContent = '$' + parseFloat(data.price).toFixed(2);

        // Add to Cart logic removed

        // Order Now Button Logic
        const orderBtn = document.getElementById('modalOrderNow');
        const newOrderBtn = orderBtn.cloneNode(true);
        orderBtn.parentNode.replaceChild(newOrderBtn, orderBtn);

        newOrderBtn.addEventListener('click', function(e) {
            e.preventDefault();
            
            const itemData = {
                id: parseInt(data.id),
                name: data.name,
                price: parseFloat(data.price),
                imageUrl: data.image
            };
            
            console.log('Adding item to cart:', itemData); // Debug log
            
            if (typeof cart !== 'undefined') {
                cart.addItem(itemData, true); // Add silently to cart
                console.log('Cart after adding:', cart.items); // Debug log
            }

            closeProductModal();
            
            // Small delay to ensure localStorage is saved before redirect
            setTimeout(() => {
                window.location.href = '/Order/Cart';
            }, 100);
        });

        modal.classList.remove('hidden');
        requestAnimationFrame(() => {
            content.classList.remove('scale-95', 'opacity-0');
        });
        document.body.style.overflow = 'hidden';
    }

    function closeProductModal() {
        const modal = document.getElementById('productModal');
        const content = document.getElementById('modalContent');
        
        content.classList.add('scale-95', 'opacity-0');
        
        setTimeout(() => {
            modal.classList.add('hidden');
            document.body.style.overflow = '';
        }, 300);
    }
    
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && !document.getElementById('productModal').classList.contains('hidden')) {
            closeProductModal();
        }
    });

</script>

