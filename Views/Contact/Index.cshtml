@model FoodHeaven.Models.ContactMessage
@{
    ViewData["Title"] = "Contact Us - FoodHeaven";
}

<!-- Hero Section with Parallax -->
<div class="relative h-[55vh] min-h-[500px] w-full overflow-hidden flex items-center justify-center bg-zinc-950">
    <div class="absolute inset-0 z-0">
        <img id="contact-hero-bg" src="~/images/contact_hero.png" class="w-full h-full object-cover opacity-50 transition-transform duration-[10s] animate-slow-zoom" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-background-light dark:to-background-dark"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl space-y-6">
        <div class="opacity-0 animate-fade-in-down">
            <span class="px-6 py-2 rounded-full border border-primary/40 text-primary bg-primary/5 backdrop-blur-xl text-xs font-black uppercase tracking-[0.4em]">Get In Touch</span>
        </div>
        <h1 class="text-6xl md:text-[100px] font-display font-black text-white leading-none opacity-0 animate-fade-in-up animation-delay-300">
            Let's Start a <br /><span class="italic text-primary">Conversation</span>
        </h1>
        <p class="text-xl md:text-2xl text-white/70 font-light max-w-3xl mx-auto opacity-0 animate-fade-in-up animation-delay-500 leading-relaxed">
            Have a question, feedback, or a special request? Our team is ready to assist you.
        </p>
    </div>
</div>

<!-- Main Content -->
<main class="container mx-auto px-4 py-20 -mt-24 relative z-20 mb-16">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-20">
        
        <!-- Left: Contact Details & Stats -->
        <div class="lg:w-5/12 space-y-10 reveal">
            
            <div class="space-y-6">
                <!-- Phone -->
                <div class="group bg-white/80 dark:bg-card-dark/80 backdrop-blur-3xl p-8 rounded-[2.5rem] shadow-xl border border-white/20 dark:border-white/5 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl cursor-pointer" onclick="copyToClipboard('+15551234567', 'Phone copied!')">
                    <div class="flex items-center gap-6">
                        <div class="w-16 h-16 rounded-2xl bg-primary/20 flex items-center justify-center text-primary shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20.01 15.38c-1.23 0-2.42-.2-3.53-.56a.977.977 0 00-1.01.24l-2.2 2.2a15.045 15.045 0 01-6.59-6.59l2.2-2.21a.96.96 0 00.25-1.01c-.36-1.11-.56-2.3-.56-3.53 0-.54-.45-.99-.99-.99H4.19C3.65 3 3 3.24 3 3.99 3 13.28 10.72 21 20.01 21c.71 0 .99-.63.99-1.18v-3.45c0-.54-.45-.99-.99-.99z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-[10px] font-black tracking-[0.2em] text-gray-400 uppercase mb-1">Direct Line</p>
                            <h3 class="text-2xl font-black text-text-main dark:text-white">+1 (555) 123-4567</h3>
                        </div>
                    </div>
                </div>

                <!-- Email -->
                <div class="group bg-white/80 dark:bg-card-dark/80 backdrop-blur-3xl p-8 rounded-[2.5rem] shadow-xl border border-white/20 dark:border-white/5 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl cursor-pointer" onclick="copyToClipboard('info@foodheaven.com', 'Email copied!')">
                    <div class="flex items-center gap-6">
                        <div class="w-16 h-16 rounded-2xl bg-blue-500/20 flex items-center justify-center text-blue-500 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-[10px] font-black tracking-[0.2em] text-gray-400 uppercase mb-1">Official Support</p>
                            <h3 class="text-2xl font-black text-text-main dark:text-white">info@foodheaven.com</h3>
                        </div>
                    </div>
                </div>

                <!-- Address -->
                <div class="group bg-white/80 dark:bg-card-dark/80 backdrop-blur-3xl p-8 rounded-[2.5rem] shadow-xl border border-white/20 dark:border-white/5 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl">
                    <div class="flex items-center gap-6">
                        <div class="w-16 h-16 rounded-2xl bg-emerald-500/20 flex items-center justify-center text-emerald-500 shadow-inner">
                            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor">
                                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 010-5 2.5 2.5 0 010 5z"/>
                            </svg>
                        </div>
                        <div>
                            <p class="text-[10px] font-black tracking-[0.2em] text-gray-400 uppercase mb-1">Our Location</p>
                            <h3 class="text-2xl font-black text-text-main dark:text-white leading-tight">123 Gourmet Street,<br />Food City, NY 10001</h3>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Operating Hours Card -->
            <div class="bg-zinc-950 rounded-[3rem] p-10 border border-white/5 relative overflow-hidden group shadow-2xl">
                <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-transparent opacity-50"></div>
                <div class="relative z-10">
                    <h3 class="text-2xl font-black text-white mb-8 flex items-center gap-3">
                        <span class="material-symbols-outlined text-primary text-3xl animate-pulse">schedule</span>
                        Operating Hours
                    </h3>
                    <div class="space-y-6">
                        <div class="flex justify-between items-center group/line">
                            <span class="text-white/60 font-medium group-hover/line:text-primary transition-colors">Monday - Friday</span>
                            <span class="text-white font-black">09:00 AM - 03:00 AM</span>
                        </div>
                        <div class="flex justify-between items-center group/line">
                            <span class="text-white/60 font-medium group-hover/line:text-primary transition-colors">Saturday - Sunday</span>
                            <span class="text-white font-black text-primary">09:00 AM - 04:00 AM</span>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- Right: Modern Contact Form -->
        <div class="lg:w-7/12 reveal">
             <div class="bg-white dark:bg-card-dark rounded-[3rem] p-10 md:p-16 shadow-2xl border border-gray-100 dark:border-white/5 relative overflow-hidden">
                
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="mb-10 p-6 rounded-3xl bg-green-500/10 border border-green-500/20 flex items-center gap-5 animate-bounce-slow">
                        <div class="size-12 bg-green-500 rounded-full flex items-center justify-center text-white shadow-lg shadow-green-500/40">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round">
                                <polyline points="20 6 9 17 4 12"></polyline>
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-black text-green-700 dark:text-green-400">Message Delivered</h4>
                            <p class="text-sm text-green-600/80 dark:text-green-300/80">@TempData["SuccessMessage"]</p>
                        </div>
                    </div>
                }

                <div class="mb-12">
                    <h2 class="text-4xl md:text-5xl font-black text-text-main dark:text-white tracking-tighter mb-4">Send a <span class="text-primary">Note.</span></h2>
                    <p class="text-text-muted text-lg font-light">Whether it's a reservation query or just to say hi, we'd love to hear from you.</p>
                </div>

                <form asp-action="Submit" method="post" class="space-y-8">
                    @Html.AntiForgeryToken()
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Full Name</label>
                            <input asp-for="FullName" required 
                                   class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400" 
                                   placeholder="Your Name" />
                            <span asp-validation-for="FullName" class="text-red-500 text-[10px] font-black uppercase tracking-widest ml-1"></span>
                        </div>

                        <div class="space-y-2">
                            <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Email Address</label>
                            <input asp-for="Email" type="email" required 
                                   class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400" 
                                   placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-red-500 text-[10px] font-black uppercase tracking-widest ml-1"></span>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Phone Number</label>
                        <input asp-for="PhoneNumber" type="tel" 
                               class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400" 
                               placeholder="+1 (555) 000-0000" />
                        <span asp-validation-for="PhoneNumber" class="text-red-500 text-[10px] font-black uppercase tracking-widest ml-1"></span>
                    </div>

                    <div class="space-y-2">
                        <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Your Message</label>
                        <textarea asp-for="Message" rows="5" required 
                                  class="w-full px-6 py-4 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-2xl focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-text-main dark:text-white placeholder-gray-400 resize-none" 
                                  placeholder="Write your message here..."></textarea>
                        <span asp-validation-for="Message" class="text-red-500 text-[10px] font-black uppercase tracking-widest ml-1"></span>
                    </div>

                    <button type="submit" class="w-full py-6 bg-black dark:bg-white text-white dark:text-black font-black text-xl rounded-2xl hover:bg-primary dark:hover:bg-primary dark:hover:text-black transition-all shadow-xl hover:shadow-primary/40 flex items-center justify-center gap-4 group/btn overflow-hidden relative">
                        <div class="absolute inset-0 bg-primary/20 translate-y-full group-hover/btn:translate-y-0 transition-transform duration-500"></div>
                        <span class="relative z-10">Send Message</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="relative z-10 group-hover/btn:translate-x-2 transition-transform">
                            <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                        </svg>
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>

<!-- FAQ Section -->
<section class="py-24 bg-gray-50 dark:bg-[#080808] reveal">
    <div class="container mx-auto px-6">
        <div class="text-center mb-16">
            <span class="text-primary font-black tracking-[0.3em] uppercase text-xs mb-2 block">Support Center</span>
            <h2 class="text-4xl md:text-6xl font-black text-text-main dark:text-white tracking-tighter">Frequently Asked <span class="text-primary italic">Questions</span></h2>
        </div>

        <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- FAQ 1 -->
            <div class="p-8 bg-white dark:bg-card-dark rounded-3xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all group">
                <h3 class="text-xl font-black text-text-main dark:text-white mb-4 group-hover:text-primary transition-colors">Do I need a reservation?</h3>
                <p class="text-text-muted leading-relaxed">While walk-ins are welcome, we recommend booking a table to ensure availability, especially during peak hours.</p>
            </div>
            <!-- FAQ 2 -->
            <div class="p-8 bg-white dark:bg-card-dark rounded-3xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all group">
                <h3 class="text-xl font-black text-text-main dark:text-white mb-4 group-hover:text-primary transition-colors">Dietary restrictions?</h3>
                <p class="text-text-muted leading-relaxed">Our menu clearly marks vegetarian, vegan, and gluten-free options. Let your server know about any severe allergies.</p>
            </div>
            <!-- FAQ 3 -->
            <div class="p-8 bg-white dark:bg-card-dark rounded-3xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all group">
                <h3 class="text-xl font-black text-text-main dark:text-white mb-4 group-hover:text-primary transition-colors">Host private events?</h3>
                <p class="text-text-muted leading-relaxed">Yes! We have dedicated spaces for parties, corporate events, and weddings. Contact us for custom packages.</p>
            </div>
            <!-- FAQ 4 -->
            <div class="p-8 bg-white dark:bg-card-dark rounded-3xl border border-gray-100 dark:border-white/5 hover:border-primary/30 transition-all group">
                <h3 class="text-xl font-black text-text-main dark:text-white mb-4 group-hover:text-primary transition-colors">Delivery options?</h3>
                <p class="text-text-muted leading-relaxed">We offer direct delivery through our website and are also available on major food delivery platforms.</p>
            </div>
        </div>
    </div>
</section>

<style>
    .animate-slow-zoom { animation: slowZoom 20s infinite alternate ease-in-out; }
    @@keyframes slowZoom { from { transform: scale(1); } to { transform: scale(1.1); } }
    
    .animate-fade-in-up { animation: fadeInUp 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    .animate-fade-in-down { animation: fadeInDown 1.2s cubic-bezier(0.2, 1, 0.3, 1) forwards; }
    
    @@keyframes fadeInUp { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }
    @@keyframes fadeInDown { from { opacity: 0; transform: translateY(-40px); } to { opacity: 1; transform: translateY(0); } }
    
    .animation-delay-300 { animation-delay: 300ms; }
    .animation-delay-500 { animation-delay: 500ms; }

    .animate-bounce-slow { animation: bounceSlow 3s infinite ease-in-out; }
    @@keyframes bounceSlow { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
</style>

@section Scripts {
    <script>
        const revealObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.15 });

        document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));

        function copyToClipboard(text, msg) {
            navigator.clipboard.writeText(text);
            alert(msg);
        }
    </script>
}
