    <!-- Scripts -->
    <script>
        // --- NAVIGATION ---
        function switchTab(tabId) {
            // Update Active Nav
            document.querySelectorAll('.nav-item').forEach(el => {
                el.classList.remove('active-nav');
                el.classList.add('text-gray-400');
            });
            const activeBtn = document.getElementById('nav-' + tabId);
            activeBtn.classList.add('active-nav');
            activeBtn.classList.remove('text-gray-400');

            // Show View
            document.querySelectorAll('[id^="view-"]').forEach(el => el.classList.add('hidden'));
            document.getElementById('view-' + tabId).classList.remove('hidden');
            
            // Update Title
            const titles = {
                'dashboard': 'Dashboard Overview',
                'menu': 'Menu Management',
                'orders': 'Order Management',
                'reservations': 'Reservation Management',
                'users': 'User Directory',
                'admins': 'Administrator Management',
                'history': 'Daily Reports & History',
                'subscribers': 'Newsletter Subscribers',
                'deals': 'Chef Specials Management',
                'messages': 'Messages',
                'database-logs': 'Database Audit Logs'
            };
            document.getElementById('page-title').innerText = titles[tabId];

            // Load Data
            if (tabId === 'menu') loadMenuItems();
            if (tabId === 'orders') loadOrders();
            if (tabId === 'reservations') loadReservations();
            if (tabId === 'users') loadUsers();
            if (tabId === 'admins') loadAdmins();
            if (tabId === 'history') loadHistory();
            if (tabId === 'subscribers') loadSubscribers();
            if (tabId === 'deals') loadDeals();
            if (tabId === 'messages') loadMessages();
            if (tabId === 'database-logs') loadDatabaseLogs();

            // Mobile: Close Sidebar on selection
            if(window.innerWidth < 768) {
                const sidebar = document.getElementById('sidebar');
                if(!sidebar.classList.contains('-translate-x-full')) {
                    toggleSidebar();
                }
            }
        }

        function toggleSidebar() {
            const sidebar = document.getElementById('sidebar');
            const overlay = document.getElementById('mobile-overlay');
            
            if (sidebar.classList.contains('-translate-x-full')) {
                // Open
                sidebar.classList.remove('-translate-x-full');
                overlay.classList.remove('hidden');
                setTimeout(() => overlay.classList.remove('opacity-0'), 10);
            } else {
                // Close
                sidebar.classList.add('-translate-x-full');
                overlay.classList.add('opacity-0');
                setTimeout(() => overlay.classList.add('hidden'), 300);
            }
        }


        // --- MENU MANAGEMENT ---
        function loadMenuItems() {
            const category = document.getElementById('menu-filter').value;
            const search = document.getElementById('menu-search') ? document.getElementById('menu-search').value : '';
            fetch(`/Admin/GetMenuItems?category=${encodeURIComponent(category)}&search=${encodeURIComponent(search)}`)
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('menu-table-body');
                    tbody.innerHTML = '';
                    data.forEach(item => {
                        const row = `
                            <tr>
                                <td class="p-4 flex items-center gap-3">
                                    <img src="${item.imageUrl}" class="w-10 h-10 rounded-lg object-cover bg-white/5">
                                    <span class="font-bold">${item.name}</span>
                                </td>
                                <td class="p-4 text-gray-400">${item.category}</td>
                                <td class="p-4 font-bold text-primary">$${item.price.toFixed(2)}</td>
                                <td class="p-4 text-center">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                      <input type="checkbox" class="sr-only peer" ${item.isAvailable ? 'checked' : ''} onchange="toggleItemAvailability(${item.id}, this.checked)">
                                      <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-gray-400 after:border-gray-500 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500 peer-checked:after:bg-white"></div>
                                    </label>
                                </td>
                                <td class="p-4 text-right">
                                    <button onclick="editItem(${item.id})" class="p-2 hover:text-primary transition-colors"><span class="material-symbols-outlined">edit</span></button>
                                    <button onclick="deleteItem(${item.id})" class="p-2 hover:text-red-500 transition-colors"><span class="material-symbols-outlined">delete</span></button>
                                </td>
                            </tr>
                        `;
                        tbody.innerHTML += row;
                    });
                });
        }

        function openMenuModal() {
            document.getElementById('itemId').value = ''; 
            document.getElementById('menuForm').reset();
            document.getElementById('modalTitle').innerText = 'Add New Item';
            document.getElementById('menuModal').classList.remove('hidden');
            document.getElementById('menuModal').classList.add('flex');
        }

        function closeMenuModal() {
             document.getElementById('menuModal').classList.add('hidden');
             document.getElementById('menuModal').classList.remove('flex');
        }

        function editItem(id) {
            fetch('/Admin/GetMenuItem?id=' + id)
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    const item = data.item;
                    document.getElementById('itemId').value = item.id;
                    document.getElementById('itemName').value = item.name;
                    document.getElementById('itemPrice').value = item.price;
                    document.getElementById('itemCategory').value = item.category;
                    document.getElementById('itemImage').value = item.imageUrl;
                    document.getElementById('itemDescription').value = item.description;
                    
                    document.getElementById('modalTitle').innerText = 'Edit Item';
                    document.getElementById('menuModal').classList.remove('hidden');
                    document.getElementById('menuModal').classList.add('flex');
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }
        
        function toggleItemAvailability(id, isAvailable) {
            fetch('/Admin/ToggleMenuItemAvailability?id=' + id + '&isAvailable=' + isAvailable, {
                method: 'POST'
            })
            .then(r => r.json())
            .then(data => {
                if (!data.success) {
                    alert('Error updating availability: ' + data.message);
                    loadMenuItems(); // reload to reset state
                }
            })
            .catch(err => {
                alert('Network error');
                loadMenuItems();
            });
        }
        
        // Redefined loadMenuItems to enable Edit
        // ... (See simplified logic below)
        
        // --- ORDERS ---
        function loadOrders() {
            const search = document.getElementById('order-search') ? document.getElementById('order-search').value : '';
            fetch(`/Admin/GetOrdersData?search=${encodeURIComponent(search)}&_t=${new Date().getTime()}`)
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('orders-table-body');
                    tbody.innerHTML = '';
                    data.forEach(order => {
                        tbody.innerHTML += `
                            <tr>
                                <td class="p-4 font-mono text-gray-400">#${order.id}</td>
                                <td class="p-4">
                                    <div class="font-bold">${order.customerName}</div>
                                    <div class="text-[10px] text-gray-400 mt-1 max-w-[200px] truncate" title="${order.deliveryAddress || ''}">
                                        ${order.deliveryAddress ? '<span class="material-symbols-outlined text-[10px] align-middle mr-1">location_on</span>' + order.deliveryAddress : 'Pickup / Dine-in'}
                                    </div>
                                </td>
                                <td class="p-4 text-xs text-gray-500">${order.date}</td>
                                <td class="p-4">
                                    <div class="font-bold text-primary">$${order.total.toFixed(2)}</div>
                                    ${order.discount > 0 ? `<div class="text-[9px] text-green-400 font-medium">Saved $${order.discount.toFixed(2)}</div>` : ''}
                                </td>
                                <td class="p-4 text-center">
                                    ${order.promoCode ? `<span class="bg-primary/10 text-primary text-[10px] px-2 py-0.5 rounded-full border border-primary/20 font-black uppercase tracking-widest">${order.promoCode}</span>` : '<span class="text-gray-600 text-xs">-</span>'}
                                </td>
                                <td class="p-4"><span class="px-2 py-1 rounded text-xs font-bold ${getStatusColor(order.status)}">${order.status}</span></td>
                                <td class="p-4 text-right">
                                    <button onclick="updateStatus(${order.id}, 'Completed')" class="text-xs font-bold text-green-500 hover:underline mr-2">Complete</button>
                                    <button onclick="updateStatus(${order.id}, 'Delivered')" class="text-xs font-bold text-blue-500 hover:underline">Deliver</button>
                                </td>
                            </tr>
                        `;
                    });
                });
        }

        function updateStatus(id, status) {
            fetch('/Admin/UpdateOrderStatus?id=' + id + '&status=' + status, { method: 'POST' })
            .then(r => r.json())
            .then(d => { 
                if(d.success) loadOrders(); 
                else alert('Error updating status: ' + d.message);
            })
            .catch(e => alert('Network error: ' + e));
        }

        function getStatusColor(status) {
            if(status === 'Pending') return 'bg-orange-500/10 text-orange-500';
            if(status === 'Completed') return 'bg-green-500/10 text-green-500';
            return 'bg-blue-500/10 text-blue-500';
        }

        // --- RESERVATIONS ---
        function loadReservations() {
            const search = document.getElementById('res-search') ? document.getElementById('res-search').value : '';
            fetch(`/Admin/GetReservationsData?search=${encodeURIComponent(search)}&_t=${new Date().getTime()}`)
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('reservations-table-body');
                    tbody.innerHTML = '';
                    data.forEach(res => {
                        let statusColor = 'text-red-500';
                        if (res.status === 'Confirmed') statusColor = 'text-green-500';
                        else if (res.status === 'Completed') statusColor = 'text-blue-500';

                        tbody.innerHTML += `
                            <tr>
                                <td class="p-4 font-bold">${res.customerName}</td>
                                <td class="p-4 text-sm text-gray-400">${res.date} at ${res.time}</td>
                                <td class="p-4">${res.partySize} ppl</td>
                                <td class="p-4"><span class="text-xs border border-white/20 px-2 py-0.5 rounded">${res.reservationType}</span></td>
                                <td class="p-4"><span class="text-xs font-bold ${statusColor}">${res.status}</span></td>
                                <td class="p-4 text-right">
                                     ${res.status === 'Confirmed' ? `
                                        <button onclick="updateResStatus(${res.id}, 'Completed')" class="text-xs font-bold text-green-500 hover:underline mr-2">Complete</button>
                                        <button onclick="updateResStatus(${res.id}, 'Cancelled')" class="text-xs text-red-500 hover:underline">Cancel</button>
                                     ` : ''}
                                     ${res.status === 'Completed' ? '<span class="text-xs text-green-500 font-bold flex items-center justify-end gap-1"><span class="material-symbols-outlined text-sm">check</span> Done</span>' : ''}
                                </td>
                            </tr>
                        `;
                    });
                });
        }
        
        function updateResStatus(id, status) {
             fetch('/Admin/UpdateReservationStatus?id=' + id + '&status=' + status, { method: 'POST' })
            .then(r => r.json())
            .then(d => { 
                if(d.success) loadReservations(); 
                else alert('Error updating reservation: ' + d.message);
            })
            .catch(e => alert('Network error: ' + e));
        }

        function clearOrders() {
            if(!confirm('START NEW DAY?\n\nThis will DELETE ALL orders to prepare for a fresh day. This action cannot be undone.')) return;
            fetch('/Admin/ClearAllOrders', { method: 'POST' })
            .then(r => r.json())
            .then(d => {
                if(d.success) {
                    loadOrders();
                    alert('Orders cleared successfully. Ready for a new day!');
                } else {
                    alert('Error: ' + d.message);
                }
            });
        }

        function clearReservations() {
            if(!confirm('START NEW DAY?\n\nThis will DELETE ALL reservations. Are you sure you want to clear the list?')) return;
            fetch('/Admin/ClearAllReservations', { method: 'POST' })
            .then(r => r.json())
            .then(d => {
                if(d.success) {
                    loadReservations();
                    alert('Reservations cleared successfully.');
                } else {
                    alert('Error: ' + d.message);
                }
            });
        }

        // --- USERS ---
        function loadUsers() {
             fetch('/Admin/GetUsersData')
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('users-table-body');
                    tbody.innerHTML = '';
                    data.forEach(user => {
                        tbody.innerHTML += `
                            <tr>
                                <td class="p-4 font-bold flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-xs">
                                        ${user.fullName ? user.fullName.charAt(0) : '?'}
                                    </div>
                                    ${user.fullName || 'User'}
                                </td>
                                <td class="p-4 text-gray-400">${user.email}</td>
                                <td class="p-4 font-mono text-primary">${user.password || `<button onclick="resetPassword(${user.id})" class="text-[10px] bg-primary/10 hover:bg-primary hover:text-black px-2 py-0.5 rounded transition-colors">Reset to 123456</button>`}</td>
                                <td class="p-4 text-xs">${user.joined}</td>
                                <td class="p-4 text-xs font-mono text-green-400">${user.lastLogin}</td>
                            </tr>
                        `;
                    });
                });
        }

        function resetPassword(id) {
            if(!confirm('This will reset the user password to 123456. Continue?')) return;
            fetch('/Admin/ResetUserPassword/' + id, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    alert('Password reset to 123456');
                    location.reload(); // Refresh to show new PW
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }

    </script>

    <!-- Admin Modal -->
    <div id="adminModal" class="fixed inset-0 z-50 bg-black/80 backdrop-blur-sm hidden items-center justify-center p-4">
        <div class="bg-[#121212] w-full max-w-lg rounded-2xl border border-white/10 shadow-2xl p-6 relative">
            <h3 class="text-2xl font-bold mb-6">Add New Administrator</h3>
            <form id="adminForm" onsubmit="saveAdmin(event)" class="space-y-4">
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Full Name</label>
                    <input type="text" id="adminName" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white focus:border-primary outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Username</label>
                    <input type="text" id="adminUsername" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white focus:border-primary outline-none">
                </div>
                <div>
                    <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Email</label>
                    <input type="email" id="adminEmail" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white focus:border-primary outline-none">
                </div>
                <div>
                     <label class="block text-xs font-bold text-gray-400 uppercase mb-1">Password</label>
                     <input type="text" id="adminPassword" required class="w-full bg-white/5 border border-white/10 rounded-lg px-4 py-2 text-white focus:border-primary outline-none" placeholder="Enter password...">
                </div>
                
                <div class="flex gap-4 pt-4">
                    <button type="button" onclick="closeAdminModal()" class="flex-1 py-3 bg-white/5 hover:bg-white/10 rounded-xl font-bold transition-colors">Cancel</button>
                    <button type="submit" class="flex-1 py-3 bg-primary text-black hover:bg-white rounded-xl font-bold transition-colors">Create Admin</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scripts -->
    <script>
        // ... (Existing Scripts) ...

        // --- ADMINS ---
        function loadAdmins() {
             fetch('/Admin/GetAdminsData')
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('admins-table-body');
                    tbody.innerHTML = '';
                    data.forEach(user => {
                        tbody.innerHTML += `
                            <tr>
                                <td class="p-4 font-bold flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-red-500/10 text-red-500 flex items-center justify-center text-xs font-bold">
                                        ${user.fullName ? user.fullName.charAt(0) : 'A'}
                                    </div>
                                    ${user.fullName || 'Admin'}
                                </td>
                                <td class="p-4 text-gray-400">${user.email}</td>
                                <td class="p-4 font-mono text-primary">${user.password || '<span class="text-xs text-gray-500">Encrypted</span>'}</td>
                                <td class="p-4"><span class="px-2 py-0.5 rounded text-xs font-bold bg-red-500/10 text-red-500">${user.role}</span></td>
                                <td class="p-4 text-xs">${user.joined}</td>
                                <td class="p-4 text-xs font-mono text-green-400">${user.lastLogin}</td>
                                <td class="p-4 text-center">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                      <input type="checkbox" class="sr-only peer" ${user.isActive ? 'checked' : ''} onchange="toggleAdminStatus(${user.id}, this.checked)">
                                      <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-gray-400 after:border-gray-500 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500 peer-checked:after:bg-white"></div>
                                    </label>
                                </td>
                            </tr>
                        `;
                    });
                });
        }

        function toggleAdminStatus(id, isActive) {
            fetch(`/Admin/ToggleAdminStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if(!data.success) {
                        alert('Error: ' + data.message);
                        loadAdmins();
                    }
                });
        }

        function openAdminModal() {
            document.getElementById('adminForm').reset();
            document.getElementById('adminModal').classList.remove('hidden');
            document.getElementById('adminModal').classList.add('flex');
        }

        function closeAdminModal() {
             document.getElementById('adminModal').classList.add('hidden');
             document.getElementById('adminModal').classList.remove('flex');
        }

        function saveAdmin(e) {
            e.preventDefault();
            
            const admin = {
                FullName: document.getElementById('adminName').value,
                Username: document.getElementById('adminUsername').value,
                Email: document.getElementById('adminEmail').value,
                PlainPassword: document.getElementById('adminPassword').value
            };

            fetch('/Admin/AddAdmin', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(admin)
            })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    closeAdminModal();
                    loadAdmins();
                    alert('New admin added successfully!');
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }



        // --- HISTORY ---
        function loadHistory() {
             fetch('/Admin/GetHistoryData')
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('history-table-body');
                    tbody.innerHTML = '';
                    data.forEach(day => {
                        tbody.innerHTML += `
                            <tr>
                                <td class="p-4 text-gray-400 font-mono">${day.date}</td>
                                <td class="p-4 font-bold">${day.totalOrders}</td>
                                <td class="p-4">${day.totalReservations}</td>
                                <td class="p-4 font-bold text-green-500">$${day.totalRevenue.toFixed(2)}</td>
                            </tr>
                        `;
                    });
                });
        }

        function clearHistory() {
            if(!confirm('WARNING: This will delete ALL historical report data. This cannot be undone. Continue?')) return;
            fetch('/Admin/ClearAllHistory', { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    loadHistory();
                    alert('History cleared successfully.');
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }

        function loadMessages() {
             fetch('/Admin/GetMessages') // Uses existing endpoint if exists, checking controller... Use GetMessages
                .then(r => r.json())
                .then(data => {
                    const container = document.getElementById('messages-container');
                    container.innerHTML = '';
                    data.forEach(msg => {
                        container.innerHTML += `
                            <div class="bg-[#0F0F0F] border ${msg.isRead ? 'border-white/5' : 'border-primary/50'} p-4 rounded-xl flex justify-between items-start">
                                <div>
                                    <div class="flex items-center gap-2 mb-1">
                                        <h4 class="font-bold">${msg.fullName}</h4>
                                        ${!msg.isRead ? '<span class="text-[10px] bg-primary text-black px-1.5 rounded font-bold">NEW</span>' : ''}
                                    </div>
                                    <p class="text-xs text-primary mb-2">${msg.email}</p>
                                    <p class="text-gray-300 text-sm">${msg.message}</p>
                                </div>
                                ${!msg.isRead ? `<button onclick="markRead(${msg.id})" class="text-xs bg-white/10 hover:bg-white/20 px-3 py-1 rounded">Mark Read</button>` : ''}
                            </div>
                        `;
                    });
                });
        }

        function markRead(id) {
             fetch('/Admin/MarkMessageRead?id=' + id, { method: 'POST' })
            .then(r => r.json())
            .then(d => { if(d.success) loadMessages(); });
        }

        function clearMessages() {
            if(!confirm('Are you sure you want to DELETE ALL messages? This cannot be undone.')) return;
            fetch('/Admin/ClearAllMessages', { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    loadMessages();
                    alert('All messages cleared successfully.');
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }

        // --- SUBSCRIBERS ---
        function loadSubscribers() {
             fetch('/Admin/GetSubscribers')
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('subscribers-table-body');
                    tbody.innerHTML = '';
                    data.forEach(sub => {
                        tbody.innerHTML += `
                            <tr class="hover:bg-white/[0.02] transition-colors group">
                                <td class="p-4 font-medium text-gray-300">${sub.email}</td>
                                <td class="p-4 text-xs text-gray-500">${sub.date}</td>
                                <td class="p-4 text-right">
                                    <button onclick="deleteSubscriber(${sub.id})" class="p-2 text-gray-500 hover:text-red-500 transition-colors opacity-0 group-hover:opacity-100">
                                        <span class="material-symbols-outlined text-sm">delete</span>
                                    </button>
                                </td>
                            </tr>
                        `;
                    });
                });
        }

        function deleteSubscriber(id) {
            if(!confirm('Remove this subscriber?')) return;
            fetch('/Admin/DeleteSubscriber/' + id, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) loadSubscribers();
                else alert('Error: ' + data.message);
            });
        }


        function saveMenuItem(e) {
            e.preventDefault();
            
            const id = document.getElementById('itemId').value;
            const item = {
                id: id ? parseInt(id) : 0,
                name: document.getElementById('itemName').value,
                price: parseFloat(document.getElementById('itemPrice').value),
                category: document.getElementById('itemCategory').value,
                imageUrl: document.getElementById('itemImage').value,
                description: document.getElementById('itemDescription').value,
                isAvailable: true
            };

            const url = id ? '/Admin/UpdateMenuItem' : '/Admin/AddMenuItem';
            
            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(item)
            })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    closeMenuModal();
                    loadMenuItems();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }



        // --- DEALS (CHEF SPECIALS) ---
        function loadDeals() {
            const search = document.getElementById('deal-search') ? document.getElementById('deal-search').value : '';
            fetch(`/Admin/GetDealsData?search=${encodeURIComponent(search)}&_t=${new Date().getTime()}`)
                .then(r => r.json())
                .then(data => {
                    const tbody = document.getElementById('deals-table-body');
                    tbody.innerHTML = '';
                    data.forEach(deal => {
                        tbody.innerHTML += `
                            <tr>
                                <td class="p-4 flex items-center gap-3">
                                    <img src="${deal.imageUrl}" class="w-12 h-12 rounded-xl object-cover bg-white/5">
                                    <div>
                                        <div class="font-bold">${deal.title}</div>
                                        <div class="text-[10px] text-gray-500 max-w-[250px] truncate">${deal.description}</div>
                                    </div>
                                </td>
                                <td class="p-4"><span class="px-2 py-0.5 rounded text-[10px] font-bold bg-primary/10 text-primary border border-primary/20">${deal.tag || 'N/A'}</span></td>
                                <td class="p-4 font-bold text-white">$${deal.price.toFixed(2)}</td>
                                <td class="p-4 text-gray-500 line-through">$${deal.originalPrice ? deal.originalPrice.toFixed(2) : '0.00'}</td>
                                <td class="p-4 text-center">
                                    <label class="relative inline-flex items-center cursor-pointer">
                                      <input type="checkbox" class="sr-only peer" ${deal.isActive ? 'checked' : ''} onchange="toggleDealStatus(${deal.id}, this.checked)">
                                      <div class="w-11 h-6 bg-white/10 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-gray-400 after:border-gray-500 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-green-500 peer-checked:after:bg-white"></div>
                                    </label>
                                </td>
                                <td class="p-4 text-right">
                                    <button onclick="editDeal(${deal.id})" class="p-2 hover:text-primary transition-colors"><span class="material-symbols-outlined">edit</span></button>
                                    <button onclick="deleteDeal(${deal.id})" class="p-2 hover:text-red-500 transition-colors"><span class="material-symbols-outlined">delete</span></button>
                                </td>
                            </tr>
                        `;
                    });
                });
        }

        function openDealModal() {
            document.getElementById('dealId').value = '';
            document.getElementById('dealForm').reset();
            document.getElementById('dealModalTitle').innerText = 'Add New Special';
            document.getElementById('dealModal').classList.remove('hidden');
            document.getElementById('dealModal').classList.add('flex');
        }

        function closeDealModal() {
            document.getElementById('dealModal').classList.add('hidden');
            document.getElementById('dealModal').classList.remove('flex');
        }

        function saveDeal(e) {
            e.preventDefault();
            const id = document.getElementById('dealId').value;
            const deal = {
                Id: id ? parseInt(id) : 0,
                Title: document.getElementById('dealTitle').value,
                Price: parseFloat(document.getElementById('dealPrice').value),
                OriginalPrice: document.getElementById('dealOriginalPrice').value ? parseFloat(document.getElementById('dealOriginalPrice').value) : null,
                Tag: document.getElementById('dealTag').value,
                ImageUrl: document.getElementById('dealImage').value,
                Description: document.getElementById('dealDescription').value,
                IsActive: true
            };

            const url = id ? '/Admin/UpdateDeal' : '/Admin/AddDeal';
            fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(deal)
            })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    closeDealModal();
                    loadDeals();
                } else alert('Error: ' + data.message);
            });
        }

        function editDeal(id) {
            fetch(`/Admin/GetDealsData?_t=${new Date().getTime()}`) // Fetch all and find locally for simplicity or add single endpoint
                .then(r => r.json())
                .then(data => {
                    const deal = data.find(d => d.id === id);
                    if(deal) {
                        document.getElementById('dealId').value = deal.id;
                        document.getElementById('dealTitle').value = deal.title;
                        document.getElementById('dealPrice').value = deal.price;
                        document.getElementById('dealOriginalPrice').value = deal.originalPrice;
                        document.getElementById('dealTag').value = deal.tag;
                        document.getElementById('dealImage').value = deal.imageUrl;
                        document.getElementById('dealDescription').value = deal.description;

                        document.getElementById('dealModalTitle').innerText = 'Edit Special';
                        document.getElementById('dealModal').classList.remove('hidden');
                        document.getElementById('dealModal').classList.add('flex');
                    }
                });
        }

        function deleteDeal(id) {
            if(!confirm('Delete this special?')) return;
            fetch('/Admin/DeleteDeal?id=' + id, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if(data.success) loadDeals();
                    else alert('Error: ' + data.message);
                });
        }

        function toggleDealStatus(id, isActive) {
            fetch(`/Admin/ToggleDealStatus?id=${id}&isActive=${isActive}`, { method: 'POST' })
                .then(r => r.json())
                .then(data => {
                    if(!data.success) {
                        alert('Error: ' + data.message);
                        loadDeals();
                    }
                });
        }

        function deleteItem(id) {
            if(!confirm('Are you sure you want to delete this item?')) return;
            
            fetch('/Admin/DeleteMenuItem?id=' + id, { method: 'POST' })
            .then(r => r.json())
            .then(data => {
                if(data.success) {
                    loadMenuItems();
                } else {
                    alert('Error: ' + data.message);
                }
            });
        }

        // --- DATABASE LOGS (TRIGGERS) ---
        function loadDatabaseLogs() {
            fetch(`/Admin/GetDatabaseLogsData?_t=${new Date().getTime()}`)
                .then(r => r.json())
                .then(data => {
                    // Reservation Audits
                    const resBody = document.getElementById('reservation-audit-body');
                    resBody.innerHTML = '';
                    if (data && data.reservationAudits) {
                        data.reservationAudits.forEach(log => {
                            resBody.innerHTML += `
                                <tr class="hover:bg-white/5 transition-colors">
                                    <td class="p-4 font-bold text-white">${log.customerName}</td>
                                    <td class="p-4"><span class="text-[10px] text-gray-500 font-black">${log.actionType}</span></td>
                                    <td class="p-4"><span class="text-xs text-red-400 bg-red-400/10 px-2 py-0.5 rounded">${log.oldStatus}</span></td>
                                    <td class="p-4"><span class="text-xs text-green-400 bg-green-400/10 px-2 py-0.5 rounded">${log.newStatus}</span></td>
                                    <td class="p-4 text-xs text-gray-500">${new Date(log.changedAt).toLocaleString()}</td>
                                </tr>
                            `;
                        });
                    }

                    // MenuItem Audits
                    const menuBody = document.getElementById('menu-audit-body');
                    if (menuBody) {
                        menuBody.innerHTML = '';
                        if (data && data.menuItemAudits) {
                            data.menuItemAudits.forEach(log => {
                                menuBody.innerHTML += `
                                    <tr class="hover:bg-white/5 transition-colors">
                                        <td class="p-4 font-bold text-white">${log.menuItemName}</td>
                                        <td class="p-4"><span class="text-[10px] text-blue-400 font-black">${log.actionType}</span></td>
                                        <td class="p-4 text-xs text-gray-500">${new Date(log.changedAt).toLocaleString()}</td>
                                    </tr>
                                `;
                            });
                        }
                    }
                });
        }

        // INITIAL LOAD
        document.addEventListener('DOMContentLoaded', () => {
           // Auto-load dashboard stats or just default to dashboard tab view

           // The dashboard view is static for now (loaded via ViewBag), so no fetch needed immediately.
           // Maybe animate entry?
        });

    </script>
</body>
</html>
