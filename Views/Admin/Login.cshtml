@{
    ViewData["Title"] = "Admin Login - FoodHeaven";
}



<!-- Main Content -->
<main class="mx-auto flex max-w-[1440px] w-full flex-1 items-center justify-center px-6 py-12">
    <div class="w-full max-w-md">
        
        <!-- Error Message -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="bg-red-500/10 border border-red-500/30 text-red-700 dark:text-red-400 px-6 py-4 rounded-xl flex items-center gap-3 mb-6">
                <span class="material-symbols-outlined fill-current">error</span>
                <span class="font-medium">@TempData["ErrorMessage"]</span>
            </div>
        }

        <!-- Login Card -->
        <div class="bg-card-light dark:bg-card-dark rounded-2xl p-10 shadow-soft dark:shadow-none border border-gray-100 dark:border-white/5">
            <!-- Icon -->
            <div class="flex items-center justify-center mb-8">
                <div class="flex items-center justify-center size-24 rounded-full bg-gradient-to-br from-primary to-accent-gold p-[3px]">
                    <div class="flex items-center justify-center size-full rounded-full bg-card-light dark:bg-card-dark">
                        <span class="material-symbols-outlined text-5xl text-primary fill-current">admin_panel_settings</span>
                    </div>
                </div>
            </div>

            <div class="text-center mb-8">
                <h2 class="text-text-main dark:text-white text-3xl font-extrabold mb-2">Admin Portal</h2>
                <p class="text-text-main/60 dark:text-white/50">Sign in to access the dashboard</p>
            </div>
            
            <form asp-action="Login" method="post" class="space-y-6">
                @Html.AntiForgeryToken()
                
                <!-- Username -->
                <div>
                    <label for="username" class="block text-text-main dark:text-white text-sm font-bold mb-2">Username</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-text-main/40 dark:text-white/40">person</span>
                        <input type="text" 
                               id="username" 
                               name="username" 
                               required
                               class="w-full pl-12 pr-4 py-3 rounded-xl bg-background-light dark:bg-background-dark border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-text-main/40 dark:placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-primary transition-all" 
                               placeholder="Enter your username" />
                    </div>
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-text-main dark:text-white text-sm font-bold mb-2">Password</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-text-main/40 dark:text-white/40">lock</span>
                        <input type="password" 
                               id="password" 
                               name="password" 
                               required
                               class="w-full pl-12 pr-4 py-3 rounded-xl bg-background-light dark:bg-background-dark border border-gray-200 dark:border-white/10 text-text-main dark:text-white placeholder-text-main/40 dark:placeholder-white/40 focus:outline-none focus:ring-2 focus:ring-primary transition-all" 
                               placeholder="Enter your password" />
                    </div>
                </div>

                <!-- Remember Me -->
                <div class="flex items-center justify-between">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="rememberMe" class="w-4 h-4 rounded border-gray-300 dark:border-white/20 text-primary focus:ring-2 focus:ring-primary" />
                        <span class="text-text-main dark:text-white text-sm">Remember me</span>
                    </label>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full bg-gradient-to-r from-primary to-[#FFD700] hover:to-[#ffc400] text-text-main font-bold py-4 rounded-xl transition-all hover:scale-[1.02] active:scale-95 shadow-lg shadow-primary/20 flex items-center justify-center gap-2">
                    <span class="material-symbols-outlined">login</span>
                    Sign In
                </button>
            </form>

            <!-- Info -->
            <div class="mt-8 pt-6 border-t border-gray-200 dark:border-white/10">
                <div class="bg-primary/10 border border-primary/30 rounded-xl p-4 flex items-start gap-3">
                    <span class="material-symbols-outlined text-primary text-xl fill-current">info</span>
                    <div class="text-xs text-text-main dark:text-white">
                        <strong class="block mb-1">Default credentials:</strong>
                        <div class="space-y-1">
                            <div>Username: <code class="bg-background-light dark:bg-background-dark px-2 py-0.5 rounded font-mono">admin</code></div>
                            <div>Password: <code class="bg-background-light dark:bg-background-dark px-2 py-0.5 rounded font-mono">Admin@123</code></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Back to Home -->
        <div class="text-center mt-6">
            <a href="/" class="text-primary text-sm font-bold hover:underline flex items-center justify-center gap-1">
                <span class="material-symbols-outlined text-sm">arrow_back</span>
                Back to Home
            </a>
        </div>
    </div>
</main>

<!-- Footer -->

