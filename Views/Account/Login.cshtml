@{
    ViewData["Title"] = "Login - FoodHeaven";
}

<div class="min-h-screen flex items-stretch bg-background-light dark:bg-background-dark relative overflow-hidden">
    
    <!-- Left Section: Visual Experience (Desktop Only) -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden group">
        <!-- Background with Ken Burns Effect -->
        <img src="~/images/restaurant_hero_bg.png" alt="Login Background" class="absolute inset-0 w-full h-full object-cover object-center transition-transform duration-[10s] group-hover:scale-110" />
        <div class="absolute inset-0 bg-gradient-to-br from-primary/80 via-black/40 to-black/90"></div>
        
        <!-- Center Content Cluster -->
        <div class="absolute top-[55%] left-1/2 -translate-x-1/2 -translate-y-1/2 w-full px-12">
            <div class="relative z-10 flex flex-col items-center text-center text-white space-y-6 reveal">
                <div class="flex flex-col items-center">
                    <a href="/" class="flex items-center gap-3 mb-8 group/logo">
                        <span class="material-symbols-outlined text-primary text-5xl fill-current group-hover/logo:rotate-12 transition-transform">restaurant_menu</span>
                        <h1 class="text-4xl font-black tracking-tighter">FoodHeaven</h1>
                    </a>
                    <h2 class="text-7xl font-display font-black leading-tight tracking-tighter mb-6">
                        Taste the <br /><span class="text-primary italic">Extraordinary.</span>
                    </h2>
                    <p class="text-xl text-white/70 max-w-md font-light leading-relaxed">
                        Join our community of food lovers and unlock exclusive culinary experiences, secret recipes, and VIP benefits.
                    </p>
                </div>
                
                <div class="inline-flex gap-8 items-center bg-black/30 backdrop-blur-2xl px-10 py-6 rounded-[2.5rem] border border-white/10 shadow-2xl">
                    <div class="flex -space-x-4">
                        <img class="w-14 h-14 rounded-full border-4 border-black/40 shadow-xl" src="https://ui-avatars.com/api/?name=J+D&background=f2b90d&color=000" />
                        <img class="w-14 h-14 rounded-full border-4 border-black/40 shadow-xl" src="https://ui-avatars.com/api/?name=A+S&background=white&color=000" />
                        <img class="w-14 h-14 rounded-full border-4 border-black/40 shadow-xl" src="https://ui-avatars.com/api/?name=M+K&background=f2b90d&color=000" />
                    </div>
                    <p class="text-base font-black tracking-wide uppercase"><span class="text-primary">10,000+</span> Members Joined</p>
                </div>
            </div>
        </div>

        <!-- Floating Decorative Elements -->
        <div class="absolute top-1/4 right-10 w-20 h-20 bg-white/10 backdrop-blur-3xl rounded-full animate-float"></div>
        <div class="absolute bottom-1/4 left-20 w-32 h-32 bg-primary/20 backdrop-blur-2xl rounded-full animate-float-delayed"></div>
    </div>

    <!-- Right Section: Login Form -->
    <div class="w-full lg:w-1/2 flex items-start justify-center p-8 md:p-20 relative overflow-hidden bg-background-light dark:bg-background-dark">
        <!-- Spacer to force content below header -->
        <div class="absolute top-0 left-0 w-full h-40 pointer-events-none"></div>

        <!-- Mobile Logo -->
        <div class="absolute top-8 left-8 lg:hidden">
             <a href="/" class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary text-3xl fill-current">restaurant_menu</span>
                <span class="text-2xl font-black tracking-tight text-text-main dark:text-white">FoodHeaven</span>
            </a>
        </div>

        <div class="max-w-md w-full relative z-10 mt-32 lg:mt-48">
            <!-- Header -->
            <div class="mb-12 reveal">
                <h2 class="text-5xl font-display font-black text-black dark:text-white mb-4 tracking-tighter">Welcome Back</h2>
                <p class="text-gray-500 text-xl font-light">Continue your culinary journey with us.</p>
            </div>

            <!-- Login Card with 3D Tilt -->
            <div id="login-card" class="bg-white dark:bg-card-dark rounded-[3rem] shadow-2xl p-10 md:p-12 border border-gray-100 dark:border-white/5 relative overflow-hidden transition-all duration-300 reveal" style="transition-delay: 200ms;">
                
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="mb-8 p-5 rounded-3xl bg-red-50 dark:bg-red-900/10 border border-red-100 dark:border-red-900/20 flex items-center gap-4 animate-shake">
                        <span class="material-symbols-outlined text-red-500 text-3xl">error</span>
                        <p class="text-sm font-black text-red-600 dark:text-red-400 leading-tight">@TempData["ErrorMessage"]</p>
                    </div>
                }

                <form action="/Account/Login" method="post" class="space-y-8">
                    @Html.AntiForgeryToken()
                    
                    <div class="space-y-2 reveal" style="transition-delay: 300ms;">
                        <label class="text-xs font-black text-primary uppercase tracking-[0.2em] ml-1">Identity</label>
                        <div class="relative group">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors material-symbols-outlined text-2xl">person</span>
                            <input type="text" name="username" required 
                                   class="w-full pl-16 pr-6 py-5 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-[1.5rem] focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-black dark:text-white placeholder-gray-400 text-lg shadow-sm" 
                                   placeholder="Email or Username" />
                        </div>
                    </div>

                    <div class="space-y-2 reveal" style="transition-delay: 400ms;">
                        <div class="flex items-center justify-between px-1">
                            <label class="text-xs font-black text-primary uppercase tracking-[0.2em]">Password</label>
                            <a href="#" class="text-xs font-black text-text-muted hover:text-primary transition-colors uppercase tracking-widest">Forgot?</a>
                        </div>
                        <div class="relative group">
                            <span class="absolute left-6 top-1/2 -translate-y-1/2 text-gray-400 group-focus-within:text-primary transition-colors material-symbols-outlined text-2xl">lock</span>
                            <input type="password" name="password" required 
                                   class="w-full pl-16 pr-6 py-5 bg-gray-50 dark:bg-white/5 border-2 border-transparent rounded-[1.5rem] focus:border-primary/30 focus:bg-white dark:focus:bg-white/10 outline-none transition-all font-bold text-black dark:text-white placeholder-gray-400 text-lg shadow-sm" 
                                   placeholder="Your secret code" />
                        </div>
                    </div>

                    <div class="flex items-center gap-3 reveal" style="transition-delay: 500ms;">
                        <label class="relative flex items-center cursor-pointer group">
                            <input type="checkbox" name="rememberMe" class="peer sr-only" />
                            <div class="w-12 h-7 bg-gray-200 dark:bg-white/10 rounded-full peer-checked:bg-primary transition-colors duration-300"></div>
                            <div class="absolute left-1 top-1 w-5 h-5 bg-white rounded-full transition-transform duration-300 peer-checked:translate-x-5 shadow-sm"></div>
                            <span class="ml-3 text-sm font-bold text-gray-500 group-hover:text-black dark:group-hover:text-white transition-colors">Keep me signed in</span>
                        </label>
                    </div>

                    <div class="reveal" style="transition-delay: 600ms;">
                        <button type="submit" class="w-full py-5 bg-primary text-black font-black text-xl rounded-[1.5rem] hover:scale-105 active:scale-95 transition-all shadow-glow hover:shadow-primary/40 flex items-center justify-center gap-3 group/btn">
                            <span>Continue Journey</span>
                            <span class="material-symbols-outlined group-hover/btn:translate-x-2 transition-transform">arrow_forward</span>
                        </button>
                    </div>
                </form>

                <div class="mt-10 pt-8 border-t border-gray-100 dark:border-white/5 text-center reveal" style="transition-delay: 700ms;">
                    <p class="text-gray-500 font-medium">
                        New to FoodHeaven? 
                        <a href="/Account/Register" class="text-primary font-black hover:underline ml-1">Create Account</a>
                    </p>
                </div>
            </div>

            <!-- Footer Hint -->
            <p class="mt-8 text-center text-xs text-gray-500 font-medium reveal" style="transition-delay: 800ms;">
                Protected by secure encryption. © 2026 FoodHeaven
            </p>
        </div>
    </div>
</div>

<style>
    .animate-float { animation: float 6s infinite ease-in-out; }
    .animate-float-delayed { animation: float 6s infinite ease-in-out 3s; }
    @@keyframes float { 
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-20px) rotate(5deg); }
    }
    
    .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    @@keyframes shake {
        10%, 90% { transform: translate3d(-1px, 0, 0); }
        20%, 80% { transform: translate3d(2px, 0, 0); }
        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
        40%, 60% { transform: translate3d(4px, 0, 0); }
    }

    .shadow-glow { box-shadow: 0 10px 40px -10px rgba(242, 185, 13, 0.4); }
</style>

@section Scripts {
    <script>
        // Reveal Animations
        document.addEventListener('DOMContentLoaded', () => {
            const reveals = document.querySelectorAll('.reveal');
            setTimeout(() => {
                reveals.forEach(el => {
                    el.classList.add('active');
                });
            }, 100);
        });

        // 3D Tilt Effect
        const card = document.getElementById('login-card');
        if (card && window.innerWidth > 1024) {
            document.addEventListener('mousemove', (e) => {
                const rect = card.getBoundingClientRect();
                const x = e.clientX - rect.left;
                const y = e.clientY - rect.top;
                
                if (x > 0 && x < rect.width && y > 0 && y < rect.height) {
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    const rotateX = (y - centerY) / 20;
                    const rotateY = (centerX - x) / 20;
                    
                    card.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
                } else {
                    card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
                }
            });
            
            document.addEventListener('mouseleave', () => {
                card.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1)';
            });
        }
    </script>
}

