@{
    ViewData["Title"] = "Login";
}

<div class="min-h-[80vh] flex items-center justify-center bg-gray-50 dark:bg-[#0a0a0a] py-12 px-4 sm:px-6 lg:px-8 relative overflow-hidden">
    
    <!-- Background Elements -->
    <div class="absolute top-0 left-0 w-full h-full overflow-hidden pointer-events-none">
        <div class="absolute top-[-10%] left-[-10%] w-[40%] h-[40%] bg-primary/5 rounded-full blur-[100px]"></div>
        <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-blue-500/5 rounded-full blur-[100px]"></div>
        <div class="absolute inset-0 bg-[url('/images/pattern_dot.png')] opacity-[0.03] animate-pulse"></div>
    </div>

    <div class="max-w-md w-full space-y-8 relative z-10">
        
        <!-- Header -->
        <div class="text-center">
            <h2 class="text-4xl font-display font-black text-text-main dark:text-white mb-2 tracking-tight">Welcome Back</h2>
            <p class="text-text-muted dark:text-gray-400">Sign in to continue your journey</p>
        </div>

        <!-- Main Card -->
        <div class="bg-white dark:bg-card-dark rounded-[2.5rem] shadow-2xl p-8 md:p-10 border border-white/20 ring-1 ring-black/5 relative overflow-hidden group">
            
            <!-- Error Message -->
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="mb-6 p-4 rounded-2xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-900/50 flex items-center gap-3 animate-shake">
                    <span class="material-symbols-outlined text-red-500">error</span>
                    <p class="text-sm font-bold text-red-600 dark:text-red-400">@TempData["ErrorMessage"]</p>
                </div>
            }
             @if (TempData["SuccessMessage"] != null)
            {
                <div class="mb-6 p-4 rounded-2xl bg-green-50 dark:bg-green-900/20 border border-green-100 dark:border-green-900/50 flex items-center gap-3 animate-fade-in-up">
                    <span class="material-symbols-outlined text-green-500">check_circle</span>
                    <p class="text-sm font-bold text-green-600 dark:text-green-400">@TempData["SuccessMessage"]</p>
                </div>
            }

            <!-- Customer Form -->
            <form id="form-customer" action="/Account/Login" method="post" class="space-y-6 transition-all duration-500">
                @Html.AntiForgeryToken()
                
                <div>
                    <label class="block text-xs font-bold text-text-muted uppercase tracking-wider mb-2 ml-1">Email or Username</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 material-symbols-outlined text-xl">person</span>
                        <input type="text" name="username" required 
                               class="w-full pl-12 pr-4 py-4 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-medium text-text-main dark:text-white placeholder-gray-400" 
                               placeholder="Email or Username" />
                    </div>
                </div>

                <div>
                    <label class="block text-xs font-bold text-text-muted uppercase tracking-wider mb-2 ml-1">Password</label>
                    <div class="relative">
                        <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 material-symbols-outlined text-xl">lock</span>
                        <input type="password" name="password" required 
                               class="w-full pl-12 pr-4 py-4 bg-gray-50 dark:bg-white/5 border border-gray-200 dark:border-white/10 rounded-2xl focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all font-medium text-text-main dark:text-white placeholder-gray-400" 
                               placeholder="Min. 8 characters" />
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <label class="flex items-center gap-2 cursor-pointer">
                        <input type="checkbox" name="rememberMe" class="rounded border-gray-300 text-primary focus:ring-primary h-4 w-4" />
                        <span class="text-sm text-text-muted">Remember me</span>
                    </label>
                    <a href="#" class="text-sm font-bold text-primary hover:underline">Forgot password?</a>
                </div>

                <button type="submit" class="w-full py-4 bg-black dark:bg-white text-white dark:text-black font-black text-lg rounded-2xl hover:bg-primary dark:hover:bg-primary transition-all duration-300 transform hover:scale-[1.02] shadow-xl hover:shadow-primary/25 relative overflow-hidden group">
                    <span class="relative z-10 flex items-center justify-center gap-2">Login <span class="material-symbols-outlined">arrow_forward</span></span>
                </button>

                <p class="text-center text-sm text-text-muted">
                    Don't have an account? 
                    <a href="/Account/Register" class="font-bold text-primary hover:text-black dark:hover:text-white transition-colors">Sign up now</a>
                </p>
            </form>

        </div>
    </div>
</div>

<script>
    // Cart persistence is now handled in _Layout.cshtml
    // No need to clear cart here
</script>

<style>
    .ease-spring { transition-timing-function: cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
    
    @@keyframes shake {
        10%, 90% { transform: translate3d(-1px, 0, 0); }
        20%, 80% { transform: translate3d(2px, 0, 0); }
        30%, 50%, 70% { transform: translate3d(-4px, 0, 0); }
        40%, 60% { transform: translate3d(4px, 0, 0); }
    }
</style>
