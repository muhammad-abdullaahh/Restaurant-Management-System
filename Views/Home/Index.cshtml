@{
    ViewData["Title"] = "FoodHeaven - Experience Excellence";
    
    var featuredData = (ViewBag.FeaturedItems as IEnumerable<dynamic>);
    var itemsList = new List<dynamic>();

    if (featuredData != null) {
        itemsList = featuredData.ToList();
    }

    // Fallback if DB is empty, use static data for display
    if (!itemsList.Any()) {
       itemsList = new List<dynamic> {
            new { Id=101, Name="Beef Wellington", Price=45.00m, ImageUrl="/images/mains_beef_wellington.jpg", Description="Tender beef filet wrapped in puff pastry with mushroom duxelles." },
            new { Id=102, Name="Lobster Mac & Cheese", Price=26.00m, ImageUrl="https://images.unsplash.com/photo-1555949258-eb67b1ef0ceb?w=800&q=80", Description="Rich and creamy macaroni with chunks of fresh lobster." },
            new { Id=103, Name="Tiramisu", Price=9.00m, ImageUrl="https://images.unsplash.com/photo-1571877227200-a0d98ea607e9?w=800&q=80", Description="Traditional Italian dessert with coffee-soaked ladyfingers." },
            new { Id=104, Name="Grilled Salmon", Price=28.00m, ImageUrl="https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800&q=80", Description="Fresh atlantic salmon with roasted asparagus and lemon butter sauce." },
            new { Id=105, Name="Red Velvet Cake", Price=14.00m, ImageUrl="https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=800&q=80", Description="Classic red velvet sponge with cream cheese frosting." }
        };
    }
}

<!-- Hero Section with Parallax -->
<div class="relative w-full h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0 z-0">
        <img src="~/images/restaurant_hero_bg.png" alt="Hero Background" class="w-full h-full object-cover animate-slow-zoom opacity-90" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/70 via-black/50 to-background-light dark:to-background-dark"></div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto space-y-8">
        <div class="opacity-0 animate-fade-in-down animation-delay-300">
            <span class="px-4 py-2 rounded-full border border-primary/50 text-white bg-black/30 backdrop-blur-md text-sm font-bold uppercase tracking-[0.2em] shadow-lg">
                Taste the Extraordinary
            </span>
        </div>
        <h1 class="text-6xl md:text-8xl font-display font-black text-white leading-tight opacity-0 animate-fade-in-up animation-delay-500">
            Culinary <span class="text-primary italic">Heaven</span> <br /> Awaits You
        </h1>
        <p class="text-xl md:text-2xl text-gray-200 font-light max-w-2xl mx-auto opacity-0 animate-fade-in-up animation-delay-700 leading-relaxed">
            Experience a symphony of flavors crafted with passion, served with elegance, and enjoyed with love.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6 opacity-0 animate-fade-in-up animation-delay-1000 pt-8">
            <a href="/Menu" class="group relative px-8 py-4 bg-primary text-black font-bold text-lg rounded-full overflow-hidden transition-transform hover:scale-105 shadow-[0_0_20px_rgba(255,215,0,0.3)] hover:shadow-[0_0_30px_rgba(255,215,0,0.5)]">
