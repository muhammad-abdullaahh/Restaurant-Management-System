<!-- Process / Journey Section -->
<section class="py-24 bg-zinc-900 text-white relative overflow-hidden">
     <!-- Background with overlay -->
     <div class="absolute inset-0 z-0">
          <img src="~/images/restaurant_hero_bg.png" class="w-full h-full object-cover opacity-20" />
     </div>
     <div class="container mx-auto px-6 relative z-10">
          <div class="text-center mb-16">
               <span class="text-primary font-bold tracking-widest uppercase mb-2 block">How We Work</span>
               <h2 class="text-4xl md:text-5xl font-bold">Our Culinary Journey</h2>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
               <!-- Step 1 -->
               <div class="group text-center space-y-6">
                    <div class="w-24 h-24 mx-auto bg-primary/20 rounded-full flex items-center justify-center group-hover:bg-primary transition-colors duration-500">
                         <span class="material-symbols-outlined text-4xl text-primary group-hover:!text-black">agriculture</span>
                    </div>
                    <h3 class="text-2xl font-bold">Sourcing</h3>
                    <p class="text-gray-400">We partner with local organic farms to select only the finest seasonal ingredients.</p>
               </div>
               <!-- Step 2 -->
               <div class="group text-center space-y-6">
                     <div class="w-24 h-24 mx-auto bg-primary/20 rounded-full flex items-center justify-center group-hover:bg-primary transition-colors duration-500 delay-100">
                         <span class="material-symbols-outlined text-4xl text-primary group-hover:!text-black">skillet</span>
                    </div>
                    <h3 class="text-2xl font-bold">Preparation</h3>
                    <p class="text-gray-400">Our chefs meticulously prep each item daily to ensure maximum freshness.</p>
               </div>
               <!-- Step 3 -->
               <div class="group text-center space-y-6">
                     <div class="w-24 h-24 mx-auto bg-primary/20 rounded-full flex items-center justify-center group-hover:bg-primary transition-colors duration-500 delay-200">
                         <span class="material-symbols-outlined text-4xl text-primary group-hover:!text-black">restaurant</span>
                    </div>
                    <h3 class="text-2xl font-bold">Cooking</h3>
                    <p class="text-gray-400">Masterful techniques meet modern innovation to create the perfect dish.</p>
               </div>
               <!-- Step 4 -->
               <div class="group text-center space-y-6">
                     <div class="w-24 h-24 mx-auto bg-primary/20 rounded-full flex items-center justify-center group-hover:bg-primary transition-colors duration-500 delay-300">
                         <span class="material-symbols-outlined text-4xl text-primary group-hover:!text-black">room_service</span>
                    </div>
                    <h3 class="text-2xl font-bold">Serving</h3>
                    <p class="text-gray-400">Delivered to your table with a smile, ready for you to enjoy.</p>
               </div>
          </div>
     </div>
</section>

<!-- Chef's Specials (Featured) -->
<section class="py-24 bg-card-light dark:bg-card-dark relative overflow-hidden">
     <!-- Decorative Elements -->
    <div class="absolute top-0 right-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-primary/5 rounded-full blur-3xl translate-y-1/2 -translate-x-1/2"></div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row items-end justify-between mb-16 gap-6">
            <div class="text-left">
                <span class="text-primary font-bold tracking-widest uppercase mb-2 block">Handpicked</span>
                <h2 class="text-4xl md:text-5xl font-bold text-text-main dark:text-white">Chef's Specials</h2>
            </div>
             <a href="/Menu" class="group flex items-center gap-2 text-text-main dark:text-white font-bold hover:text-primary transition-colors">
                View Full Menu 
                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6">
             @foreach (var item in itemsList)
             {
                <div class="group bg-background-light dark:bg-background-dark rounded-3xl p-4 shadow-xl hover:-translate-y-3 transition-transform duration-500 border border-transparent hover:border-primary/20">
                    <div class="relative aspect-square rounded-2xl overflow-hidden mb-6">
                        <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" />
                         <div class="absolute top-4 right-4 bg-white/90 dark:bg-black/80 backdrop-blur-sm px-3 py-1 rounded-lg shadow-lg">
                            <span class="text-text-main dark:text-white font-bold">$@item.Price.ToString("F2")</span>
                        </div>
                    </div>
                    <h3 class="text-xl font-bold text-text-main dark:text-white mb-2">@item.Name</h3>
                    <p class="text-text-muted text-sm mb-4 line-clamp-2">@item.Description</p>
                    <button class="w-full py-3 rounded-xl bg-primary/10 text-primary font-bold hover:bg-primary hover:text-black transition-colors flex items-center justify-center gap-2 add-to-cart"
                            data-id="@item.Id" data-name="@item.Name" data-price="@item.Price" data-image="@item.ImageUrl">
                        <span class="material-symbols-outlined text-[20px]">shopping_cart</span> Add
                    </button>
                </div>
             }
        </div>
    </div>
</section>

