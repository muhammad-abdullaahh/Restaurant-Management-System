@{
    ViewData["Title"] = "FoodHeaven - Experience Excellence";
    
    var featuredData = (ViewBag.FeaturedItems as IEnumerable<dynamic>);
    var itemsList = new List<dynamic>();

    if (featuredData != null) {
        itemsList = featuredData.ToList();
    }

    // Fallback if DB is empty, use static data for display
    if (!itemsList.Any()) {
       itemsList = new List<dynamic> {
            new { Id=101, Name="Beef Wellington", Price=45.00m, ImageUrl="/images/mains_beef_wellington.jpg", Description="Tender beef filet wrapped in puff pastry with mushroom duxelles." },
            new { Id=102, Name="Lobster Mac & Cheese", Price=26.00m, ImageUrl="https://images.unsplash.com/photo-1555949258-eb67b1ef0ceb?w=800&q=80", Description="Rich and creamy macaroni with chunks of fresh lobster." },
            new { Id=103, Name="Tiramisu", Price=9.00m, ImageUrl="https://images.unsplash.com/photo-1571877227200-a0d98ea607e9?w=800&q=80", Description="Traditional Italian dessert with coffee-soaked ladyfingers." },
            new { Id=104, Name="Grilled Salmon", Price=28.00m, ImageUrl="https://images.unsplash.com/photo-1519708227418-c8fd9a32b7a2?w=800&q=80", Description="Fresh atlantic salmon with roasted asparagus and lemon butter sauce." },
            new { Id=105, Name="Red Velvet Cake", Price=14.00m, ImageUrl="https://images.unsplash.com/photo-1563729784474-d77dbb933a9e?w=800&q=80", Description="Classic red velvet sponge with cream cheese frosting." },
            new { Id=106, Name="Wagyu Truffle Burger", Price=32.00m, ImageUrl="/images/wagyu_burger.png", Description="Premium wagyu beef with black truffle aioli and aged cheddar." },
            new { Id=107, Name="Seafood Platter", Price=65.00m, ImageUrl="/images/platter_seafood.jpg", Description="A selection of grilled lobster, prawns, and seasonal fish." },
            new { Id=108, Name="Aloo Keema", Price=18.00m, ImageUrl="/images/aloo_keema.jpg", Description="Traditional spiced minced meat with potatoes and fresh herbs." },
            new { Id=109, Name="Classic Baklava", Price=12.00m, ImageUrl="/images/baklava.jpg", Description="Layers of phyllo pastry with chopped nuts and honey syrup." },
            new { Id=110, Name="Pistachio Gelato", Price=8.00m, ImageUrl="/images/ic_pistachio.jpg", Description="Handcrafted Italian-style gelato made with premium pistachios." }
        };
    }
}

<!-- Hero Section with Parallax & Floating Elements -->
<div class="relative w-full h-screen min-h-[700px] flex items-center justify-center overflow-hidden">
    <!-- Hero Background -->
    <div class="absolute inset-0 z-0">
        <img src="~/images/restaurant_hero_bg.png" alt="Hero Background" class="w-full h-full object-cover animate-slow-zoom opacity-90" fetchpriority="high" />
        <div class="absolute inset-0 bg-gradient-to-b from-black/80 via-black/40 to-background-light dark:to-background-dark"></div>
    </div>

    <!-- Floating Decorative Icons -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none select-none">
        <div class="absolute top-[20%] left-[10%] text-primary/20 animate-float opacity-30">
            <span class="material-symbols-outlined text-[80px]">restaurant</span>
        </div>
        <div class="absolute top-[60%] right-[15%] text-primary/20 animate-float-delayed opacity-30">
            <span class="material-symbols-outlined text-[100px]">local_bar</span>
        </div>
        <div class="absolute bottom-[20%] left-[20%] text-primary/10 animate-float opacity-20">
            <span class="material-symbols-outlined text-[60px]">cake</span>
        </div>
    </div>
    
    <div class="relative z-10 text-center px-4 max-w-5xl mx-auto space-y-10">
        <div class="opacity-0 animate-fade-in-down animation-delay-300">
            <span class="px-6 py-2.5 rounded-full border border-primary/40 text-white bg-white/5 backdrop-blur-xl text-xs md:text-sm font-black uppercase tracking-[0.3em] shadow-2xl">
                The Pinnacle of Taste
            </span>
        </div>
        <h1 class="text-6xl md:text-[100px] font-display font-black text-white leading-[0.9] opacity-0 animate-fade-in-up animation-delay-500">
            Culinary <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-yellow-200 italic">Heaven</span> <br /> 
            <span class="text-[0.6em] tracking-tight">Redefined.</span>
        </h1>
        <p class="text-lg md:text-2xl text-white/80 font-light max-w-3xl mx-auto opacity-0 animate-fade-in-up animation-delay-700 leading-relaxed">
            Where every ingredient tells a story of passion, and every dish is a masterpiece crafted just for you.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-8 opacity-0 animate-fade-in-up animation-delay-1000 pt-8">
            <a href="/Menu" class="group relative px-10 py-5 bg-primary text-black font-black text-xl rounded-full overflow-hidden transition-all hover:scale-110 shadow-glow active:scale-95">
                <span class="relative z-10 flex items-center gap-3">Explore Menu <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span></span>
                <div class="absolute inset-0 bg-white/20 translate-x-[-100%] group-hover:translate-x-[100%] transition-transform duration-700 skew-x-12"></div>
            </a>
            <a href="/Reservation/Create" class="group px-10 py-5 bg-white/5 backdrop-blur-2xl border-2 border-white/10 text-white font-black text-xl rounded-full hover:bg-white/10 transition-all hover:scale-110 active:scale-95">
                Secure a Table
            </a>
        </div>
    </div>
    
    <!-- Scroll Down Indicator -->
    <div class="absolute bottom-12 left-1/2 -translate-x-1/2 text-white/50 animate-bounce cursor-pointer hover:text-primary transition-colors" onclick="window.scrollTo({top: window.innerHeight, behavior: 'smooth'})">
        <span class="material-symbols-outlined text-5xl">expand_more</span>
    </div>
</div>

<!-- Features / Stats Bar (Reveal) -->
