<!-- Newsletter Section -->
<section class="py-24 bg-background-light dark:bg-background-dark relative overflow-hidden">
    <div class="container mx-auto px-6 relative z-10">
        <div class="bg-black rounded-[3rem] p-12 md:p-24 text-center relative overflow-hidden group shadow-2xl shadow-primary/20">
             <!-- Background Effects -->
             <div class="absolute inset-0 z-0">
                 <img src="~/images/home_newsletter_bg.jpg" class="w-full h-full object-cover opacity-20 group-hover:scale-105 transition-transform duration-1000 grayscale group-hover:grayscale-0" />
                 <div class="absolute inset-0 bg-gradient-to-t from-black via-black/80 to-transparent"></div>
             </div>
             
             <!-- Content -->
             <div class="relative z-10 max-w-4xl mx-auto space-y-8">
                 <div class="inline-block bg-primary/20 backdrop-blur-md border border-primary/30 rounded-full px-6 py-2 mb-4 animate-bounce">
                     <span class="text-primary font-bold tracking-widest uppercase text-sm">Exclusive Access</span>
                 </div>
                 
                 <h2 class="text-5xl md:text-7xl font-display font-black text-white mb-6 leading-tight">
                     Join the <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-yellow-200">FoodHeaven</span> Family
                 </h2>
                 <p class="text-xl text-gray-300 mb-10 font-light max-w-2xl mx-auto">
                     Unlock a world of culinary delights. Subscribe for secret menu items, chef's special recipes, and VIP event invitations.
                 </p>
                 
                 <form id="newsletterForm" class="flex flex-col md:flex-row gap-4 max-w-2xl mx-auto relative">
                     <div class="flex-1 relative group">
                         <div class="absolute inset-0 bg-gradient-to-r from-primary to-yellow-400 rounded-full blur opacity-25 group-hover:opacity-50 transition-opacity"></div>
                         <input type="email" id="newsletterEmail" placeholder="Your email address" 
                                class="relative w-full px-8 py-5 rounded-full bg-white/10 backdrop-blur-md border border-white/20 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:bg-white/20 transition-all text-lg" required />
                     </div>
                     <button type="submit" id="newsletterBtn" class="relative px-12 py-5 bg-gradient-to-r from-primary to-[#FFD700] hover:to-[#ffc400] text-black font-black rounded-full text-lg hover:scale-105 active:scale-95 transition-all shadow-xl shadow-primary/20 flex items-center justify-center gap-2 group">
                         <span>Subscribe</span>
