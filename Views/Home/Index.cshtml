<!-- Chef's Specials (Featured) (Reveal) -->
<section class="py-32 bg-card-light dark:bg-card-dark relative overflow-hidden">
    <!-- Decorative Glow -->
    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2"></div>
    <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-[120px] translate-y-1/2 -translate-x-1/2"></div>

    <div class="container mx-auto px-6 relative z-10">
        <div class="flex flex-col md:flex-row items-end justify-between mb-20 gap-8 reveal">
            <div class="text-left max-w-2xl">
                <span class="text-primary font-black tracking-[0.3em] uppercase mb-3 block opacity-80">Our Pride</span>
                <h2 class="text-5xl md:text-6xl font-black text-text-main dark:text-white tracking-tighter">Chef's <span class="text-primary">Masterpieces</span></h2>
                <p class="text-text-muted mt-4 text-lg">Hand-selected by our head chef to represent the very best of FoodHeaven's culinary innovation.</p>
            </div>
             <a href="/Menu" class="group flex items-center gap-3 text-text-main dark:text-white font-black hover:text-primary transition-colors text-xl">
                Full Menu 
                <span class="material-symbols-outlined group-hover:translate-x-2 transition-transform">arrow_forward</span>
            </a>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-8 reveal">
             @foreach (var item in itemsList)
             {
                <div class="group bg-background-light dark:bg-background-dark rounded-[2.5rem] p-6 shadow-xl hover:-translate-y-4 transition-all duration-500 border-2 border-transparent hover:border-primary/20 flex flex-col h-full">
                    <div class="relative aspect-[4/5] rounded-[2rem] overflow-hidden mb-8 shadow-2xl">
                        <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110" loading="lazy" />
                         <div class="absolute top-5 right-5 bg-white/95 dark:bg-black/80 backdrop-blur-xl px-4 py-2 rounded-2xl shadow-xl">
                            <span class="text-text-main dark:text-white font-black text-lg">$@item.Price.ToString("F2")</span>
                        </div>
                    </div>
                    <div class="flex-grow">
                        <h3 class="text-2xl font-black text-text-main dark:text-white mb-3 tracking-tight">@item.Name</h3>
                        <p class="text-text-muted text-sm mb-6 line-clamp-3 leading-relaxed">@item.Description</p>
                    </div>
                    <button class="w-full py-5 rounded-[1.5rem] bg-primary text-black font-black hover:bg-primary-dark transition-all flex items-center justify-center gap-3 add-to-cart shadow-gold-glow active:scale-95"
                            data-id="@item.Id" data-name="@item.Name" data-price="@item.Price" data-image="@item.ImageUrl">
                        <span class="material-symbols-outlined text-[24px] fill-current">shopping_cart</span> Add to Order
                    </button>
                </div>
             }
        </div>
    </div>
</section>

<!-- Process / Journey Section (Reveal) -->
<section class="py-32 bg-zinc-950 text-white relative overflow-hidden">
