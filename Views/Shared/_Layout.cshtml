                    <!-- Hours -->
                    <div class="space-y-8">
                        <h3 class="text-xl font-bold text-white tracking-tight flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-primary"></span>
                            Working Hours
                        </h3>
                        <div class="bg-white/5 border border-white/10 rounded-3xl p-6 relative overflow-hidden group hover:border-primary/30 transition-all">
                             <div class="flex items-center justify-between mb-6">
                                <div id="status-container" class="flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20">
                                    <span class="relative flex h-2 w-2">
                                       <span id="status-ping" class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                                       <span id="status-dot" class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
                                    </span>
                                    <span id="status-text" class="text-[10px] font-black text-green-400 uppercase tracking-wide">Open Now</span>
                                </div>
                                <span class="material-symbols-outlined text-gray-500 group-hover:text-primary transition-colors">schedule</span>
                            </div>
                            <div class="space-y-4">
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-gray-400">Mon - Fri</span>
                                    <span class="text-white font-bold">09:00 - 03:00</span>
                                </div>
                                <div class="flex justify-between items-center text-sm">
                                    <span class="text-gray-400">Sat - Sun</span>
                                    <span class="text-primary font-bold">09:00 - 04:00</span>
