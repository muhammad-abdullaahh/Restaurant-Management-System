            </div>
        </footer>

        <script>
            function updateBusinessStatus() {
                const now = new Date();
                const day = now.getDay(); 
                const hour = now.getHours();
                let isOpen = false;

                if (hour >= 9) {
                    isOpen = true;
                } else {
                    const prevDay = (day === 0) ? 6 : day - 1;
                    if (prevDay === 0 || prevDay === 6) {
                        if (hour < 4) isOpen = true;
                    } else {
                        if (hour < 3) isOpen = true;
                    }
                }

                const container = document.getElementById('status-container');
                const text = document.getElementById('status-text');
                const dot = document.getElementById('status-dot');
                const ping = document.getElementById('status-ping');

                if (isOpen) {
                    container.className = "flex items-center gap-2 px-3 py-1 rounded-full bg-green-500/10 border border-green-500/20 transition-all duration-300";
                    text.innerText = "Open Now";
                    text.className = "text-[10px] font-black text-green-400 uppercase tracking-wide";
                    dot.className = "relative inline-flex rounded-full h-2 w-2 bg-green-500";
                    ping.style.display = "inline-flex";
                } else {
                    container.className = "flex items-center gap-2 px-3 py-1 rounded-full bg-red-500/10 border border-red-500/20 transition-all duration-300";
                    text.innerText = "Closed";
                    text.className = "text-[10px] font-black text-red-500 uppercase tracking-wide";
                    dot.className = "relative inline-flex rounded-full h-2 w-2 bg-red-500";
                    ping.style.display = "none";
                }
            }
            document.addEventListener('DOMContentLoaded', updateBusinessStatus);
            setInterval(updateBusinessStatus, 60000);
        </script>
        
    </div>

    <!-- Scripts -->
    <script>
        // User-specific persistent cart management
        (function() {
            @if (User.Identity?.IsAuthenticated == true)
            {
                <text>
                var currentUser = '@User.Identity.Name';
                var previousUser = localStorage.getItem('foodHeaven_current_user');
                
                // If switching users, save the old user's cart first
                if (previousUser && previousUser !== currentUser) {
                    console.log('Switching from ' + previousUser + ' to ' + currentUser);
                    
                    // Save previous user's cart
                var currentCart = localStorage.getItem('foodHeaven_cart');
                    if (currentCart) {
                        localStorage.setItem('foodHeaven_cart_' + previousUser, currentCart);
                    }
                    
                    // Clear current cart when switching users
                    localStorage.removeItem('foodHeaven_cart');
                    localStorage.removeItem('foodHeaven_direct_checkout');
                    
                    // Load new user's saved cart
                    var savedCart = localStorage.getItem('foodHeaven_cart_' + currentUser);
                    if (savedCart) {
                        console.log('Restoring cart for ' + currentUser + ':', savedCart);
                        localStorage.setItem('foodHeaven_cart', savedCart);
                    } else {
                        console.log('No saved cart for ' + currentUser);
                    }
                } else if (!previousUser) {
                    // First time login for this session - load saved cart if exists
                    var savedCart = localStorage.getItem('foodHeaven_cart_' + currentUser);
                    if (savedCart) {
                        console.log('Restoring cart for ' + currentUser + ':', savedCart);
                        localStorage.setItem('foodHeaven_cart', savedCart);
                    }
                }
                
                // Update current user
                localStorage.setItem('foodHeaven_current_user', currentUser);
                </text>
            }
            else
            {
                <text>
                // User not logged in
                var previousUser = localStorage.getItem('foodHeaven_current_user');
                
                // Save current cart to previous user if exists
                if (previousUser) {
                    var currentCart = localStorage.getItem('foodHeaven_cart');
                    if (currentCart) {
                        localStorage.setItem('foodHeaven_cart_' + previousUser, currentCart);
                        console.log('Saved cart for ' + previousUser + ' on logout');
                    }
                }
                
                // Clear current session
                localStorage.removeItem('foodHeaven_current_user');
                localStorage.removeItem('foodHeaven_cart');
                localStorage.removeItem('foodHeaven_direct_checkout');
                sessionStorage.clear();
                </text>
            }
        })();
    </script>
    <script>
        // Preloader Logic with Failsafe
        (function() {
            const hidePreloader = () => {
                const preloader = document.getElementById('preloader');
                if (preloader && preloader.style.visibility !== 'hidden') {
                    preloader.style.opacity = '0';
                    setTimeout(() => {
                        preloader.style.visibility = 'hidden';
                    }, 800);
                }
            };

            // Hide on load
            window.addEventListener('load', () => {
                setTimeout(hidePreloader, 100);
            });

            // Failsafe: Hide after 5 seconds regardless of load
            setTimeout(hidePreloader, 5000);
        })();

        // Global Scroll Reveal & Header Logic
        (function() {
            const header = document.getElementById('main-header');
            const headerContainer = document.getElementById('header-container');
            
            // 1. Reveal Observer
            const revealObserver = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.add('active');
                        revealObserver.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.1 });

            const initReveals = () => {
                document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el));
            };

            // 2. Header Scroll Logic
            const handleScroll = () => {
                const headerTexts = document.querySelectorAll('.header-text');
                const headerBgs = document.querySelectorAll('.header-text-bg');
                
                if (window.scrollY > 50) {
                    header.classList.add('scrolled');
                    header.classList.remove('bg-black/10', 'backdrop-blur-md', 'border-white/5');
                    headerContainer.classList.remove('py-6', 'md:py-8');
                    headerContainer.classList.add('py-3', 'md:py-4');
                    headerTexts.forEach(el => {
                        el.classList.remove('text-white');
                        el.classList.add('text-text-main', 'dark:text-white');
                    });
                    headerBgs.forEach(el => {
                        el.classList.remove('bg-white/10', 'hover:bg-white/20', 'text-white');
                        el.classList.add('bg-gray-100', 'dark:bg-white/5', 'text-text-main', 'dark:text-white');
                    });
                } else {
                    header.classList.remove('scrolled');
                    header.classList.add('bg-black/10', 'backdrop-blur-md', 'border-white/5');
                    headerContainer.classList.add('py-6', 'md:py-8');
                    headerContainer.classList.remove('py-3', 'md:py-4');
                    headerTexts.forEach(el => {
                        el.classList.add('text-white');
                        el.classList.remove('text-text-main', 'dark:text-white');
                    });
                    headerBgs.forEach(el => {
                        el.classList.add('bg-white/10', 'hover:bg-white/20', 'text-white');
                        el.classList.remove('bg-gray-100', 'dark:bg-white/5', 'text-text-main', 'dark:text-white');
                    });
                }
            };

            // Initialize
            document.addEventListener('DOMContentLoaded', () => {
                initReveals();
                handleScroll();
            });
            window.addEventListener('scroll', handleScroll);

            // Failsafe: Reveal all after 6 seconds in case observer fails
            setTimeout(() => {
                document.querySelectorAll('.reveal').forEach(el => el.classList.add('active'));
            }, 6000);
        })();
    </script>
    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>


